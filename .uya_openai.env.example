# Dou Dizhu AI config for the simulator demo, web build, and Cloudflare Worker deploy flow.
# Copy to `.uya_openai.env` or point `UYA_OPENAI_CONFIG_FILE` at your own file.
# `UPSTREAM_OPENAI_API_KEY` is used by `make ddz-openai-proxy-secrets*`.
# `OPENAI_API_KEY` is the optional client bearer token sent to the Worker.

UPSTREAM_OPENAI_API_KEY=sk-your-upstream-openai-key
CLIENT_BEARER_TOKEN=
UYA_DDZ_USE_OPENAI=1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=
OPENAI_API_PATH=/ddz/decision
