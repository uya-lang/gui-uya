export fn custom_retained_sync(
    custom: &CustomRetained,
    cpu_value: i32,
    mem_value: i32,
    net_value: i32,
    keyboard_text_value: &const byte,
    uppercase_mode: bool,
    status_text: &const byte
) void {
    if custom == null {
        return;
    }
    custom_retained_init(custom);

    const default_subtitle: &const byte = "Click gauges to tune values, or tap keyboard keys to edit the buffer." as &const byte;
    var subtitle: &const byte = default_subtitle;
    if status_text != null && status_text[0] != 0 {
        subtitle = status_text;
    }
    if !custom_cstr_eq(&custom.subtitle_text[0], subtitle) {
        custom_copy_cstr(&custom.subtitle_text[0], 160usize, subtitle);
        _ = custom.hero_subtitle.set_text(&custom.subtitle_text[0]);
    }

    var keyboard_text: &const byte = "HELLO UYAGUI" as &const byte;
    if keyboard_text_value != null && keyboard_text_value[0] != 0 {
        keyboard_text = keyboard_text_value;
    }
    if !custom_cstr_eq(&custom.keyboard_text_buf[0], keyboard_text) {
        custom_copy_cstr(&custom.keyboard_text_buf[0], 64usize, keyboard_text);
        _ = custom.keyboard_text_label.set_text(&custom.keyboard_text_buf[0]);
    }

    if custom.cpu_value != cpu_value {
        custom.cpu_value = cpu_value;
        _ = snprintf(&custom.cpu_text[0], 24usize, "CPU %d%%" as &const byte, cpu_value);
        _ = custom.cpu_label.set_text(&custom.cpu_text[0]);
        custom_draw_gauge(&custom.cpu_gauge, cpu_value, Color{ r: 16, g: 185, b: 129, a: 255 });
    }
    if custom.mem_value != mem_value {
        custom.mem_value = mem_value;
        _ = snprintf(&custom.mem_text[0], 24usize, "Memory %d%%" as &const byte, mem_value);
        _ = custom.mem_label.set_text(&custom.mem_text[0]);
        custom_draw_gauge(&custom.mem_gauge, mem_value, Color{ r: 249, g: 115, b: 22, a: 255 });
    }
    if custom.net_value != net_value {
        custom.net_value = net_value;
        _ = snprintf(&custom.net_text[0], 24usize, "Network %d%%" as &const byte, net_value);
        _ = custom.net_label.set_text(&custom.net_text[0]);
        custom_draw_gauge(&custom.net_gauge, net_value, Color{ r: 239, g: 68, b: 68, a: 255 });
    }

    if custom.uppercase_mode != uppercase_mode {
        custom.uppercase_mode = uppercase_mode;
        _ = custom.shift_btn.set_label("Shift");
        if uppercase_mode {
            _ = custom.shift_btn.set_variant(BtnVariant.Filled, 0u32);
        } else {
            _ = custom.shift_btn.set_variant(BtnVariant.Outlined, 0u32);
        }
        custom.shift_btn.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(11u8) as u32);
    }
}

export fn render_demo_custom_retained_state(
    custom: &CustomRetained,
    ctx: &RenderCtx,
    origin_x: i16,
    origin_y: i16,
    cpu_value: i32,
    mem_value: i32,
    net_value: i32,
    keyboard_text_value: &const byte,
    uppercase_mode: bool,
    status_text: &const byte
) void {
    if custom == null {
        return;
    }
    custom_retained_sync(custom, cpu_value, mem_value, net_value, keyboard_text_value, uppercase_mode, status_text);
    custom.page.widget.at(origin_x, origin_y);
    custom.page.render(ctx);
}

export fn render_demo_custom_state(
    ctx: &RenderCtx,
    origin_x: i16,
    origin_y: i16,
    cpu_value: i32,
    mem_value: i32,
    net_value: i32,
    keyboard_text_value: &const byte,
    uppercase_mode: bool,
    status_text: &const byte
) void {
    var custom: CustomRetained = custom_retained_new();
    render_demo_custom_retained_state(&custom, ctx, origin_x, origin_y, cpu_value, mem_value, net_value, keyboard_text_value, uppercase_mode, status_text);
}

export fn render_demo_custom(ctx: &RenderCtx, origin_x: i16, origin_y: i16) void {
    render_demo_custom_state(ctx, origin_x, origin_y, 32, 68, 91, "HELLO UYAGUI", true, "Custom widgets static preview");
}

export fn run_demo_custom() i32 {
    const bytes_len: usize = framebuffer_required_bytes(SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, PixelFormat.ARGB8888);
    const bytes: &byte = malloc(bytes_len) as &byte;
    if bytes == null {
        return 2;
    }
    defer {
        free(bytes as &void);
    }
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(bytes, SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, SIM_DEFAULT_RES_WIDTH * 4u16, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 248, g: 245, b: 239, a: 255 });
    render_demo_custom(&ctx, 0, 0);
    if ctx.stats.text_ops == 0u32 || ctx.stats.image_ops == 0u32 || ctx.stats.rect_ops == 0u32 {
        return 1;
    }
    return 0;
}
