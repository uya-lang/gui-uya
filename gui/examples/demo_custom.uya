        space_btn: custom_action_key("Space"),
        enter_btn: custom_action_key("Enter"),
        notes_panel: Panel.new(),
        notes_title: Label.new("Pattern"),
        notes_text: Label.new("The gauge uses Canvas drawing primitives, while the keyboard composes GridView + Button into a reusable on-screen input surface."),
