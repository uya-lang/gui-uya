export fn custom_retained_new() CustomRetained {
    return CustomRetained{
        tree: obj_tree_new(),
        page: Page.new("Custom"),
        hero: Panel.new(),
        hero_title: Label.new("Custom Control Lab"),
        hero_subtitle: Label.new("Click gauges to tune values, or tap keyboard keys to edit the buffer."),
        gauges_panel: Panel.new(),
        gauges_title: Label.new("Gauge Cards"),
        cpu_label: Label.new("CPU 32%"),
        cpu_gauge: Canvas.new(),
        mem_label: Label.new("Memory 68%"),
        mem_gauge: Canvas.new(),
        net_label: Label.new("Network 91%"),
        net_gauge: Canvas.new(),
        keyboard_panel: Panel.new(),
        keyboard_title: Label.new("Keyboard Prototype"),
        keyboard_text_label: Label.new("HELLO UYAGUI"),
        row1: GridView.new(),
        key_q: custom_small_key("Q"),
