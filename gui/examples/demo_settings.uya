use core.color.Color;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_new;
use render.ctx.RenderCtx;
use render.ctx.render_ctx_new;
use style.StyleProp;
use widget.lbl.Label;
use widget.page.Page;
use widget.panel.Panel;
use widget.slider.Slider;
use widget.switch.Switch;

export fn render_demo_settings_state(ctx: &RenderCtx, origin_x: i16, origin_y: i16, wifi_enabled: bool, alerts_enabled: bool, brightness_value: i32) void {
    var page: Page = Page.new("Settings");
    page.widget.at(origin_x, origin_y);
    page.widget.size(640, 480);
    page.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 245, g: 248, b: 252, a: 255 });

    var panel: Panel = Panel.new();
    panel.widget.at(40, 32);
    panel.widget.size(560, 416);

    var title: Label = Label.new("Settings");
    title.widget.at(40, 32);
    title.widget.size(220, 36);
    title.widget.base.style.set_u32(StyleProp.FontSize, 28u32);
    title.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 15, g: 23, b: 42, a: 255 });

    var wifi_label: Label = Label.new("Wi-Fi");
    wifi_label.widget.at(40, 104);
    wifi_label.widget.size(160, 24);
    wifi_label.widget.base.style.set_u32(StyleProp.FontSize, 18u32);
    var wifi: Switch = Switch.new(wifi_enabled);
    wifi.widget.at(416, 92);

    var notif_label: Label = Label.new("Alerts");
    notif_label.widget.at(40, 176);
    notif_label.widget.size(160, 24);
    notif_label.widget.base.style.set_u32(StyleProp.FontSize, 18u32);
    var notif: Switch = Switch.new(alerts_enabled);
    notif.widget.at(416, 164);

    var bright_label: Label = Label.new("Brightness");
    bright_label.widget.at(40, 264);
    bright_label.widget.size(200, 24);
    bright_label.widget.base.style.set_u32(StyleProp.FontSize, 18u32);
    var brightness: Slider = Slider.new(0, 100, brightness_value);
    brightness.widget.at(40, 312);
    brightness.widget.size(480, 20);

    page.add(panel.obj());
    panel.add(title.obj());
    panel.add(wifi_label.obj());
    panel.add(wifi.obj());
    panel.add(notif_label.obj());
    panel.add(notif.obj());
    panel.add(bright_label.obj());
    panel.add(brightness.obj());
    page.render(ctx);
}

export fn render_demo_settings(ctx: &RenderCtx, origin_x: i16, origin_y: i16) void {
    render_demo_settings_state(ctx, origin_x, origin_y, true, false, 68);
}

export fn run_demo_settings() i32 {
    var bytes: [byte: 1228800] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 640, 480, 2560, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 245, g: 248, b: 252, a: 255 });
    render_demo_settings(&ctx, 0, 0);
    if ctx.stats.text_ops == 0u32 || ctx.stats.circle_ops == 0u32 {
        return 1;
    }
    return 0;
}
