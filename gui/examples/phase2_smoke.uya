use std.runtime.entry;

use core.color.Color;
use core.color.WHITE;
use core.rect.Rect;
use platform.disp.DisplayCtx;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.display_ctx_new;
use platform.disp.framebuffer_new;
use render.batch.DrawBatch;
use render.batch.draw_batch_new;
use render.cpu_backend.cpu_render_batch_execute;
use render.ctx.RenderCtx;
use render.ctx.ctx_pixel;
use render.ctx.render_ctx_new;
use render.font.Font;
use render.font.TextAlign;
use render.font.draw_text_aligned;
use render.font.font_default;
use render.img.ImageData;
use render.img.draw_image_scaled;
use render.img.image_data_new;
use render.zerocopy.ZeroCopyCtx;
use render.zerocopy.zerocopy_ctx_new;

/// 运行 `phase2_smoke` 场景并返回退出码。
export fn run_phase2_smoke() i32 {
    var front_bytes: [byte: 1024] = [];
    var back_bytes: [byte: 1024] = [];
    var img_bytes: [byte: 12] = [255, 0, 0,   0, 255, 0,   0, 0, 255,   255, 255, 255];

    const front: FrameBuffer = framebuffer_new(&front_bytes[0], 16, 16, 64, PixelFormat.ARGB8888);
    const back: FrameBuffer = framebuffer_new(&back_bytes[0], 16, 16, 64, PixelFormat.ARGB8888);
    var display: DisplayCtx = display_ctx_new(front, back);
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&back_bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const font: Font = font_default();
    const img: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);
    var batch: DrawBatch = draw_batch_new();
    var zc: ZeroCopyCtx = zerocopy_ctx_new(&display);
    const white0: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white1: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    ctx.clear(Color{ r: 24, g: 28, b: 36, a: 255 });
    ctx.fill_round_rect(Rect{ x: 1, y: 1, w: 6, h: 6 }, 2, Color{ r: 255, g: 0, b: 0, a: 255 });
    ctx.draw_arc(8, 8, 4, 0, 180, 1, white0);
    draw_image_scaled(&ctx, Rect{ x: 8, y: 1, w: 4, h: 4 }, &img);
    draw_text_aligned(&ctx, Rect{ x: 0, y: 10, w: 16, h: 6 }, "P2", 2usize, &font, white1, TextAlign.Center);

    batch.push_fill_rect(Rect{ x: 12, y: 12, w: 2, h: 2 }, Color{ r: 0, g: 255, b: 0, a: 255 });
    batch.push_draw_rect(Rect{ x: 11, y: 11, w: 4, h: 4 }, Color{ r: 255, g: 255, b: 255, a: 255 }, 1);
    batch.optimize();
    cpu_render_batch_execute(&ctx, &batch);
    zc.present(Rect{ x: 0, y: 0, w: 16, h: 16 });

    if display.frame_id != 1u32 {
        return 1;
    }
    if ctx_pixel(&ctx, 2, 2) != Color{ r: 255, g: 0, b: 0, a: 255 } {
        return 2;
    }
    if ctx_pixel(&ctx, 13, 13) != Color{ r: 0, g: 255, b: 0, a: 255 } {
        return 3;
    }
    return 0;
}
