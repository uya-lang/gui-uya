use std.runtime.entry;

use core.event.EventQueue;
use core.event.EventType;
use core.event.InputDev;
use core.event.event_point;
use core.event.event_queue_new;
use core.obj.GuiObj;
use core.obj.gui_obj_default;
use core.obj.gui_obj_register;
use core.obj.gui_obj_reset_registry;
use core.obj_tree.ObjTree;
use core.obj_tree.obj_tree_new;
use core.point.Point;
use core.rect.Rect;

/// 运行 `phase0_smoke` 场景并返回退出码。
export fn run_phase0_smoke() i32 {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 200, h: 200 });
    child.set_area(Rect{ x: 20, y: 20, w: 50, h: 50 });

    if !gui_obj_register(0, &root) {
        return 1;
    }
    if !gui_obj_register(1, &child) {
        return 2;
    }

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    if tree.find_at_point(0, Point{ x: 25, y: 25 }) != 1 {
        return 3;
    }

    var queue: EventQueue = event_queue_new();
    if !queue.push(event_point(EventType.Click, InputDev.Touch, 1, 10, Point{ x: 25, y: 25 })) {
        return 4;
    }

    return 0;
}
