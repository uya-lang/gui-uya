    chapter_offsets: [usize: 12],
    scroll_y: i32,
    auto_scroll: bool,
    drag_active: bool,
    drag_last_y: i16,
    last_auto_tick_ms: u32,
}

fn novel_title_font() &Font {
    const font: &Font = font_ui_default_ref(NOVEL_TITLE_FONT_SIZE);
    if font != null {
        return font;
    }
    return font_system_ui_ref(NOVEL_TITLE_FONT_SIZE);
}

