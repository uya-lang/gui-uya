struct NovelUtf8CodePoint {
    codepoint: u32,
    span: usize,
}

struct NovelLine {
    start: usize,
    len: usize,
}

export struct NovelRetained {
    ready: bool,
    text: [byte: 49152],
    text_len: usize,
    char_count: i32,
    lines: [NovelLine: 1536],
