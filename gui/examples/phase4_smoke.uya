use anim.easing.EasingType;
use anim.timeline.AnimManager;
use anim.timeline.anim_manager_new;
use anim.tween.AnimProp;
use anim.tween.Tween;
use anim.tween.anim_value_i32;
use core.color.Color;
use core.event.Event;
use core.event.EventType;
use core.event.event_none;
use core.obj.gui_obj_register;
use core.obj.gui_obj_reset_registry;
use core.point.Point;
use core.rect.Rect;
use platform.disp.DisplayDriverKind;
use platform.disp.DisplayDriverProfile;
use platform.disp.DisplayCtx;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.display_ctx_new;
use platform.disp.display_driver_profile;
use platform.disp.framebuffer_new;
use platform.indev.IInputDev;
use platform.indev.InputManager;
use platform.indev.TouchDriver;
use platform.indev.input_manager_new;
use platform.indev.touch_driver_new;
use render.ctx.RenderCtx;
use render.ctx.render_ctx_new;
use render.img.ImageData;
use render.img.image_data_new;
use res.cache.ImageCache;
use res.cache.image_cache_new;
use res.cache.image_cache_put_async;
use res.fs.RomFileSystem;
use res.fs.fs_read_async;
use res.fs.rom_fs_new;
use style.StyleProp;
use std.async.block_on;
use widget.page.Page;
use widget.page.PageNavigator;
use widget.page.PageTransitionKind;
use widget.page.page_navigator_new;

export fn run_phase4_smoke() i32 {
    gui_obj_reset_registry();

    var front_bytes: [byte: 16384] = [];
    var back_bytes: [byte: 16384] = [];
    const front: FrameBuffer = framebuffer_new(&front_bytes[0], 64, 48, 256, PixelFormat.ARGB8888);
    const back: FrameBuffer = framebuffer_new(&back_bytes[0], 64, 48, 256, PixelFormat.ARGB8888);
    var display: DisplayCtx = display_ctx_new(front, back);
    _ = display;
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&back_bytes[0], 64, 48, 256, PixelFormat.ARGB8888));

    var page_a: Page = Page.new("P4-A");
    var page_b: Page = Page.new("P4-B");
    page_a.widget.at(0, 0);
    page_a.widget.size(64, 48);
    page_b.widget.at(0, 0);
    page_b.widget.size(64, 48);
    page_a.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 255, g: 243, b: 236, a: 255 });
    page_b.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 232, g: 244, b: 255, a: 255 });

    _ = gui_obj_register(1, page_a.obj());
    _ = gui_obj_register(2, page_b.obj());

    var nav: PageNavigator = page_navigator_new(Rect{ x: 0, y: 0, w: 64, h: 48 });
    _ = nav.push(page_a.obj(), PageTransitionKind.None, 0u32);
    _ = nav.push(page_b.obj(), PageTransitionKind.SlideLeft, 120u32);
    nav.render(&ctx);
    nav.update(120u32);
    if nav.top() != page_b.obj() {
        return 1;
    }

    var manager: AnimManager = anim_manager_new();
    var tween: Tween = Tween.new(2, AnimProp.X, anim_value_i32(12), 100u32);
    tween.with_from_i32(0);
    tween.with_easing(EasingType.EaseOutCubic);
    _ = manager.start_tween(&tween) catch {
        return 2;
    };
    manager.update_all(100u32);
    if page_b.widget.base.x != 12 {
        return 3;
    }

    var rom: RomFileSystem = rom_fs_new();
    var blob: [byte: 4] = [80, 52, 33, 10];
    var fs_out: [byte: 8] = [];
    _ = rom.add_file("phase4.bin", &blob[0] as &const byte, 4usize);
    const fs_n: usize = block_on<usize>(fs_read_async<RomFileSystem>(&rom, "phase4.bin", &fs_out[0], 8usize)) catch {
        return 4;
    };
    if fs_n != 4usize || fs_out[0] != 80 {
        return 5;
    }

    var cache: ImageCache = image_cache_new(4, 64u32);
    var img_bytes: [byte: 12] = [255, 0, 0,   0, 255, 0,   0, 0, 255,   255, 255, 255];
    const img: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);
    const loaded: bool = block_on<bool>(image_cache_put_async(&cache, 9u32, img)) catch {
        return 6;
    };
    if !loaded {
        return 7;
    }

    var out_img: ImageData = img;
    if !cache.get(9u32, &out_img) || out_img.size.w != 2 {
        return 8;
    }

    var touch: TouchDriver = touch_driver_new();
    var manager_input: InputManager = input_manager_new();
    var touch_dev: IInputDev = touch;
    _ = manager_input.attach(&touch_dev);
    touch.feed(3, 10u32, Point{ x: 4, y: 4 }, true);
    var evt: Event = event_none();
    if !manager_input.poll(&evt) || evt.event_type != EventType.Press {
        return 9;
    }

    const st7789: DisplayDriverProfile = display_driver_profile(DisplayDriverKind.ST7789);
    if st7789.width != 240 || st7789.height != 320 {
        return 10;
    }

    return 0;
}
