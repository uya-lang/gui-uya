extern fn malloc(size: usize) &void;
extern fn free(ptr: &void) void;

fn widgets_cstr_eq(a: &const byte, b: &const byte) bool {
    if a == null && b == null {
        return true;
    }
    if a == null || b == null {
        return false;
    }
    var len: usize = 0usize;
    while a[len] != 0 && b[len] != 0 {
        len = len + 1usize;
    }
    if a[len] != 0 || b[len] != 0 {
        return false;
    }
    return strncmp(a as *const byte, b as *const byte, len) == 0;
}

fn widgets_copy_cstr(dst: &byte, cap: usize, src: &const byte) void {
    if dst == null || cap == 0usize {
        return;
    }
    if src == null {
        dst[0] = 0;
        return;
    }
    var i: usize = 0usize;
    while i + 1usize < cap && src[i] != 0 {
        dst[i] = src[i];
        i = i + 1usize;
    }
    dst[i] = 0;
}

fn widgets_sync_button(button: &Button, label: &const byte, variant: BtnVariant, icon: u32, font_size: u8) void {
    if button == null {
        return;
    }
    _ = button.set_label(label);
    _ = button.set_variant(variant, icon);
    button.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(font_size) as u32);
}

fn widgets_seed_preview(bytes: &byte) void {
    if bytes == null {
        return;
    }
    var y: i32 = 0;
    while y < 8 {
        var x: i32 = 0;
        while x < 8 {
            const idx: i32 = (y * 8 + x) * 3;
            bytes[idx as usize] = ((32 + x * 24) as! byte).value;
            bytes[(idx + 1) as usize] = ((72 + y * 18) as! byte).value;
            bytes[(idx + 2) as usize] = ((180 - x * 10 + y * 4) as! byte).value;
            x = x + 1;
        }
        y = y + 1;
    }
}

fn widgets_fill_chart(chart: &Chart, volume_value: i32, auto_refresh: bool, selected_item: i32, action_idx: i32) void {
    _ = chart.clear();
    if auto_refresh || action_idx == 1 {
        chart.chart_type = ChartType.Area;
    } else {
        chart.chart_type = ChartType.Bar;
    }
    const base: i32 = 14 + selected_item * 3 + action_idx * 5;
    const peak: i32 = volume_value / 2;
    _ = chart.add_point(base + 8);
    _ = chart.add_point(base + peak / 3);
    _ = chart.add_point(base + 11);
    _ = chart.add_point(base + peak / 2);
    _ = chart.add_point(base + 14);
    _ = chart.add_point(base + peak / 2 + 6);
}

export struct WidgetsRetained {
    tree: ObjTree,
    page: Page,
    hero: Panel,
    hero_title: Label,
    hero_subtitle: Label,
    controls: Panel,
    controls_title: Label,
    primary_btn: Button,
    secondary_btn: Button,
    text_btn: Button,
    sync_btn: Button,
    slider_label: Label,
    slider: Slider,
    switch_label: Label,
    toggle: Switch,
    visuals: Panel,
    visuals_title: Label,
    preview: Image,
    canvas: Canvas,
    visuals_note: Label,
    collections: Panel,
    collections_title: Label,
    collections_note: Label,
    inbox: ListView,
    data_panel: Panel,
    data_title: Label,
    chart: Chart,
    actions: GridView,
    archive_btn: Button,
    ship_btn: Button,
    preview_rgb: [byte: 192],
    preview_data: ImageData,
    canvas_bytes: [byte: 21504],
    slider_text: [byte: 32],
    subtitle_text: [byte: 160],
    ready: bool,
    control_idx: i32,
    volume_value: i32,
    auto_refresh: bool,
    selected_item: i32,
    action_idx: i32,
}

export fn widgets_retained_new() WidgetsRetained {
    return WidgetsRetained{
        tree: obj_tree_new(),
        page: Page.new("Widgets"),
        hero: Panel.new(),
        hero_title: Label.new("Widget Showcase"),
        hero_subtitle: Label.new("Click buttons, drag slider, toggle switch, select list rows."),
        controls: Panel.new(),
        controls_title: Label.new("Controls"),
        primary_btn: Button.outlined("Primary"),
        secondary_btn: Button.outlined("Outlined"),
        text_btn: Button.text_only("Quiet Action"),
        sync_btn: Button.outlined("Sync"),
        slider_label: Label.new("Volume 72%"),
        slider: Slider.new(0, 100, 72),
        switch_label: Label.new("Auto refresh"),
        toggle: Switch.new(true),
        visuals: Panel.new(),
        visuals_title: Label.new("Media & Draw"),
        preview: Image.from_data(null),
        canvas: Canvas.new(),
        visuals_note: Label.new("Image shows bitmap scaling, while Canvas draws a tiny dashboard preview into an off-screen buffer."),
        collections: Panel.new(),
        collections_title: Label.new("Collections"),
        collections_note: Label.new("ListView handles selection and scrolling; GridView lays out quick actions in compact cells."),
        inbox: ListView.new(),
        data_panel: Panel.new(),
        data_title: Label.new("Data Widgets"),
        chart: Chart.new(),
        actions: GridView.new(),
        archive_btn: Button.outlined("Archive"),
        ship_btn: Button.outlined("Ship"),
        preview_rgb: [],
        preview_data: empty_image(),
        canvas_bytes: [],
        slider_text: [],
        subtitle_text: [],
        ready: false,
        control_idx: -1,
        volume_value: -1,
        auto_refresh: false,
        selected_item: -1,
        action_idx: -1,
    };
}

