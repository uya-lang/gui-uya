    widgets.page.widget.at(0, 0);
    widgets.page.widget.size(SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT);
    widgets.page.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 244, g: 247, b: 251, a: 255 });

    widgets.hero.widget.at(sim_layout_x(20), sim_layout_y(16));
    widgets.hero.widget.size(sim_layout_w(600), sim_layout_h(64));
