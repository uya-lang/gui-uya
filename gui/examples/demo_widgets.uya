export fn widgets_retained_sync(
    widgets: &WidgetsRetained,
    control_idx: i32,
    volume_value: i32,
    auto_refresh: bool,
    selected_item: i32,
    action_idx: i32,
    status_text: &const byte
) void {
    if widgets == null {
        return;
    }
    widgets_retained_init(widgets);
    const volume_changed: bool = widgets.volume_value != volume_value;
    const auto_refresh_changed: bool = widgets.auto_refresh != auto_refresh;
    const selected_changed: bool = widgets.selected_item != selected_item;
    const action_changed: bool = widgets.action_idx != action_idx;

    const default_subtitle: &const byte = "Click buttons, drag slider, toggle switch, select list rows." as &const byte;
    var subtitle: &const byte = default_subtitle;
    if status_text != null && status_text[0] != 0 {
        subtitle = status_text;
    }
    if !widgets_cstr_eq(&widgets.subtitle_text[0], subtitle) {
        widgets_copy_cstr(&widgets.subtitle_text[0], 160usize, subtitle);
        _ = widgets.hero_subtitle.set_text(&widgets.subtitle_text[0]);
    }

    if widgets.control_idx != control_idx {
        widgets.control_idx = control_idx;
        var primary_variant: BtnVariant = BtnVariant.Outlined;
        var secondary_variant: BtnVariant = BtnVariant.Outlined;
        var text_variant: BtnVariant = BtnVariant.Text;
        var sync_variant: BtnVariant = BtnVariant.Outlined;
        var sync_icon: u32 = 0u32;
        if control_idx == 0 {
            primary_variant = BtnVariant.Filled;
        }
        if control_idx == 1 {
            secondary_variant = BtnVariant.Filled;
        }
        if control_idx == 2 {
            text_variant = BtnVariant.Filled;
        }
        if control_idx == 3 {
            sync_variant = BtnVariant.IconText;
            sync_icon = 1u32;
        }
        widgets_sync_button(&widgets.primary_btn, "Primary", primary_variant, 0u32, 14u8);
        widgets_sync_button(&widgets.secondary_btn, "Outlined", secondary_variant, 0u32, 14u8);
        widgets_sync_button(&widgets.text_btn, "Quiet Action", text_variant, 0u32, 13u8);
        widgets_sync_button(&widgets.sync_btn, "Sync", sync_variant, sync_icon, 13u8);
    }

    if volume_changed {
        widgets.volume_value = volume_value;
        _ = snprintf(&widgets.slider_text[0], 32usize, "Volume %d%%" as &const byte, volume_value);
        _ = widgets.slider_label.set_text(&widgets.slider_text[0]);
        widgets.slider.set_value(volume_value);
    } else {
        widgets.slider.set_value(volume_value);
    }

    if auto_refresh_changed {
        widgets.auto_refresh = auto_refresh;
        _ = widgets.toggle.set_checked(auto_refresh);
    }

    if selected_changed {
        widgets.selected_item = selected_item;
        widgets.inbox.select(selected_item);
    }

    if action_changed || volume_changed || auto_refresh_changed || selected_changed {
        widgets_fill_chart(&widgets.chart, volume_value, auto_refresh, selected_item, action_idx);
    }
    if action_changed {
        widgets.action_idx = action_idx;
        var archive_variant: BtnVariant = BtnVariant.Outlined;
        var ship_variant: BtnVariant = BtnVariant.Outlined;
        if action_idx == 0 {
            archive_variant = BtnVariant.Filled;
        }
        if action_idx == 1 {
            ship_variant = BtnVariant.Filled;
        }
        widgets_sync_button(&widgets.archive_btn, "Archive", archive_variant, 0u32, 12u8);
        widgets_sync_button(&widgets.ship_btn, "Ship", ship_variant, 0u32, 12u8);
    }
}

export fn render_demo_widgets_retained_state(
    widgets: &WidgetsRetained,
    ctx: &RenderCtx,
    origin_x: i16,
    origin_y: i16,
    control_idx: i32,
    volume_value: i32,
    auto_refresh: bool,
    selected_item: i32,
    action_idx: i32,
    status_text: &const byte
) void {
    if widgets == null {
        return;
    }
    widgets_retained_sync(widgets, control_idx, volume_value, auto_refresh, selected_item, action_idx, status_text);
    widgets.page.widget.at(origin_x, origin_y);
    widgets.page.render(ctx);
}

export fn render_demo_widgets_state(
    ctx: &RenderCtx,
    origin_x: i16,
    origin_y: i16,
    control_idx: i32,
    volume_value: i32,
    auto_refresh: bool,
    selected_item: i32,
    action_idx: i32,
    status_text: &const byte
) void {
    var widgets: WidgetsRetained = widgets_retained_new();
    render_demo_widgets_retained_state(
        &widgets,
        ctx,
        origin_x,
        origin_y,
        control_idx,
        volume_value,
        auto_refresh,
        selected_item,
        action_idx,
        status_text
    );
}

export fn render_demo_widgets(ctx: &RenderCtx, origin_x: i16, origin_y: i16) void {
    render_demo_widgets_state(ctx, origin_x, origin_y, 0, 72, true, 2, 1, "Widget showcase static preview");
}

export fn run_demo_widgets() i32 {
    const bytes_len: usize = framebuffer_required_bytes(SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, PixelFormat.ARGB8888);
    const bytes: &byte = malloc(bytes_len) as &byte;
    if bytes == null {
        return 2;
    }
    defer {
        free(bytes as &void);
    }
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(bytes, SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, SIM_DEFAULT_RES_WIDTH * 4u16, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 244, g: 247, b: 251, a: 255 });
    render_demo_widgets(&ctx, 0, 0);
    if ctx.stats.text_ops == 0u32 || ctx.stats.image_ops == 0u32 || ctx.stats.rect_ops == 0u32 {
        return 1;
    }
    return 0;
}
