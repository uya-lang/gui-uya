extern fn malloc(size: usize) &void;
extern fn free(ptr: &void) void;

const ANIM_ID_LINEAR_PILL: i32 = 120;
const ANIM_ID_CUBIC_PILL: i32 = 121;
const ANIM_ID_BOUNCE_PILL: i32 = 122;
const ANIM_ID_METER_FILL: i32 = 123;
const ANIM_ID_MORPH_TILE: i32 = 124;

fn animation_track_start_x() i32 {
    return sim_layout_x(8) as i32;
}

fn animation_track_end_x() i32 {
    return sim_layout_x(330) as i32;
}

fn animation_meter_start_w() i32 {
    return sim_layout_w(44u16) as i32;
}

fn animation_meter_end_w() i32 {
    return sim_layout_w(252u16) as i32;
}

fn animation_morph_start_x() i32 {
    return sim_layout_x(20) as i32;
}

fn animation_morph_end_x() i32 {
    return sim_layout_x(178) as i32;
}

fn animation_replay_rect_local() Rect {
    return sim_layout_rect(38, 434, 112u16, 28u16);
}

fn animation_toggle_rect_local() Rect {
    return sim_layout_rect(178, 434, 112u16, 28u16);
}

fn animation_style_chip(panel: &Panel, bg: Color, border: Color) void {
    if panel == null {
        return;
    }
    panel.widget.base.style.set_color(StyleProp.BgColor, bg);
    panel.widget.base.style.set_color(StyleProp.BorderColor, border);
    panel.widget.base.style.set_color(StyleProp.ShadowColor, Color{ r: 15, g: 23, b: 42, a: 18 });
    panel.widget.base.style.set_i32(StyleProp.ShadowOffsetY, 1);
    panel.widget.base.style.set_u32(StyleProp.BorderWidth, 1u32);
    panel.widget.base.style.set_u32(StyleProp.Radius, 12u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
}

fn animation_style_track(panel: &Panel) void {
    if panel == null {
        return;
    }
    panel.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 241, g: 245, b: 249, a: 255 });
    panel.widget.base.style.set_color(StyleProp.BorderColor, Color{ r: 203, g: 213, b: 225, a: 255 });
    panel.widget.base.style.set_color(StyleProp.ShadowColor, Color{ r: 0, g: 0, b: 0, a: 0 });
    panel.widget.base.style.set_u32(StyleProp.BorderWidth, 1u32);
    panel.widget.base.style.set_u32(StyleProp.Radius, 14u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
}

fn animation_style_meter_fill(panel: &Panel) void {
    if panel == null {
        return;
    }
    panel.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 16, g: 185, b: 129, a: 255 });
    panel.widget.base.style.set_color(StyleProp.BorderColor, Color{ r: 5, g: 150, b: 105, a: 255 });
    panel.widget.base.style.set_color(StyleProp.ShadowColor, Color{ r: 0, g: 0, b: 0, a: 0 });
    panel.widget.base.style.set_u32(StyleProp.BorderWidth, 0u32);
    panel.widget.base.style.set_u32(StyleProp.Radius, 8u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
}

fn animation_style_button(button: &Button) void {
    if button == null {
        return;
    }
    button.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
}

fn animation_refresh_status(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    var state_text: &const byte = "Playing" as &const byte;
    var toggle_text: &const byte = "Pause" as &const byte;
    if !anim.playing {
        state_text = "Paused" as &const byte;
        toggle_text = "Play" as &const byte;
    }
    _ = snprintf(
        &anim.status_text[0],
        96usize,
        "%s | cycle %d" as &const byte,
        state_text,
        anim.cycle_count
    );
    anim.status_label.set_text(&anim.status_text[0]);
    _ = anim.toggle_btn.set_label(toggle_text);
}

fn animation_start_cycle(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    anim.manager.stop_all();

    var linear_move: Tween = Tween.new(ANIM_ID_LINEAR_PILL, AnimProp.X, anim_value_i32(animation_track_end_x()), 1400u32);
    linear_move.with_from_i32(animation_track_start_x());
    linear_move.with_easing(EasingType.Linear);
    linear_move.repeat(1);
    linear_move.yoyo(true);
    _ = anim.manager.start_tween(&linear_move) catch {};

    var cubic_move: Tween = Tween.new(ANIM_ID_CUBIC_PILL, AnimProp.X, anim_value_i32(animation_track_end_x()), 1400u32);
    cubic_move.with_from_i32(animation_track_start_x());
    cubic_move.with_easing(EasingType.EaseInOutCubic);
    cubic_move.repeat(1);
    cubic_move.yoyo(true);
    _ = anim.manager.start_tween(&cubic_move) catch {};

    var bounce_move: Tween = Tween.new(ANIM_ID_BOUNCE_PILL, AnimProp.X, anim_value_i32(animation_track_end_x()), 1400u32);
    bounce_move.with_from_i32(animation_track_start_x());
    bounce_move.with_easing(EasingType.EaseOutBounce);
    bounce_move.repeat(1);
    bounce_move.yoyo(true);
    _ = anim.manager.start_tween(&bounce_move) catch {};

    var meter_width: Tween = Tween.new(ANIM_ID_METER_FILL, AnimProp.Width, anim_value_i32(animation_meter_end_w()), 1100u32);
    meter_width.with_from_i32(animation_meter_start_w());
    meter_width.with_easing(EasingType.EaseOutCubic);
    meter_width.repeat(1);
    meter_width.yoyo(true);
    _ = anim.manager.start_tween(&meter_width) catch {};

    var meter_color: Tween = Tween.new(
        ANIM_ID_METER_FILL,
        AnimProp.BgColor,
        anim_value_color(Color{ r: 59, g: 130, b: 246, a: 255 }),
        1100u32
    );
    meter_color.with_from_color(Color{ r: 16, g: 185, b: 129, a: 255 });
    meter_color.with_easing(EasingType.EaseInOutSine);
    meter_color.repeat(1);
    meter_color.yoyo(true);
    _ = anim.manager.start_tween(&meter_color) catch {};

    var morph_x: Tween = Tween.new(ANIM_ID_MORPH_TILE, AnimProp.X, anim_value_i32(animation_morph_end_x()), 1400u32);
    morph_x.with_from_i32(animation_morph_start_x());
    morph_x.with_easing(EasingType.EaseInOutSine);
    morph_x.repeat(1);
    morph_x.yoyo(true);
    _ = anim.manager.start_tween(&morph_x) catch {};

    var morph_radius: Tween = Tween.new(ANIM_ID_MORPH_TILE, AnimProp.Radius, anim_value_i32(24), 1400u32);
    morph_radius.with_from_i32(12);
    morph_radius.with_easing(EasingType.EaseInOutSine);
    morph_radius.repeat(1);
    morph_radius.yoyo(true);
    _ = anim.manager.start_tween(&morph_radius) catch {};

    var morph_opacity: Tween = Tween.new(ANIM_ID_MORPH_TILE, AnimProp.Opacity, anim_value_i32(255), 1400u32);
    morph_opacity.with_from_i32(132);
    morph_opacity.with_easing(EasingType.EaseOutCubic);
    morph_opacity.repeat(1);
    morph_opacity.yoyo(true);
    _ = anim.manager.start_tween(&morph_opacity) catch {};

    var morph_color: Tween = Tween.new(
        ANIM_ID_MORPH_TILE,
        AnimProp.BgColor,
        anim_value_color(Color{ r: 236, g: 72, b: 153, a: 255 }),
        1400u32
    );
    morph_color.with_from_color(Color{ r: 251, g: 146, b: 60, a: 255 });
    morph_color.with_easing(EasingType.EaseInOutSine);
    morph_color.repeat(1);
    morph_color.yoyo(true);
    _ = anim.manager.start_tween(&morph_color) catch {};
}

export struct AnimationRetained {
    tree: ObjTree,
    page: Page,
    hero: Panel,
    hero_title: Label,
    hero_subtitle: Label,
    stage: Panel,
    stage_title: Label,
    stage_note: Label,
    linear_name: Label,
    cubic_name: Label,
    bounce_name: Label,
    linear_track: Panel,
    linear_pill: Panel,
    cubic_track: Panel,
    cubic_pill: Panel,
    bounce_track: Panel,
    bounce_pill: Panel,
    control_panel: Panel,
    control_title: Label,
    control_note: Label,
    meter_track: Panel,
    meter_fill: Panel,
    status_label: Label,
    replay_btn: Button,
    toggle_btn: Button,
    morph_panel: Panel,
    morph_title: Label,
    morph_note: Label,
    morph_tile: Panel,
    morph_caption: Label,
    status_text: [byte: 96],
    ready: bool,
    manager: AnimManager,
    playing: bool,
    cycle_count: i32,
}

/// 创建默认的 `AnimationRetained` 实例。
export fn animation_retained_new() AnimationRetained {
    return AnimationRetained{
        tree: obj_tree_new(),
        page: Page.new("Animation"),
        hero: Panel.new(),
        hero_title: Label.new("Animation Lab"),
        hero_subtitle: Label.new("AnimManager drives X, width, opacity, radius and color in one looping scene."),
        stage: Panel.new(),
        stage_title: Label.new("Same distance, different easing"),
        stage_note: Label.new("Linear keeps a constant pace, cubic eases in and out, bounce lands with extra personality."),
        linear_name: Label.new("Linear"),
        cubic_name: Label.new("EaseInOutCubic"),
        bounce_name: Label.new("EaseOutBounce"),
        linear_track: Panel.new(),
        linear_pill: Panel.new(),
        cubic_track: Panel.new(),
        cubic_pill: Panel.new(),
        bounce_track: Panel.new(),
        bounce_pill: Panel.new(),
        control_panel: Panel.new(),
        control_title: Label.new("Width Tween"),
        control_note: Label.new("Replay restarts tweens. Pause freezes the frame."),
        meter_track: Panel.new(),
        meter_fill: Panel.new(),
        status_label: Label.new("Playing | cycle 1"),
        replay_btn: Button.outlined("Replay"),
        toggle_btn: Button.filled("Pause"),
        morph_panel: Panel.new(),
        morph_title: Label.new("Morph Card"),
        morph_note: Label.new("Tile glides while changing radius, opacity and color."),
        morph_tile: Panel.new(),
        morph_caption: Label.new("Radius + opacity + bg color"),
        status_text: [],
        ready: false,
        manager: anim_manager_new(),
        playing: true,
        cycle_count: 1,
    };
}

/// 返回 `Replay` 按钮在 demo 本地坐标系中的区域。
export fn animation_demo_replay_rect() Rect {
    return animation_replay_rect_local();
}

/// 返回 `Play/Pause` 按钮在 demo 本地坐标系中的区域。
export fn animation_demo_toggle_rect() Rect {
    return animation_toggle_rect_local();
}

/// 初始化 `animation_retained` 的内部状态。
export fn animation_retained_init(anim: &AnimationRetained) void {
    if anim == null || anim.ready {
        return;
    }

    anim.page.widget.at(0, 0);
    anim.page.widget.size(SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT);
    anim.page.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 244, g: 247, b: 252, a: 255 });

    anim.hero.widget.at(sim_layout_x(20), sim_layout_y(16));
    anim.hero.widget.size(sim_layout_w(600u16), sim_layout_h(72u16));
    anim.hero.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 255, g: 255, b: 255, a: 255 });

    anim.hero_title.widget.at(sim_layout_x(20), sim_layout_y(14));
    anim.hero_title.widget.size(sim_layout_w(560u16), sim_layout_h(28u16));
    anim.hero_title.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(26u8) as u32);
    _ = anim.hero_title.set_align(TextAlign.Center);

    anim.hero_subtitle.widget.at(sim_layout_x(20), sim_layout_y(44));
    anim.hero_subtitle.widget.size(sim_layout_w(560u16), sim_layout_h(16u16));
    anim.hero_subtitle.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.hero_subtitle.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 100, g: 116, b: 139, a: 255 });
    _ = anim.hero_subtitle.set_align(TextAlign.Center);

    anim.stage.widget.at(sim_layout_x(20), sim_layout_y(100));
    anim.stage.widget.size(sim_layout_w(600u16), sim_layout_h(194u16));
    anim.stage.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 255, g: 255, b: 255, a: 255 });

    anim.stage_title.widget.at(sim_layout_x(18), sim_layout_y(16));
    anim.stage_title.widget.size(sim_layout_w(260u16), sim_layout_h(18u16));
    anim.stage_title.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(18u8) as u32);

    anim.stage_note.widget.at(sim_layout_x(18), sim_layout_y(36));
    anim.stage_note.widget.size(sim_layout_w(564u16), sim_layout_h(18u16));
    anim.stage_note.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.stage_note.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 100, g: 116, b: 139, a: 255 });
    anim.stage_note.overflow = TextOverflow.Wrap;

    anim.linear_name.widget.at(sim_layout_x(18), sim_layout_y(74));
    anim.linear_name.widget.size(sim_layout_w(116u16), sim_layout_h(16u16));
    anim.linear_name.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.linear_name.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 51, g: 65, b: 85, a: 255 });

    anim.cubic_name.widget.at(sim_layout_x(18), sim_layout_y(116));
    anim.cubic_name.widget.size(sim_layout_w(116u16), sim_layout_h(16u16));
    anim.cubic_name.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.cubic_name.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 51, g: 65, b: 85, a: 255 });

    anim.bounce_name.widget.at(sim_layout_x(18), sim_layout_y(158));
    anim.bounce_name.widget.size(sim_layout_w(116u16), sim_layout_h(16u16));
    anim.bounce_name.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.bounce_name.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 51, g: 65, b: 85, a: 255 });

    animation_style_track(&anim.linear_track);
    anim.linear_track.widget.at(sim_layout_x(148), sim_layout_y(68));
    anim.linear_track.widget.size(sim_layout_w(420u16), sim_layout_h(28u16));

    animation_style_track(&anim.cubic_track);
    anim.cubic_track.widget.at(sim_layout_x(148), sim_layout_y(110));
    anim.cubic_track.widget.size(sim_layout_w(420u16), sim_layout_h(28u16));

    animation_style_track(&anim.bounce_track);
    anim.bounce_track.widget.at(sim_layout_x(148), sim_layout_y(152));
    anim.bounce_track.widget.size(sim_layout_w(420u16), sim_layout_h(28u16));

    animation_style_chip(
