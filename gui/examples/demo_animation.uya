    anim.control_note.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.control_note.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 71, g: 85, b: 105, a: 255 });
    anim.control_note.overflow = TextOverflow.Wrap;

    animation_style_track(&anim.meter_track);
