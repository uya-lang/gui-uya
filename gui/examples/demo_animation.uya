    anim.morph_caption.widget.at(sim_layout_x(18), sim_layout_y(124));
    anim.morph_caption.widget.size(sim_layout_w(252u16), sim_layout_h(20u16));
    anim.morph_caption.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
