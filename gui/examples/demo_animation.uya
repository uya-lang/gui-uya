    anim.cubic_pill.widget.size(sim_layout_w(82u16), sim_layout_h(24u16));

    animation_style_chip(
        &anim.bounce_pill,
        Color{ r: 249, g: 115, b: 22, a: 255 },
        Color{ r: 234, g: 88, b: 12, a: 255 }
