        anim.easing_labels[i].widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(9u8) as u32);
        anim.easing_labels[i].widget.base.style.set_color(StyleProp.FgColor, Color{ r: 51, g: 65, b: 85, a: 255 });

        anim.easing_tracks[i] = Panel.new();
