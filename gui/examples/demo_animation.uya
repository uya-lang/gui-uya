        anim.easing_panel.add(anim.easing_labels[i].obj());
        anim.easing_panel.add(anim.easing_tracks[i].obj());
        anim.easing_tracks[i].add(anim.easing_pills[i].obj());
        _ = gui_obj_register(ANIM_ID_EASING_BASE + i, anim.easing_pills[i].obj());
        i = i + 1;
