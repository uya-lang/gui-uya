/// 切换到指定动画视图。
export fn animation_retained_set_view(anim: &AnimationRetained, view: i32) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    var next: i32 = view;
    if next < 0 {
        next = 0;
    }
    if next >= ANIM_VIEW_COUNT {
        next = ANIM_VIEW_COUNT - 1;
    }
    if anim.current_view == next {
        return;
    }
    anim.current_view = next;
    animation_apply_view(anim);
    animation_refresh_status(anim);
}

/// 切换到下一个动画视图。
export fn animation_retained_next_view(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    var next: i32 = anim.current_view + 1;
    if next >= ANIM_VIEW_COUNT {
        next = 0;
    }
    animation_retained_set_view(anim, next);
}

/// 切换到上一个动画视图。
export fn animation_retained_prev_view(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    var next: i32 = anim.current_view - 1;
    if next < 0 {
        next = ANIM_VIEW_COUNT - 1;
    }
    animation_retained_set_view(anim, next);
}

/// 将外部状态同步到 `animation_retained`。
export fn animation_retained_sync(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    animation_apply_view(anim);
    animation_refresh_status(anim);
}

/// 重播整段动画序列。
export fn animation_retained_replay(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    anim.playing = true;
    anim.cycle_count = 1;
    animation_start_cycle(anim);
    animation_transition_reset(anim);
    animation_refresh_status(anim);
}

/// 切换动画播放状态。
export fn animation_retained_toggle(anim: &AnimationRetained) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    if anim.playing {
        anim.playing = false;
    } else {
        anim.playing = true;
        if !anim.manager.is_animating() {
            animation_start_cycle(anim);
        }
    }
    animation_refresh_status(anim);
}

/// 处理动画 demo 的本地触摸事件。
export fn animation_retained_handle_touch(anim: &AnimationRetained, evt: &Event, local: Point) bool {
    if anim == null || evt == null {
        return false;
    }
    animation_retained_init(anim);
    if evt.event_type != EventType.Click {
        return false;
    }

    var i: i32 = 0;
    while i < 3 {
        const section_rect: Rect = animation_section_rect_local(i);
        const px: i16 = local.x;
        const py: i16 = local.y;
        const right: i16 = section_rect.x + section_rect.w as i16;
        const bottom: i16 = section_rect.y + section_rect.h as i16;
        if px >= section_rect.x && px < right && py >= section_rect.y && py < bottom {
            animation_retained_set_view(anim, i);
            return true;
        }
        i = i + 1;
    }

    const replay_rect: Rect = animation_replay_rect_local();
    const replay_point: Point = Point{ x: local.x, y: local.y };
    if replay_rect.contains(replay_point) {
        animation_retained_replay(anim);
        return true;
    }

    const toggle_rect: Rect = animation_toggle_rect_local();
    const toggle_point: Point = Point{ x: local.x, y: local.y };
    if toggle_rect.contains(toggle_point) {
        animation_retained_toggle(anim);
        return true;
    }
    return false;
}

/// 推进动画 demo 的时间轴。
export fn animation_retained_update(anim: &AnimationRetained, dt_ms: u32) void {
    if anim == null {
        return;
    }
    animation_retained_init(anim);
    if !anim.playing {
        return;
    }

    if !anim.manager.is_animating() {
        anim.cycle_count = anim.cycle_count + 1;
        animation_start_cycle(anim);
    }
    anim.manager.update_all(dt_ms);
    animation_transition_update(anim, dt_ms);
    animation_refresh_status(anim);
}

/// 使用 retained 状态将 `animation` demo 渲染到指定上下文。
export fn render_demo_animation_retained_state(anim: &AnimationRetained, ctx: &RenderCtx, origin_x: i16, origin_y: i16) void {
    if anim == null {
        return;
    }
    animation_retained_sync(anim);
    anim.page.widget.at(origin_x, origin_y);
    if anim.current_view == ANIM_VIEW_TRANSITION {
        animation_transition_sync_layout(anim);
    }
    anim.page.render(ctx);
    if anim.current_view == ANIM_VIEW_TRANSITION {
        anim.transition_nav.render(ctx);
    }
}

/// 将 `animation` demo 渲染到指定上下文。
export fn render_demo_animation(ctx: &RenderCtx, origin_x: i16, origin_y: i16) void {
    var anim: AnimationRetained = animation_retained_new();
    render_demo_animation_retained_state(&anim, ctx, origin_x, origin_y);
}

/// 运行 `animation` demo 并返回退出码。
export fn run_demo_animation() i32 {
    const bytes_len: usize = framebuffer_required_bytes(SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, PixelFormat.ARGB8888);
    const bytes: &byte = malloc(bytes_len) as &byte;
    if bytes == null {
        return 2;
    }
    defer {
        free(bytes as &void);
    }

    var anim: AnimationRetained = animation_retained_new();
    animation_retained_sync(&anim);
    const before_x: i32 = anim.easing_pills[0].widget.base.x as i32;
    animation_retained_update(&anim, 220u32);
    const after_x: i32 = anim.easing_pills[0].widget.base.x as i32;

    var ctx: RenderCtx = render_ctx_new(framebuffer_new(bytes, SIM_DEFAULT_RES_WIDTH, SIM_DEFAULT_RES_HEIGHT, SIM_DEFAULT_RES_WIDTH * 4u16, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 244, g: 247, b: 252, a: 255 });
    render_demo_animation_retained_state(&anim, &ctx, 0, 0);

    animation_retained_set_view(&anim, ANIM_VIEW_PROPERTY);
    ctx.clear(Color{ r: 244, g: 247, b: 252, a: 255 });
    render_demo_animation_retained_state(&anim, &ctx, 0, 0);

    animation_retained_set_view(&anim, ANIM_VIEW_TRANSITION);
    animation_retained_update(&anim, ANIM_TRANSITION_HOLD_MS + 120u32);
    ctx.clear(Color{ r: 244, g: 247, b: 252, a: 255 });
    render_demo_animation_retained_state(&anim, &ctx, 0, 0);

    if after_x <= before_x {
        return 1;
    }
    if ctx.stats.text_ops == 0u32 || ctx.stats.rect_ops == 0u32 {
        return 3;
    }
    return 0;
}
