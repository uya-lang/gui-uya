    anim.morph_panel.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 255, g: 247, b: 237, a: 255 });

    anim.morph_title.widget.at(sim_layout_x(18), sim_layout_y(16));
    anim.morph_title.widget.size(sim_layout_w(160u16), sim_layout_h(18u16));
    anim.morph_title.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(18u8) as u32);

    anim.morph_note.widget.at(sim_layout_x(18), sim_layout_y(38));
    anim.morph_note.widget.size(sim_layout_w(260u16), sim_layout_h(34u16));
    anim.morph_note.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.morph_note.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 120, g: 53, b: 15, a: 255 });
