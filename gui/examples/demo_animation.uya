    anim.meter_fill.widget.size(sim_layout_w(44u16), sim_layout_h(16u16));

    anim.status_label.widget.at(sim_layout_x(18), sim_layout_y(98));
    anim.status_label.widget.size(sim_layout_w(252u16), sim_layout_h(16u16));
    anim.status_label.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(12u8) as u32);
    anim.status_label.widget.base.style.set_color(StyleProp.FgColor, Color{ r: 15, g: 23, b: 42, a: 255 });

    animation_style_button(&anim.replay_btn);
