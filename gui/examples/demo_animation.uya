    anim.control_title.widget.size(sim_layout_w(160u16), sim_layout_h(18u16));
    anim.control_title.widget.base.style.set_u32(StyleProp.FontSize, sim_layout_font(18u8) as u32);

    anim.control_note.widget.at(sim_layout_x(18), sim_layout_y(38));
