export const TEST_RENDER_ASSETS_MODULE: i32 = 1;
const TEST_DEJAVU_TTF_BYTES: &[const byte] = @embed("../render/DejaVuSans.ttf");

test "image draw and cache get work" {
    var dst_bytes: [byte: 256] = [];
    var img_bytes: [byte: 12] = [255, 0, 0,   0, 255, 0,   0, 0, 255,   255, 255, 255];
    const fb: FrameBuffer = framebuffer_new(&dst_bytes[0], 6, 6, 18, PixelFormat.RGB888);
    var ctx: RenderCtx = render_ctx_new(fb);
    const img: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);

    draw_image(&ctx, 0, 0, &img);
    draw_image_scaled(&ctx, Rect{ x: 2, y: 0, w: 2, h: 2 }, &img);
    draw_image_clipped(&ctx, Rect{ x: 0, y: 2, w: 2, h: 2 }, &img, Rect{ x: 1, y: 0, w: 1, h: 2 });

    try assert_eq_bool(ctx_pixel(&ctx, 0, 0) == RED, true);
    try assert_eq_bool(ctx_pixel(&ctx, 3, 0) == Color{ r: 0, g: 255, b: 0, a: 255 }, true);

    var cache: ImageCache = image_cache_new(4, 64u32);
    var out: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);
    cache.put(7u32, image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888));
    try assert_eq_bool(cache.get(7u32, &out), true);
    try assert_eq_i32(out.size.w as i32, 2);
}

test "image rotation keeps source quadrants consistent" {
    var dst_bytes: [byte: 256] = [];
    var img_bytes: [byte: 12] = [255, 0, 0,   0, 255, 0,   0, 0, 255,   255, 255, 255];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&dst_bytes[0], 6, 6, 24, PixelFormat.RGB888));
    const img: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);

    draw_image_rotated(&ctx, 1, 1, &img, 90);

    var saw_red: bool = false;
    var saw_green: bool = false;
    var saw_blue: bool = false;
    var saw_white: bool = false;
    var lit_pixels: i32 = 0;
    var py: i32 = 0;
    while py < 6 {
        var px: i32 = 0;
        while px < 6 {
            const sample: Color = ctx_pixel(&ctx, px as i16, py as i16);
            if sample == RED {
                saw_red = true;
                lit_pixels = lit_pixels + 1;
            } else if sample == Color{ r: 0, g: 255, b: 0, a: 255 } {
                saw_green = true;
                lit_pixels = lit_pixels + 1;
            } else if sample == Color{ r: 0, g: 0, b: 255, a: 255 } {
                saw_blue = true;
                lit_pixels = lit_pixels + 1;
            } else if sample == Color{ r: 255, g: 255, b: 255, a: 255 } {
                saw_white = true;
                lit_pixels = lit_pixels + 1;
            }
            px = px + 1;
        }
        py = py + 1;
    }

    try assert_eq_bool(saw_red, true);
    try assert_eq_bool(saw_green, true);
    try assert_eq_bool(saw_blue, true);
    try assert_eq_bool(saw_white, true);
    try assert_eq_bool(lit_pixels >= 4, true);
}

test "font draws and measures text" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const font: Font = font_default();
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    const white0: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white1: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white2: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    try assert_eq_i32(text_width("OK", 2usize, &font) as i32, 13);
    draw_text(&ctx, 0, 0, "OK", 2usize, &font, white0);
    draw_text_aligned(&ctx, Rect{ x: 0, y: 8, w: 16, h: 8 }, "A", 1usize, &font, white1, TextAlign.Center);

    try assert_eq_bool(ctx.stats.text_ops >= 2u32, true);
    try assert_eq_bool(ctx_pixel(&ctx, 1, 0) == white2, true);
}

test "font glyphs are no longer placeholder boxes" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    const font: Font = font_default();
    const white_draw: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    draw_text(&ctx, 0, 0, "I", 1usize, &font, white_draw);

    try assert_eq_bool(ctx_pixel(&ctx, 0, 3) == BLACK, true);
    try assert_eq_bool(ctx_pixel(&ctx, 2, 3) == white_expect, true);
}

test "font can draw chinese glyphs" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const font: Font = font_default();
    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const black_expect: Color = Color{ r: 0, g: 0, b: 0, a: 255 };

    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    try assert_eq_i32(text_width("中文", 6usize, &font) as i32, 16);
    draw_text(&ctx, 0, 0, "中文", 6usize, &font, Color{ r: 255, g: 255, b: 255, a: 255 });

    try assert_eq_bool(ctx_pixel(&ctx, 3, 0) == white_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 7, 0) == black_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 11, 0) == white_expect, true);
}

test "ttf missing chinese glyphs prefer scalable cjk fallback before builtin bitmap" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    var asset: TtfFontAsset = ttf_font_asset_new();
    try assert_eq_bool(
        ttf_font_load_memory(&asset, "DejaVuSans", TEST_DEJAVU_TTF_BYTES.ptr, TEST_DEJAVU_TTF_BYTES.len, 12u16),
        true
    );

    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const black_expect: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const system_cjk: &Font = font_system_ui_ref(12u8);
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    draw_text(&ctx, 0, 0, "中文", 6usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });
    if system_cjk != null {
        try assert_eq_bool(text_width("中文", 6usize, &asset.font) >= 18, true);
        try assert_eq_i32(
            text_width("中", 3usize, &asset.font) as i32,
            text_width("中", 3usize, system_cjk) as i32
        );
        return;
    }

    try assert_eq_i32(text_width("中文", 6usize, &asset.font) as i32, 16);
    try assert_eq_bool(ctx_pixel(&ctx, 3, 0) == white_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 7, 0) == black_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 11, 0) == white_expect, true);
}

test "widget font resolves scalable ui font and honors dpi scaling in gui core" {
    font_ui_reset_runtime();
    var small_style: Style = style_default();
    var large_style: Style = style_default();
    small_style.set_u32(StyleProp.FontSize, 11u32);
    large_style.set_u32(StyleProp.FontSize, 14u32);

    const small_font: &Font = widget_font(&small_style);
    const large_font: &Font = widget_font(&large_style);
    try assert_eq_bool(small_font.render_kind == FontRenderKind.TrueTypeOutline, true);
    try assert_eq_bool(large_font.render_kind == FontRenderKind.TrueTypeOutline, true);
    try assert_eq_i32(small_font.height as i32, 11);
    try assert_eq_i32(large_font.height as i32, 14);
    try assert_eq_bool(text_width("Hint", 4usize, small_font) < text_width("Hint", 4usize, large_font), true);

    font_ui_set_dpi(144u16);
    const scaled_font: &Font = widget_font(&large_style);
    try assert_eq_i32(font_ui_pixel_height(14u8) as i32, 21);
    try assert_eq_i32(scaled_font.height as i32, 21);
    try assert_eq_bool(text_width("Hint", 4usize, large_font) < text_width("Hint", 4usize, scaled_font), true);
    font_ui_reset_runtime();
}

test "font antialiases diagonal edges" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const font: Font = font_default();
    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    draw_text(&ctx, 0, 0, "/", 1usize, &font, Color{ r: 255, g: 255, b: 255, a: 255 });

    const edge: Color = ctx_pixel(&ctx, 3, 0);
    try assert_eq_bool(edge.r > 0u8, true);
    try assert_eq_bool(edge.r < 255u8, true);
    try assert_eq_bool(ctx_pixel(&ctx, 4, 0) == white_expect, true);
}

test "font applies builtin kerning and exposes compact system variant" {
    const font: Font = font_default();
    const compact: Font = font_system_compact();

    try assert_eq_i32(text_width("AA", 2usize, &font) as i32, 13);
    try assert_eq_i32(text_width("AV", 2usize, &font) as i32, 12);
    try assert_eq_bool(text_width("AV", 2usize, &compact) < text_width("AV", 2usize, &font), true);
}

test "bmfont asset loads glyphs and draws atlas alpha" {
    var atlas: [byte: 12] = [
        0, 255,   255, 0,   255, 255,
        255, 255, 255, 255, 0, 255,
    ];
    const desc: &const byte = "common lineHeight=2 base=2\nchar id=65 x=0 y=0 width=2 height=2 xoffset=0 yoffset=0 xadvance=3\nchar id=86 x=2 y=0 width=2 height=2 xoffset=0 yoffset=0 xadvance=3\nchar id=63 x=4 y=0 width=2 height=2 xoffset=0 yoffset=0 xadvance=3\nkerning first=65 second=86 amount=-1\n";

    var asset: BitmapFontAsset = bitmap_font_asset_new();
    try assert_eq_bool(bitmap_font_load_bmfont(&asset, desc, strlen(desc as *const byte), &atlas[0], 6u16), true);
    try assert_eq_i32(text_width("AV", 2usize, &asset.font) as i32, 5);

    var bytes: [byte: 256] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 8, 4, 32, PixelFormat.ARGB8888));
    const white_expect0: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white_expect1: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white_expect2: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    draw_text(&ctx, 0, 0, "AV?", 3usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });

    try assert_eq_bool(ctx_pixel(&ctx, 1, 0) == white_expect0, true);
    try assert_eq_bool(ctx_pixel(&ctx, 2, 0) == white_expect1, true);
    try assert_eq_bool(ctx_pixel(&ctx, 6, 1) == white_expect2, true);
}

test "vector system font rasterizes strokes" {
    const font: Font = font_system_vector();
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    draw_text(&ctx, 0, 0, "AV0", 3usize, &font, Color{ r: 255, g: 255, b: 255, a: 255 });

    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
    try assert_eq_bool(ctx.stats.line_ops > 0u32, true);
    try assert_eq_bool(ctx_pixel(&ctx, 3, 0) == white_expect, true);
}

test "ttf font asset loads and renders outlines in pure uya path" {
    ttf_cache_reset();
    var asset: TtfFontAsset = ttf_font_asset_new();
    try assert_eq_bool(
        ttf_font_load_memory(&asset, "DejaVuSans", TEST_DEJAVU_TTF_BYTES.ptr, TEST_DEJAVU_TTF_BYTES.len, 18u16),
        true
    );

    const glyph_a: Glyph = glyph_for_char(&asset.font, 'A' as u8);
    try assert_eq_bool(glyph_a.width > 0u8, true);
    try assert_eq_bool(text_width("AV", 2usize, &asset.font) < text_width("AA", 2usize, &asset.font), true);

    var bytes: [byte: 4096] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 32, 32, 128, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    draw_text(&ctx, 1, 4, "AV0?", 4usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });

    var lit_pixels: i32 = 0;
    var py: i32 = 0;
    while py < 24 {
        var px: i32 = 0;
        while px < 28 {
            const sampled: Color = ctx_pixel(&ctx, px as i16, py as i16);
            if sampled.r > 0u8 {
                lit_pixels = lit_pixels + 1;
            }
            px = px + 1;
        }
        py = py + 1;
    }

    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
    try assert_eq_bool(lit_pixels > 40, true);
}

test "ttf composite glyphs and cache work" {
    ttf_cache_reset();
    var asset: TtfFontAsset = ttf_font_asset_new();
    try assert_eq_bool(
        ttf_font_load_memory(&asset, "DejaVuSans", TEST_DEJAVU_TTF_BYTES.ptr, TEST_DEJAVU_TTF_BYTES.len, 20u16),
        true
    );

    var bytes_a: [byte: 4096] = [];
    var bytes_b: [byte: 4096] = [];
    var bytes_c: [byte: 4096] = [];
    var ctx_a: RenderCtx = render_ctx_new(framebuffer_new(&bytes_a[0], 32, 32, 128, PixelFormat.ARGB8888));
    var ctx_b: RenderCtx = render_ctx_new(framebuffer_new(&bytes_b[0], 32, 32, 128, PixelFormat.ARGB8888));
    var ctx_c: RenderCtx = render_ctx_new(framebuffer_new(&bytes_c[0], 32, 32, 128, PixelFormat.ARGB8888));
    ctx_a.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    ctx_b.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    ctx_c.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    draw_text(&ctx_a, 1, 3, "Ä", 2usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });
    try assert_eq_bool(ttf_cache_miss_count() > 0u32, true);
    draw_text(&ctx_b, 1, 3, "Ä", 2usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });
    try assert_eq_bool(ttf_cache_hit_count() > 0u32, true);
    draw_text(&ctx_c, 1, 3, "A", 1usize, &asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });

    var composite_lit: i32 = 0;
    var base_lit: i32 = 0;
    var y3: i32 = 0;
    while y3 < 24 {
        var x: i32 = 0;
        while x < 24 {
            if ctx_pixel(&ctx_b, x as i16, y3 as i16).r > 0u8 {
                composite_lit = composite_lit + 1;
            }
            if ctx_pixel(&ctx_c, x as i16, y3 as i16).r > 0u8 {
                base_lit = base_lit + 1;
            }
            x = x + 1;
        }
        y3 = y3 + 1;
    }
    try assert_eq_bool(composite_lit > base_lit, true);
}

test "ttf hinting toggle changes small glyph rasterization" {
    var hinted_asset: TtfFontAsset = ttf_font_asset_new();
    var plain_asset: TtfFontAsset = ttf_font_asset_new();
    try assert_eq_bool(
        ttf_font_load_memory(&hinted_asset, "DejaVuSans", TEST_DEJAVU_TTF_BYTES.ptr, TEST_DEJAVU_TTF_BYTES.len, 11u16),
        true
    );
    try assert_eq_bool(
        ttf_font_load_memory(&plain_asset, "DejaVuSans", TEST_DEJAVU_TTF_BYTES.ptr, TEST_DEJAVU_TTF_BYTES.len, 11u16),
        true
    );
    ttf_font_set_hinting(&plain_asset, false);

    var hinted_bytes: [byte: 1024] = [];
    var plain_bytes: [byte: 1024] = [];
    var hinted_ctx: RenderCtx = render_ctx_new(framebuffer_new(&hinted_bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    var plain_ctx: RenderCtx = render_ctx_new(framebuffer_new(&plain_bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    hinted_ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    plain_ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    draw_text(&hinted_ctx, 1, 2, "H", 1usize, &hinted_asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });
    draw_text(&plain_ctx, 1, 2, "H", 1usize, &plain_asset.font, Color{ r: 255, g: 255, b: 255, a: 255 });

    var pixel_diff: i32 = 0;
    var py2: i32 = 0;
    while py2 < 16 {
        var px2: i32 = 0;
        while px2 < 16 {
            if ctx_pixel(&hinted_ctx, px2 as i16, py2 as i16) != ctx_pixel(&plain_ctx, px2 as i16, py2 as i16) {
                pixel_diff = pixel_diff + 1;
            }
            px2 = px2 + 1;
        }
        py2 = py2 + 1;
    }
    try assert_eq_bool(pixel_diff > 0, true);
}
