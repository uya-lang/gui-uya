use core.obj.GuiObj;
use core.obj.gui_obj_default;
use core.obj_pool.OBJ_POOL_CAPACITY;
use core.obj_pool.ObjPool;
use core.obj_pool.ObjPoolIndices;
use res.buf.Buffer;
use res.buf.Slice;
use res.buf.buffer_new;
use res.buf.slice_from_ptr;
use res.pool.MemPool;
use res.pool.PoolManager;
use res.pool.mem_pool_new;
use res.pool.pool_manager_new;
use std.mem.allocator.g_allocator;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;

export const TEST_POOL_MODULE: i32 = 1;

test "mem pool stress alloc free" {
    var pool: MemPool = mem_pool_new(32, 32);
    var i: i32 = 0;
    while i < 10000 {
        const ptr: &byte = try pool.alloc();
        try assert_eq_bool(ptr != null, true);
        pool.free(ptr);
        i = i + 1;
    }

    try assert_eq_i32(pool.used_count(), 0);
    try assert_eq_i32(pool.free_count(), 32);
}

test "pool manager routes by size" {
    var manager: PoolManager = pool_manager_new();
    const small: &byte = try manager.alloc(16);
    const medium: &byte = try manager.alloc(96);
    const large: &byte = try manager.alloc(256);

    try assert_eq_bool(small != null, true);
    try assert_eq_bool(medium != null, true);
    try assert_eq_bool(large != null, true);

    manager.free(small, 16);
    manager.free(medium, 96);
    manager.free(large, 256);
}

test "buffer resize append clear" {
    var buf: Buffer = buffer_new(&g_allocator);
    var src: [byte: 4] = [1, 2, 3, 4];

    try buf.resize(2);
    try assert_eq_u64(buf.len as u64, 2u64);
    try assert_eq_bool(buf.cap >= 2usize, true);

    try buf.append(src[0:4]);
    try assert_eq_u64(buf.len as u64, 6u64);
    try assert_eq_u64(buf.as_slice().len as u64, 6u64);
    try assert_eq_i32(buf.data[2] as i32, 1);
    try assert_eq_i32(buf.data[5] as i32, 4);

    buf.clear();
    try assert_eq_u64(buf.len as u64, 0u64);
}

test "slice generic helper" {
    var values: [i32: 3] = [7, 8, 9];
    const view: Slice<i32> = Slice<i32>{ ptr: &values[0], len: 3usize };
    try assert_eq_u64(view.len as u64, 3u64);
    try assert_eq_i32(view.ptr[0], 7);
    try assert_eq_i32(view.ptr[2], 9);
}

test "mem pool fragmentation reuse" {
    var pool: MemPool = mem_pool_new(16, 8);
    var ptrs: [&byte: 8] = [];
    var i: i32 = 0;
    while i < 8 {
        ptrs[i as usize] = try pool.alloc();
        i = i + 1;
    }

    pool.free(ptrs[1]);
    pool.free(ptrs[3]);
    pool.free(ptrs[5]);
    pool.free(ptrs[7]);
    try assert_eq_i32(pool.used_count(), 4);

    const a: &byte = try pool.alloc();
    const b: &byte = try pool.alloc();
    const c: &byte = try pool.alloc();
    const d: &byte = try pool.alloc();
    try assert_eq_bool(a != null && b != null && c != null && d != null, true);
    try assert_eq_i32(pool.used_count(), 8);
}

test "obj pool lifecycle" {
    var pool: ObjPool<GuiObj> = ObjPool<GuiObj>{
        storage: [],
        states: [],
        live_count: 0,
    };
    const first: &GuiObj = pool.alloc_obj();
    const second: &GuiObj = pool.alloc_obj();

    first[0] = gui_obj_default();
    second[0] = gui_obj_default();
    first.type_tag = 100;
    second.type_tag = 200;

    try assert_eq_i32(pool.used_count(), 2);
    try assert_eq_i32(pool.get_obj(0).type_tag as i32, 100);
    try assert_eq_i32(pool.get_obj(1).type_tag as i32, 200);

    const indices: ObjPoolIndices = pool.foreach();
    try assert_eq_i32(indices.len, 2);

    pool.free_obj(first);
    try assert_eq_i32(pool.used_count(), 1);
    try assert_eq_bool(pool.get_obj(0) != null, true);
    try assert_eq_i32(pool.capacity(), OBJ_POOL_CAPACITY);
}
