use core.event.Event;
use core.event.GestureConfig;
use core.event.EventType;
use core.event.InputDev;
use core.event.event_none;
use core.event.gesture_config_default;
use core.point.POINT_ZERO;
use core.point.Point;
use platform.fb.indev_fb_common.FB_EVT_HOVER_MOVE;
use platform.fb.indev_fb_common.FB_EVT_KEY_DOWN;
use platform.fb.indev_fb_common.FB_EVT_TOUCH_DOWN;
use platform.fb.indev_fb_common.FB_EVT_TOUCH_UP;
use platform.fb.indev_fb_common.FB_EVT_WHEEL;
use platform.fb.indev_fb_common.FbHostEvent;
use platform.fb.indev_fb_common.fb_hover_point_default;
use platform.fb.indev_fb_common.fb_feed_host_event;
use platform.indev.EncoderDriver;
use platform.indev.IInputDev;
use platform.indev.InputManager;
use platform.indev.KeyDriver;
use platform.indev.MouseDriver;
use platform.indev.TouchCalibSample;
use platform.indev.TouchDriver;
use platform.indev.encoder_driver_new;
use platform.indev.input_manager_new;
use platform.indev.key_driver_new;
use platform.indev.mouse_driver_new;
use platform.indev.touch_calibration_identity;
use platform.indev.touch_driver_new;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.expect;

export const TEST_INPUT_DEV_MODULE: i32 = 1;

test "touch driver reads pending event" {
    var driver: TouchDriver = touch_driver_new();
    var evt: Event = event_none();
    driver.feed(3, 11, Point{ x: 4, y: 5 }, true);
    try assert_eq_bool(driver.read(&evt), true);
    try assert_eq_i32(evt.target, 3);
    try expect(evt.event_type == EventType.Press);
}

test "mouse key and encoder drivers read pending event" {
    var mouse: MouseDriver = mouse_driver_new();
    var key: KeyDriver = key_driver_new();
    var encoder: EncoderDriver = encoder_driver_new();
    var evt: Event = event_none();

    mouse.feed(1, 1, Point{ x: 2, y: 3 }, true);
    try assert_eq_bool(mouse.read(&evt), true);
    try expect(evt.event_type == EventType.Press);

    key.feed(2, 2, 13, true);
    try assert_eq_bool(key.read(&evt), true);
    try expect(evt.event_type == EventType.KeyDown);

    encoder.feed(3, 3, 4);
    try assert_eq_bool(encoder.read(&evt), true);
    try assert_eq_i32(evt.value(), 4);
}

test "touch driver calibration and filter map raw samples" {
    var driver: TouchDriver = touch_driver_new();
    driver.set_filter_enabled(false);
    driver.calibration = touch_calibration_identity();

    var samples: [TouchCalibSample: 4] = [
        TouchCalibSample{ raw: Point{ x: 100, y: 100 }, screen: Point{ x: 0, y: 0 } },
        TouchCalibSample{ raw: Point{ x: 900, y: 100 }, screen: Point{ x: 80, y: 0 } },
        TouchCalibSample{ raw: Point{ x: 100, y: 900 }, screen: Point{ x: 0, y: 80 } },
        TouchCalibSample{ raw: Point{ x: 900, y: 900 }, screen: Point{ x: 80, y: 80 } },
    ];
    driver.calibrate_4pt(&samples[0], 4);

    var evt: Event = event_none();
    driver.feed_raw(9, 10u32, Point{ x: 500, y: 500 }, true);
    try assert_eq_bool(driver.read(&evt), true);
    try expect(evt.point().x >= 39 && evt.point().x <= 41);
    try expect(evt.point().y >= 39 && evt.point().y <= 41);
}

test "input manager supports hotplug and edge gestures" {
    var touch: TouchDriver = touch_driver_new();
    var mouse: MouseDriver = mouse_driver_new();
    var manager: InputManager = input_manager_new();
    var touch_dev: IInputDev = touch;
    var mouse_dev: IInputDev = mouse;

    try assert_eq_bool(manager.attach(&touch_dev), true);
    try assert_eq_bool(manager.attach(&mouse_dev), true);
    try assert_eq_i32(manager.device_count(), 2);

    var config: GestureConfig = gesture_config_default();
    config.swipe_threshold = 10;
    touch.set_gesture_config(config);
    touch.set_filter_enabled(false);
    touch.feed(5, 1u32, Point{ x: 2, y: 2 }, true);
    touch.feed(5, 20u32, Point{ x: 20, y: 2 }, false);

    var evt: Event = event_none();
    try assert_eq_bool(manager.poll(&evt), true);
    try expect(evt.event_type == EventType.Press || evt.event_type == EventType.Release || evt.event_type == EventType.SwipeRight || evt.event_type == EventType.Click);

    try assert_eq_bool(manager.detach(InputDev.Mouse), true);
    try assert_eq_i32(manager.device_count(), 1);
    try assert_eq_bool(manager.hotplug_revision >= 3u32, true);
}

test "fb input system translates tty key events" {
    var touch: TouchDriver = touch_driver_new();
    var key: KeyDriver = key_driver_new();
    var encoder: EncoderDriver = encoder_driver_new();
    var hover_pending: bool = false;
    var hover_point: Point = fb_hover_point_default();

    var raw: FbHostEvent = FbHostEvent{
        kind: FB_EVT_KEY_DOWN,
        x: 0,
        y: 0,
        value: 0,
        key_code: 'P' as u16,
        reserved: 0u16,
    };
    fb_feed_host_event(&touch, &key, &encoder, &raw, 44u32, &hover_pending, &hover_point);

    var evt: Event = event_none();
    try assert_eq_bool(key.read(&evt), true);
    try expect(evt.event_type == EventType.KeyDown);
    try assert_eq_i32(evt.key_code() as i32, 'P' as i32);
}

test "fb input common translates hover touch and wheel" {
    var touch: TouchDriver = touch_driver_new();
    var key: KeyDriver = key_driver_new();
    var encoder: EncoderDriver = encoder_driver_new();
    var hover_pending: bool = false;
    var hover_point: Point = POINT_ZERO;
    var evt: Event = event_none();

    var hover_raw: FbHostEvent = FbHostEvent{
        kind: FB_EVT_HOVER_MOVE,
        x: 12,
        y: 18,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    fb_feed_host_event(&touch, &key, &encoder, &hover_raw, 1u32, &hover_pending, &hover_point);
    try assert_eq_bool(hover_pending, true);
    try assert_eq_i32(hover_point.x as i32, 12);
    try assert_eq_i32(hover_point.y as i32, 18);

    touch.set_filter_enabled(false);
    var down_raw: FbHostEvent = FbHostEvent{
        kind: FB_EVT_TOUCH_DOWN,
        x: 20,
        y: 22,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    fb_feed_host_event(&touch, &key, &encoder, &down_raw, 2u32, &hover_pending, &hover_point);
    try assert_eq_bool(touch.read(&evt), true);
    try expect(evt.event_type == EventType.Press);
    try assert_eq_i32(evt.point().x as i32, 20);

    var up_raw: FbHostEvent = FbHostEvent{
        kind: FB_EVT_TOUCH_UP,
        x: 20,
        y: 22,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    fb_feed_host_event(&touch, &key, &encoder, &up_raw, 3u32, &hover_pending, &hover_point);
    try assert_eq_bool(touch.read(&evt), true);
    try expect(evt.event_type == EventType.Release);

    var wheel_raw: FbHostEvent = FbHostEvent{
        kind: FB_EVT_WHEEL,
        x: 0,
        y: 0,
        value: -2,
        key_code: 0u16,
        reserved: 0u16,
    };
    fb_feed_host_event(&touch, &key, &encoder, &wheel_raw, 4u32, &hover_pending, &hover_point);
    try assert_eq_bool(encoder.read(&evt), true);
    try assert_eq_i32(evt.value(), -2);
}
