use core.dirty_region.DirtyRegion;
use core.dirty_region.dirty_region_new;
use core.rect.Rect;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_new;
use sim.web_present_plan.WebPresentPlan;
use sim.web_present_plan.WebPresentMode;
use sim.web_present_plan.web_build_present_plan;
use std.testing.assert_eq_i32;

export const TEST_WEB_PRESENT_PLAN_MODULE: i32 = 1;

test "web present plan keeps small dirty upload partial" {
    var dirty: DirtyRegion = dirty_region_new();
    dirty.add(Rect{ x: 4, y: 5, w: 8, h: 9 });
    var pixels: [byte: 16384] = [];
    const fb: FrameBuffer = framebuffer_new(&pixels[0], 64u16, 64u16, 256u16, PixelFormat.ARGB8888);
    const plan: WebPresentPlan = web_build_present_plan(&fb, &dirty);
    try assert_eq_i32(plan.mode as i32, WebPresentMode.Dirty as i32);
    try assert_eq_i32(plan.rect_count, 1);
}

test "web present plan falls back to full upload on large coverage" {
    var dirty: DirtyRegion = dirty_region_new();
    dirty.add(Rect{ x: 0, y: 0, w: 60, h: 60 });
    var pixels: [byte: 16384] = [];
    const fb: FrameBuffer = framebuffer_new(&pixels[0], 64u16, 64u16, 256u16, PixelFormat.ARGB8888);
    const plan: WebPresentPlan = web_build_present_plan(&fb, &dirty);
    try assert_eq_i32(plan.mode as i32, WebPresentMode.Full as i32);
    try assert_eq_i32(plan.rect_count, 1);
}

    test "web present plan skips empty dirty set" {
    var dirty: DirtyRegion = dirty_region_new();
    var pixels: [byte: 16384] = [];
    const fb: FrameBuffer = framebuffer_new(&pixels[0], 64u16, 64u16, 256u16, PixelFormat.ARGB8888);
    const plan: WebPresentPlan = web_build_present_plan(&fb, &dirty);
    try assert_eq_i32(plan.mode as i32, WebPresentMode.None as i32);
    try assert_eq_i32(plan.rect_count, 0);
}
