use core.color.Color;
use core.rect.Rect;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_new;
use render.ctx.RenderCtx;
use render.ctx.ctx_pixel;
use render.ctx.render_ctx_new;
use render.font.Font;
use render.font.font_system_default;
use richtext.document.RichDocument;
use richtext.document.rich_document_new;
use richtext.layout.RichLayoutCache;
use richtext.layout.rich_layout_cache_new;
use richtext.render.RichTextRenderer;
use richtext.render.rich_text_renderer_new;
use richtext.selection.RichPos;
use richtext.selection.RichRange;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_RICHTEXT_RENDER_MODULE: i32 = 1;

test "rich text renderer draws document text using visual lines" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("I" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 32u16, 0u32);

    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const white: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var renderer: RichTextRenderer = rich_text_renderer_new();
    try renderer.draw_document(&ctx, Rect{ x: 0, y: 0, w: 16u16, h: 16u16 }, &doc, &layout, &font, &white);

    try assert_eq_bool(ctx_pixel(&ctx, 2, 3) == white, true);
}

test "rich text renderer fills selection highlight rects" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 0u32);

    var bytes: [byte: 4096] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 32, 32, 128, PixelFormat.ARGB8888));
    const green: Color = Color{ r: 0, g: 255, b: 0, a: 255 };
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var renderer: RichTextRenderer = rich_text_renderer_new();
    var rects: [Rect: 4] = [];
    _ = try layout.selection_rects(&doc, &font, RichRange{
        anchor: try doc.linear_offset_to_pos(3u32),
        focus: try doc.linear_offset_to_pos(8u32),
    }, &rects[0], 4u32);
    const rect_count: u32 = try renderer.draw_selection(&ctx, Rect{ x: 0, y: 0, w: 32u16, h: 32u16 }, &doc, &layout, &font, RichRange{
        anchor: try doc.linear_offset_to_pos(3u32),
        focus: try doc.linear_offset_to_pos(8u32),
    }, &green);

    try assert_eq_i32(rect_count as i32, 2);
    try assert_eq_bool(ctx_pixel(&ctx, rects[0].x + 1i16, rects[0].y + 1i16) == green, true);
}

test "rich text renderer draws caret at layout position" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("ab" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 32u16, 0u32);

    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const white: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var renderer: RichTextRenderer = rich_text_renderer_new();
    const caret: RichPos = try doc.linear_offset_to_pos(1u32);
    const caret_rect: Rect = try renderer.draw_caret(&ctx, Rect{ x: 0, y: 0, w: 16u16, h: 16u16 }, &doc, &layout, &font, caret, &white);

    try assert_eq_i32(caret_rect.x as i32, (try layout.line_x_for_pos(&doc, &font, 0u32, caret)) as i32);
    try assert_eq_i32(caret_rect.y as i32, layout.lines[0].y as i32);
    try assert_eq_i32(caret_rect.h as i32, layout.lines[0].h as i32);
    try assert_eq_bool(ctx_pixel(&ctx, caret_rect.x, caret_rect.y + 1i16) == white, true);
}

test "rich text renderer draws placeholder text when asked" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    var font: Font = font_system_default();
    const white: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var renderer: RichTextRenderer = rich_text_renderer_new();
    renderer.draw_placeholder(&ctx, Rect{ x: 0, y: 0, w: 16u16, h: 16u16 }, "I" as &const byte, 1usize, &font, &white);

    try assert_eq_bool(ctx_pixel(&ctx, 2, 3) == white, true);
}
