use core.event.Event;
use core.event.EventType;
use core.event.InputDev;
use core.event.event_point;
use core.point.Point;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_new;
use platform.disp.framebuffer_required_bytes;
use render.ctx.RenderCtx;
use render.ctx.render_ctx_new;
use examples.demo_game.game_retained_new;
use sim.app.SimApp;
use sim.app.sim_app_new;
use sim.common.SIM_DEFAULT_RES_HEIGHT;
use sim.common.SIM_DEFAULT_RES_WIDTH;
use sim.common.sim_layout_x;
use sim.common.sim_layout_y;
use sim.common.sim_cstr_eq;
use sim.common.SIM_KEY_F11;
use sim.common.SIM_KEY_LEFT;
use sim.common.SIM_KEY_SPACE;
use sim.config.SimConfig;
use sim.config.SimDemoKind;
use sim.config.SimGpuKind;
use sim.config.sim_config_default;
use sim.config.sim_gpu_name;
use sim.recorder.RecordedEvent;
use sim.recorder.RecorderEventKind;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

extern fn malloc(size: usize) &void;
extern fn free(ptr: &void) void;

export const TEST_SIM_APP_MODULE: i32 = 1;

test "sim config defaults to auto gpu and exposes names" {
    const cfg: SimConfig = sim_config_default();
    try assert_eq_i32(cfg.gpu as i32, SimGpuKind.Auto as i32);
    try assert_eq_i32(cfg.width as i32, SIM_DEFAULT_RES_WIDTH as i32);
    try assert_eq_i32(cfg.height as i32, SIM_DEFAULT_RES_HEIGHT as i32);
    try assert_eq_bool(sim_cstr_eq(sim_gpu_name(SimGpuKind.Auto), "auto"), true);
    try assert_eq_bool(sim_cstr_eq(sim_gpu_name(SimGpuKind.Software), "software"), true);
    try assert_eq_bool(sim_cstr_eq(sim_gpu_name(SimGpuKind.Gles2), "gles2"), true);
}

test "sim app renders and reacts to playback-style input" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.width = 320;
    cfg.height = 240;
    try assert_eq_bool(app.init(cfg), true);

    var down: RecordedEvent = RecordedEvent{
        frame_offset: 0u32,
        kind: RecorderEventKind.TouchDown,
        x: 40,
        y: 80,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    var up: RecordedEvent = RecordedEvent{
        frame_offset: 60u32,
        kind: RecorderEventKind.TouchUp,
        x: 40,
        y: 80,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    app.handle_recorded_event(&down, 100u32);
    app.handle_recorded_event(&up, 160u32);
    try assert_eq_i32(app.tap_count, 1);

    var wheel: RecordedEvent = RecordedEvent{
        frame_offset: 100u32,
        kind: RecorderEventKind.Wheel,
        x: 40,
        y: 80,
        value: 2,
        key_code: 0u16,
        reserved: 0u16,
    };
    app.handle_recorded_event(&wheel, 200u32);
    try assert_eq_bool(app.slider.get_value() > 42, true);

    var key_evt: RecordedEvent = RecordedEvent{
        frame_offset: 140u32,
        kind: RecorderEventKind.KeyDown,
        x: 0,
        y: 0,
        value: 0,
        key_code: SIM_KEY_F11,
        reserved: 0u16,
    };
    app.handle_recorded_event(&key_evt, 240u32);
    try assert_eq_bool(app.consume_fullscreen_toggle(), true);

    var pixels: [byte: 307200] = [];
    const fb: FrameBuffer = framebuffer_new(&pixels[0], cfg.width, cfg.height, cfg.width * 4u16, PixelFormat.ARGB8888);
    var ctx: RenderCtx = render_ctx_new(fb);
    app.render(&ctx);
    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
    try assert_eq_bool(ctx.stats.image_ops > 0u32, true);
}

test "sim app can render standalone dashboard demo mode" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    const width: u16 = SIM_DEFAULT_RES_WIDTH;
    const height: u16 = SIM_DEFAULT_RES_HEIGHT;
    cfg.demo = SimDemoKind.Dashboard;
    cfg.width = width;
    cfg.height = height;
    try assert_eq_bool(app.init(cfg), true);

    const pixels_len: usize = framebuffer_required_bytes(width, height, PixelFormat.ARGB8888);
    const pixels: &byte = malloc(pixels_len) as &byte;
    if pixels == null {
        try assert_eq_bool(false, true);
        return;
    }
    defer {
        free(pixels as &void);
    }
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(pixels, width, height, width * 4u16, PixelFormat.ARGB8888));
    app.render(&ctx);
    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
    try assert_eq_bool(ctx.stats.line_ops > 0u32, true);
}

test "standalone music demo reacts to touch click" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Music;
    cfg.width = SIM_DEFAULT_RES_WIDTH;
    cfg.height = SIM_DEFAULT_RES_HEIGHT;
    try assert_eq_bool(app.init(cfg), true);
    try assert_eq_bool(app.music_playing, false);

    var click_evt: Event = event_point(EventType.Click, InputDev.Touch, -1, 40u32, Point{ x: sim_layout_x(64), y: sim_layout_y(260) });
    app.handle_translated_event(&click_evt);
    try assert_eq_bool(app.music_playing, true);
}

test "standalone dashboard and 2048 demos react to touch and playback taps" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Dashboard;
    cfg.width = SIM_DEFAULT_RES_WIDTH;
    cfg.height = SIM_DEFAULT_RES_HEIGHT;
    try assert_eq_bool(app.init(cfg), true);

    var dashboard_click: Event = event_point(EventType.Click, InputDev.Touch, -1, 40u32, Point{ x: sim_layout_x(504), y: sim_layout_y(228) });
    app.handle_translated_event(&dashboard_click);
    try assert_eq_i32(app.dashboard_metric, 1);

    app.switch_demo(SimDemoKind.Game, "test");
    app.game_demo = game_retained_new();
    app.game_demo.ready = true;
    app.game_demo.rng_state = 11u32;
    app.game_demo.board[0] = 2;
    app.game_demo.board[1] = 2;

    app.handle_key_event(SIM_KEY_LEFT, true, 50u32, false);
    try assert_eq_i32(app.game_demo.board[0], 4);
    try assert_eq_i32(app.game_demo.score, 4);

    app.game_demo = game_retained_new();
    app.game_demo.ready = true;
    app.game_demo.rng_state = 19u32;
    app.game_demo.board[0] = 2;
    app.game_demo.board[4] = 2;
    var press_evt: Event = event_point(EventType.Press, InputDev.Touch, -1, 60u32, Point{ x: 160, y: 260 });
    var release_evt: Event = event_point(EventType.Release, InputDev.Touch, -1, 72u32, Point{ x: 160, y: 180 });
    app.handle_translated_event(&press_evt);
    app.handle_translated_event(&release_evt);
    try assert_eq_i32(app.game_demo.board[0], 4);
    try assert_eq_i32(app.game_demo.score, 4);

    app.game_demo = game_retained_new();
    app.game_demo.ready = true;
    app.game_demo.rng_state = 27u32;
    app.game_demo.board[0] = 2;
    app.game_demo.board[4] = 2;
    var down: RecordedEvent = RecordedEvent{
        frame_offset: 0u32,
        kind: RecorderEventKind.TouchDown,
        x: 160,
        y: 260,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    var up: RecordedEvent = RecordedEvent{
        frame_offset: 10u32,
        kind: RecorderEventKind.TouchUp,
        x: 160,
        y: 180,
        value: 0,
        key_code: 0u16,
        reserved: 0u16,
    };
    app.handle_recorded_event(&down, 100u32);
    app.handle_recorded_event(&up, 110u32);
    try assert_eq_i32(app.game_demo.board[0], 4);
    try assert_eq_i32(app.game_demo.score, 4);
}

test "standalone novel demo exposes 10k+ chinese text and supports scrolling" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Novel;
    cfg.width = SIM_DEFAULT_RES_WIDTH;
    cfg.height = SIM_DEFAULT_RES_HEIGHT;
    try assert_eq_bool(app.init(cfg), true);

    const pixels_len: usize = framebuffer_required_bytes(cfg.width, cfg.height, PixelFormat.ARGB8888);
    const pixels: &byte = malloc(pixels_len) as &byte;
    if pixels == null {
        try assert_eq_bool(false, true);
        return;
    }
    defer {
        free(pixels as &void);
    }
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(pixels, cfg.width, cfg.height, cfg.width * 4u16, PixelFormat.ARGB8888));
    app.render(&ctx);
    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
    try assert_eq_bool(app.novel_demo.char_count > 10000, true);
    try assert_eq_bool(app.novel_demo.line_count > 200, true);

    const scroll_before: i32 = app.novel_demo.scroll_y;
    app.handle_wheel_event(-2, 80u32, false);
    try assert_eq_bool(app.novel_demo.scroll_y > scroll_before, true);

    try assert_eq_bool(app.novel_demo.auto_scroll, false);
    app.handle_key_event(SIM_KEY_SPACE, true, 100u32, false);
    try assert_eq_bool(app.novel_demo.auto_scroll, true);
}
