use core.event.Event;
use core.event.EventType;
use core.event.InputDev;
use core.event.event_point;
use core.point.Point;
use core.rect.Rect;
use libc.O_RDONLY;
use libc.sys_close;
use libc.sys_open;
use libc.sys_read;
use libc.pthread;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_new;
use platform.disp.framebuffer_required_bytes;
use render.ctx.RenderCtx;
use render.ctx.render_ctx_new;
use sim.app.SimApp;
use sim.app.sim_app_new;
use sim.common.SIM_DEFAULT_RES_HEIGHT;
use sim.common.SIM_DEFAULT_RES_WIDTH;
use sim.config.SimConfig;
use sim.config.SimDemoKind;
use sim.config.sim_config_default;
use sim.recorder.RecordedEvent;
use sim.recorder.RecorderEventKind;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

extern fn malloc(size: usize) &void;
extern fn free(ptr: &void) void;

export const TEST_INTEGRATION_MODULE: i32 = 1;

const INTEGRATION_CONCURRENT_WORKERS: i32 = 4;
const INTEGRATION_WORKER_CLICKS: i32 = 8;
const INTEGRATION_RSS_THRESHOLD_KB: i32 = 16384;

var _integration_start_flag: atomic i32 = 0;
var _integration_clicks_done: [i32: 4] = [];
var _integration_mutex: pthread_mutex_t = pthread_mutex_t{ state: 0, owner: 0, type: 0 };
struct IntegrationRecordedBuffer {
    events: [RecordedEvent: 64],
    count: i32,
}

var _integration_shared_events: &IntegrationRecordedBuffer = null;
var _integration_inject_point: Point = Point{ x: 0, y: 0 };

fn integration_ctx_for_pixels(pixels: &byte, width: u16, height: u16) RenderCtx {
    return render_ctx_new(framebuffer_new(pixels, width, height, width * 4u16, PixelFormat.ARGB8888));
}

fn integration_event_at(kind: EventType, timestamp: u32, point: Point) Event {
    return event_point(kind, InputDev.Touch, -1, timestamp, point);
}

fn integration_nav_click_point(rect: Rect) Point {
    return Point{
        x: rect.x + rect.w as i16 / 2,
        y: rect.y + rect.h as i16 / 2,
    };
}

fn integration_demo_has_rich_output(demo: SimDemoKind, ctx: &RenderCtx) bool {
    if ctx == null {
        return false;
    }
    if demo == SimDemoKind.Dashboard || demo == SimDemoKind.Game {
        return ctx.stats.line_ops > 0u32 || ctx.stats.rect_ops > 0u32 || ctx.stats.text_ops > 0u32;
    }
    if demo == SimDemoKind.Perf || demo == SimDemoKind.Widgets || demo == SimDemoKind.Custom {
        return ctx.stats.text_ops > 0u32 && (ctx.stats.image_ops > 0u32 || ctx.stats.line_ops > 0u32 || ctx.stats.rect_ops > 0u32);
    }
    return ctx.stats.text_ops > 0u32 || ctx.stats.image_ops > 0u32 || ctx.stats.line_ops > 0u32 || ctx.stats.rect_ops > 0u32;
}

fn integration_read_rss_kb() !i32 {
    var buf: [byte: 4096] = [];
    const fd: i32 = (sys_open("/proc/self/status\0" as *const byte, O_RDONLY as i32, 0) catch {
        return error.AssertionFailed;
    });
    defer {
        _ = sys_close(fd) catch {};
    }
    const n: isize = (sys_read(fd, &buf[0], 4096usize) catch {
        return error.AssertionFailed;
    });
    if n <= 0 {
        return error.AssertionFailed;
    }

    const pattern: [byte: 6] = ['V', 'm', 'R', 'S', 'S', ':'];
    var i: i32 = 0;
    while i + 6 < n as i32 {
        var matched: bool = true;
        var j: i32 = 0;
        while j < 6 {
            if buf[(i + j) as usize] != pattern[j as usize] {
                matched = false;
                break;
            }
            j = j + 1;
        }
        if matched {
            var cursor: i32 = i + 6;
            while cursor < n as i32 && (buf[cursor as usize] == ' ' || buf[cursor as usize] == '\t') {
                cursor = cursor + 1;
            }
            var value: i32 = 0;
            while cursor < n as i32 && buf[cursor as usize] >= '0' && buf[cursor as usize] <= '9' {
                value = value * 10 + (buf[cursor as usize] as i32 - '0' as i32);
                cursor = cursor + 1;
            }
            return value;
        }
        i = i + 1;
    }
    return error.AssertionFailed;
}

fn integration_render_demo_frame(app: &SimApp, width: u16, height: u16, pixels: &byte, force_full: bool) RenderCtx {
    var ctx: RenderCtx = integration_ctx_for_pixels(pixels, width, height);
    if app.supports_dirty_render() {
        _ = app.render_retained(&ctx, force_full);
    } else {
        app.render(&ctx);
    }
    return ctx;
}

fn integration_click_home_entry(app: &SimApp, index: i32, timestamp: u32) void {
    const rect: Rect = app.home_nav_button_rect(index);
    const point: Point = integration_nav_click_point(rect);
    var evt: Event = integration_event_at(EventType.Click, timestamp, point);
    app.handle_translated_event(&evt);
}

fn integration_click_back(app: &SimApp, timestamp: u32) void {
    const rect: Rect = app.standalone_back_button_rect();
    const point: Point = integration_nav_click_point(rect);
    var evt: Event = integration_event_at(EventType.Click, timestamp, point);
    app.handle_translated_event(&evt);
}

fn integration_scene_worker(arg: &void) &void {
    const worker_idx_ref: &i32 = arg as &i32;
    const worker_idx: i32 = worker_idx_ref[0];
    while _integration_start_flag == 0 {
        _ = pthread_yield();
    }

    var click_idx: i32 = 0;
    while click_idx < INTEGRATION_WORKER_CLICKS {
        _ = pthread_mutex_lock(&_integration_mutex);
        const injected: &IntegrationRecordedBuffer = _integration_shared_events;
        if injected != null && injected.count < 64 {
            const ts: u32 = ((worker_idx * 1000 + click_idx * 3) as! u32).value;
            injected.events[injected.count as usize] = RecordedEvent{
                frame_offset: ts + 2u32,
                kind: RecorderEventKind.TouchUp,
                x: _integration_inject_point.x,
                y: _integration_inject_point.y,
                value: 0,
                key_code: 0u16,
                reserved: 0u16,
            };
            injected.count = injected.count + 1;
        }
        _ = pthread_mutex_unlock(&_integration_mutex);
        click_idx = click_idx + 1;
    }

    _integration_clicks_done[worker_idx as usize] = click_idx;
    return null;
}

test "integration suite walks 10 plus complex app scenes through home navigation" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Phase4;
    cfg.width = SIM_DEFAULT_RES_WIDTH;
    cfg.height = SIM_DEFAULT_RES_HEIGHT;
    try assert_eq_bool(app.init(cfg), true);

    const pixels_len: usize = framebuffer_required_bytes(cfg.width, cfg.height, PixelFormat.ARGB8888);
    const pixels: &byte = malloc(pixels_len) as &byte;
    if pixels == null {
        try assert_eq_bool(false, true);
        return;
    }
    defer {
        free(pixels as &void);
    }

    var home_ctx: RenderCtx = integration_render_demo_frame(&app, cfg.width, cfg.height, pixels, true);
    try assert_eq_bool(home_ctx.stats.text_ops > 0u32, true);

    var i: i32 = 0;
    while i < 9 {
        integration_click_home_entry(&app, i, ((100 + i) as! u32).value);
        try assert_eq_i32(app.config.demo as i32, app.home_nav_button_demo(i) as i32);

        var demo_ctx: RenderCtx = integration_render_demo_frame(&app, cfg.width, cfg.height, pixels, true);
        try assert_eq_bool(integration_demo_has_rich_output(app.config.demo, &demo_ctx), true);

        integration_click_back(&app, ((300 + i) as! u32).value);
        try assert_eq_i32(app.config.demo as i32, SimDemoKind.Phase4 as i32);
        i = i + 1;
    }
}

test "integration virtual 24h retained loop stays stable" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Phase4;
    cfg.width = 320u16;
    cfg.height = 240u16;
    try assert_eq_bool(app.init(cfg), true);

    app.toggle.checked = true;
    const pixels_len: usize = framebuffer_required_bytes(cfg.width, cfg.height, PixelFormat.ARGB8888);
    const pixels: &byte = malloc(pixels_len) as &byte;
    if pixels == null {
        try assert_eq_bool(false, true);
        return;
    }
    defer {
        free(pixels as &void);
    }

    var now_ms: u32 = 0u32;
    var frame_idx: i32 = 0;
    while frame_idx < 1440 {
        now_ms = now_ms + 60000u32;
        app.update(60000u32, now_ms);
        if frame_idx % 12 == 0 {
            var ctx: RenderCtx = integration_render_demo_frame(&app, cfg.width, cfg.height, pixels, frame_idx == 0);
            try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
        }
        frame_idx = frame_idx + 1;
    }

    try assert_eq_bool(app.pending_exit, false);
    try assert_eq_bool(app.chart.point_count > 0u16, true);
    try assert_eq_bool(app.chart.point_count <= 60u16, true);
    try assert_eq_bool(app.last_chart_tick_ms > 0u32, true);
}

test "integration repeated scene batches keep rss growth bounded" {
    const warmup_start_kb: i32 = try integration_read_rss_kb();
    _ = warmup_start_kb;

    var warmup: i32 = 0;
    while warmup < 9 {
        var warm_app: SimApp = sim_app_new();
        var warm_cfg: SimConfig = sim_config_default();
        if warmup % 3 == 0 {
            warm_cfg.demo = SimDemoKind.Novel;
        } else if warmup % 3 == 1 {
            warm_cfg.demo = SimDemoKind.Widgets;
        } else {
            warm_cfg.demo = SimDemoKind.Custom;
        }
        warm_cfg.width = 320u16;
        warm_cfg.height = 240u16;
        try assert_eq_bool(warm_app.init(warm_cfg), true);
        var warm_pixels: [byte: 307200] = [];
        var warm_ctx: RenderCtx = integration_render_demo_frame(&warm_app, warm_cfg.width, warm_cfg.height, &warm_pixels[0], true);
        try assert_eq_bool(warm_ctx.stats.text_ops > 0u32, true);
        warmup = warmup + 1;
    }

    const before_kb: i32 = try integration_read_rss_kb();
    var iter: i32 = 0;
    while iter < 12 {
        var app: SimApp = sim_app_new();
        var cfg: SimConfig = sim_config_default();
        cfg.width = 320u16;
        cfg.height = 240u16;
        if iter % 3 == 0 {
            cfg.demo = SimDemoKind.Novel;
        } else if iter % 3 == 1 {
            cfg.demo = SimDemoKind.Widgets;
        } else {
            cfg.demo = SimDemoKind.Custom;
        }
        try assert_eq_bool(app.init(cfg), true);
        var pixels: [byte: 307200] = [];
        var ctx: RenderCtx = integration_render_demo_frame(&app, cfg.width, cfg.height, &pixels[0], true);
        try assert_eq_bool(integration_demo_has_rich_output(cfg.demo, &ctx), true);
        iter = iter + 1;
    }
    const after_kb: i32 = try integration_read_rss_kb();
    try assert_eq_bool(after_kb - before_kb <= INTEGRATION_RSS_THRESHOLD_KB, true);
}

test "integration multithreaded event injection stays consistent under serialized dispatch" {
    var app: SimApp = sim_app_new();
    var cfg: SimConfig = sim_config_default();
    cfg.demo = SimDemoKind.Phase4;
    cfg.width = 320u16;
    cfg.height = 240u16;
    try assert_eq_bool(app.init(cfg), true);

    var injected: IntegrationRecordedBuffer = IntegrationRecordedBuffer{
        events: [],
        count: 0,
    };
    var workers: [pthread_t: 4] = [];
    var worker_ids: [i32: 4] = [0, 1, 2, 3];
    var i: i32 = 0;
    const action: Rect = app.action_button.widget.base.screen_area();
    _integration_shared_events = &injected;
    _integration_inject_point = integration_nav_click_point(action);
    _integration_start_flag = 0;
    try assert_eq_i32(pthread_mutex_init(&_integration_mutex, null as &const pthread_mutexattr_t), 0);
    while i < INTEGRATION_CONCURRENT_WORKERS {
        _integration_clicks_done[i as usize] = 0;
        try assert_eq_i32(pthread_create(&workers[i as usize], null as &const pthread_attr_t, &integration_scene_worker as &void, (&worker_ids[i as usize]) as &void), 0);
        i = i + 1;
    }

    _integration_start_flag = 1;

    i = 0;
    while i < INTEGRATION_CONCURRENT_WORKERS {
        try assert_eq_i32(pthread_join(&workers[i as usize], null as & &void), 0);
        i = i + 1;
    }
    _ = pthread_mutex_destroy(&_integration_mutex);
    _integration_shared_events = null;

    var total_clicks: i32 = 0;
    i = 0;
    while i < INTEGRATION_CONCURRENT_WORKERS {
        total_clicks = total_clicks + _integration_clicks_done[i as usize];
        i = i + 1;
    }
    i = 0;
    while i < injected.count {
        const record: RecordedEvent = injected.events[i as usize];
        var evt: Event = event_point(
            EventType.Click,
            InputDev.Touch,
            -1,
            record.frame_offset,
            Point{ x: record.x, y: record.y }
        );
        app.handle_translated_event(&evt);
        i = i + 1;
    }
    try assert_eq_i32(total_clicks, INTEGRATION_CONCURRENT_WORKERS * INTEGRATION_WORKER_CLICKS);
    try assert_eq_i32(injected.count, total_clicks);
    try assert_eq_i32(app.tap_count, total_clicks);
}
