export const TEST_WIDGET_MODULE: i32 = 1;

struct CountingWidgetEvent : IWidgetEventCallback {
    count_ref: &i32,
}

struct CountingWidgetValue : IWidgetValueCallback {
    value_ref: &i32,
}

CountingWidgetEvent {
    fn invoke(self: &Self, widget: &Widget, evt: &Event, user_data: &void) void {
        _ = widget;
        _ = evt;
        _ = user_data;
        self.count_ref[0] = self.count_ref[0] + 1;
    }
}

CountingWidgetValue {
    fn invoke(self: &Self, widget: &Widget, value: i32, user_data: &void) void {
        _ = widget;
        _ = user_data;
        self.value_ref[0] = value;
    }
}

test "button integrates with dispatcher click callback" {
    var button: Button = Button.filled("OK");
    button.widget.at(0, 0);

    var click_count: i32 = 0;
    var cb_impl: CountingWidgetEvent = CountingWidgetEvent{ count_ref: &click_count };
    var cb: IWidgetEventCallback = cb_impl;
    button.on_click(&cb, null);

    var press_evt: Event = event_point(EventType.Press, InputDev.Touch, -1, 100, Point{ x: 8, y: 8 });
    var release_evt: Event = event_point(EventType.Release, InputDev.Touch, -1, 160, Point{ x: 8, y: 8 });
    var click_evt: Event = event_point(EventType.Click, InputDev.Touch, -1, 161, Point{ x: 8, y: 8 });
    _ = button.handle_event(&press_evt);
    _ = button.handle_event(&release_evt);
    _ = button.handle_event(&click_evt);

    try assert_eq_i32(click_count, 1);
}

test "panel renders child button and label through gui tree" {
    var bytes: [byte: 4096] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 32, 32, 128, PixelFormat.ARGB8888));

    var panel: Panel = Panel.new();
    var button: Button = Button.filled("A");
    var label: Label = Label.new("T");

    panel.widget.at(0, 0);
    panel.widget.size(32, 32);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
    button.widget.at(4, 4);
    button.widget.size(20, 12);
    label.widget.at(4, 20);
    label.widget.size(20, 8);

    panel.add(button.obj());
    panel.add(label.obj());
    panel.render(&ctx);

    try assert_eq_bool(ctx_pixel(&ctx, 8, 10) == Color{ r: 33, g: 126, b: 227, a: 255 }, true);
    try assert_eq_bool(ctx.stats.text_ops >= 2u32, true);
}

test "image widget scales source into target area" {
    var fb: [byte: 4096] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&fb[0], 16, 16, 64, PixelFormat.ARGB8888));
    var img_bytes: [byte: 12] = [255, 0, 0,   0, 255, 0,   0, 0, 255,   255, 255, 255];
    var image_data: ImageData = image_data_new(&img_bytes[0], 2, 2, 6, PixelFormat.RGB888);
    var image: Image = Image.from_data(&image_data);
    image.widget.at(0, 0);
    image.widget.size(8, 8);

    image.render(&ctx);
    try assert_eq_bool(ctx.stats.image_ops > 0u32, true);
}

test "slider and switch propagate value changes" {
    var slider: Slider = Slider.new(0, 100, 25);
    var sw: Switch = Switch.new(false);
    var value: i32 = -1;
    var cb_impl: CountingWidgetValue = CountingWidgetValue{ value_ref: &value };
    var cb: IWidgetValueCallback = cb_impl;
    slider.on_change(&cb, null);

    var slider_evt: Event = event_point(EventType.Click, InputDev.Touch, 2, 10, Point{ x: 140, y: 10 });
    _ = slider.handle_event(&slider_evt);
    try assert_eq_bool(value >= 0, true);

    value = -1;
    sw.on_change(&cb, null);
    var switch_evt: Event = event_point(EventType.Click, InputDev.Touch, 3, 12, Point{ x: 12, y: 12 });
    _ = sw.handle_event(&switch_evt);
    try assert_eq_bool(sw.checked, true);
    try assert_eq_i32(value, 1);
}

test "list view selection and grid view children work" {
    var list: ListView = ListView.new();
    list.add_item("One");
    list.add_item("Two");
    list.add_item("Three");
    list.select_next();
    list.select_next();
    try assert_eq_i32(list.selected(), 1);
    try assert_eq_i32(list.content_size().h as i32, 72);

    var grid: GridView = GridView.new();
    var bytes: [byte: 36864] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 96, 96, 384, PixelFormat.ARGB8888));
    var a: Button = Button.outlined("1");
    var b: Button = Button.outlined("2");
    grid.widget.at(0, 0);
    grid.widget.size(80, 80);
    grid.columns = 1;
    grid.item_size.w = 32;
    grid.item_size.h = 20;
    grid.row_gap = 6u8;
    grid.cell_padding = 3u8;
    grid.add_child(a.obj());
    grid.add_child(b.obj());
    grid.render(&ctx);
    try assert_eq_i32(grid.child_count(), 2);
    try assert_eq_i32(a.widget.base.x as i32, 11);
    try assert_eq_i32(a.widget.base.y as i32, 11);
    try assert_eq_i32(a.widget.base.w as i32, 26);
    try assert_eq_i32(a.widget.base.h as i32, 14);
    try assert_eq_i32(b.widget.base.y as i32 - a.widget.base.y as i32, 26);
}

test "grid view can center child content inside padded cells" {
    var bytes: [byte: 36864] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 96, 96, 384, PixelFormat.ARGB8888));
    var grid: GridView = GridView.new();
    var button: Button = Button.outlined("C");

    grid.widget.at(0, 0);
    grid.widget.size(80, 80);
    grid.columns = 1;
    grid.item_size.w = 32;
    grid.item_size.h = 20;
    grid.cell_padding = 3u8;
    grid.cell_content_mode = GridCellContentMode.Center;
    button.widget.size(12, 10);
    grid.add_child(button.obj());
    grid.render(&ctx);

    try assert_eq_i32(button.widget.base.x as i32, 18);
    try assert_eq_i32(button.widget.base.y as i32, 13);
    try assert_eq_i32(button.widget.base.w as i32, 12);
    try assert_eq_i32(button.widget.base.h as i32, 10);
}

test "grid view can center the whole content block" {
    var bytes: [byte: 36864] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 96, 96, 384, PixelFormat.ARGB8888));
    var grid: GridView = GridView.new();
    var a: Button = Button.outlined("A");
    var b: Button = Button.outlined("B");

    grid.widget.at(0, 0);
    grid.widget.size(80, 80);
    grid.columns = 1;
    grid.item_size.w = 20;
    grid.item_size.h = 12;
    grid.row_gap = 4u8;
    grid.content_align_x = GridContentAlign.Center;
    grid.content_align_y = GridContentAlign.Center;
    grid.add_child(a.obj());
    grid.add_child(b.obj());
    grid.render(&ctx);

    try assert_eq_i32(a.widget.base.x as i32, 30);
    try assert_eq_i32(a.widget.base.y as i32, 26);
    try assert_eq_i32(b.widget.base.x as i32, 30);
    try assert_eq_i32(b.widget.base.y as i32, 42);
}

test "chart and canvas render content" {
    var back_bytes: [byte: 8192] = [];
    var canvas_bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&back_bytes[0], 48, 32, 192, PixelFormat.ARGB8888));

    var chart: Chart = Chart.new();
    chart.chart_type = ChartType.Area;
    _ = chart.add_point(2);
    _ = chart.add_point(6);
    _ = chart.add_point(3);
    _ = chart.add_point(8);
    chart.widget.at(0, 0);
    chart.widget.size(24, 16);
    chart.render(&ctx);
    try assert_eq_bool(ctx.stats.line_ops > 0u32, true);

    var canvas: Canvas = Canvas.with_buffer(&canvas_bytes[0], 8, 8, 32, PixelFormat.ARGB8888);
    canvas.widget.at(24, 0);
    canvas.widget.size(16, 16);
    canvas.begin_draw().fill_rect(Rect{ x: 0, y: 0, w: 8, h: 8 }, Color{ r: 0, g: 255, b: 0, a: 255 });
    canvas.end_draw();
    canvas.render(&ctx);

    try assert_eq_bool(ctx_pixel(&ctx, 28, 4) == Color{ r: 0, g: 255, b: 0, a: 255 }, true);
}

test "page can render nested widgets" {
    gui_obj_reset_registry();

    var bytes: [byte: 8192] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 48, 32, 192, PixelFormat.ARGB8888));
    var page: Page = Page.new("Page");
    var panel: Panel = Panel.new();
    var button: Button = Button.filled("A");

    page.widget.size(48, 32);
    page.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
    panel.widget.at(2, 2);
    panel.widget.size(28, 18);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 2u32);
    button.widget.at(4, 4);
    button.widget.size(20, 12);

    page.add(panel.obj());
    panel.add(button.obj());
    page.render(&ctx);

    try assert_eq_bool(ctx_pixel(&ctx, 9, 10) == Color{ r: 33, g: 126, b: 227, a: 255 }, true);
    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
}

test "page navigator supports push pop transitions and edge swipe" {
    var bytes: [byte: 8192] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 48, 32, 192, PixelFormat.ARGB8888));
    var page_a: Page = Page.new("A");
    var page_b: Page = Page.new("B");
    page_a.widget.at(0, 0);
    page_a.widget.size(48, 32);
    page_b.widget.at(0, 0);
    page_b.widget.size(48, 32);
    page_a.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 255, g: 240, b: 240, a: 255 });
    page_b.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 240, g: 248, b: 255, a: 255 });

    var nav: PageNavigator = page_navigator_new(Rect{ x: 0, y: 0, w: 48, h: 32 });
    try assert_eq_bool(nav.push(page_a.obj(), PageTransitionKind.None, 0u32), true);
    try assert_eq_bool(nav.push(page_b.obj(), PageTransitionKind.SlideLeft, 120u32), true);
    try assert_eq_bool(nav.is_animating(), true);
    nav.render(&ctx);
    nav.update(60u32);
    try assert_eq_bool(nav.is_animating(), true);
    nav.update(60u32);
    try assert_eq_bool(nav.top() == page_b.obj(), true);

    var swipe_evt: Event = event_point(EventType.SwipeRight, InputDev.Touch, -1, 200u32, Point{ x: 2, y: 8 });
    try assert_eq_bool(nav.handle_event(&swipe_evt), true);
    nav.update(180u32);
    try assert_eq_bool(nav.top() == page_a.obj(), true);
}

test "widget surface applies blurred style shadows" {
    var bytes: [byte: 8192] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 32, 24, 128, PixelFormat.ARGB8888));
    var panel: Panel = Panel.new();
    const black_clear: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const black_expect: Color = Color{ r: 0, g: 0, b: 0, a: 255 };

    ctx.clear(black_clear);
    panel.widget.at(4, 4);
    panel.widget.size(12, 12);
    panel.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 32, g: 48, b: 72, a: 255 });
    panel.widget.base.style.set_u32(StyleProp.Radius, 4u32);
    panel.widget.base.style.set_i32(StyleProp.ShadowOffsetX, 3);
    panel.widget.base.style.set_i32(StyleProp.ShadowOffsetY, 1);
    panel.widget.base.style.set_i32(StyleProp.ShadowBlur, 3);
    panel.widget.base.style.set_color(StyleProp.ShadowColor, Color{ r: 255, g: 255, b: 255, a: 160 });

    panel.render(&ctx);

    const shadow: Color = ctx_pixel(&ctx, 19, 10);
    try assert_eq_bool(shadow.r > 0u8, true);
    try assert_eq_bool(shadow.r < 255u8, true);
    try assert_eq_bool(ctx_pixel(&ctx, 1, 1) == black_expect, true);
}
