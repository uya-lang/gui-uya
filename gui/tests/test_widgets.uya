test "chart and canvas render content" {
    var back_bytes: [byte: 8192] = [];
    var canvas_bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&back_bytes[0], 48, 32, 192, PixelFormat.ARGB8888));

    var chart: Chart = Chart.new();
    chart.chart_type = ChartType.Area;
    _ = chart.add_point(2);
    _ = chart.add_point(6);
    _ = chart.add_point(3);
    _ = chart.add_point(8);
    chart.widget.at(0, 0);
    chart.widget.size(24, 16);
    chart.render(&ctx);
    try assert_eq_bool(ctx.stats.line_ops > 0u32, true);

    var canvas: Canvas = Canvas.with_buffer(&canvas_bytes[0], 8, 8, 32, PixelFormat.ARGB8888);
    canvas.widget.at(24, 0);
    canvas.widget.size(16, 16);
    canvas.begin_draw().fill_rect(Rect{ x: 0, y: 0, w: 8, h: 8 }, Color{ r: 0, g: 255, b: 0, a: 255 });
    canvas.end_draw();
    canvas.render(&ctx);

    try assert_eq_bool(ctx_pixel(&ctx, 28, 4) == Color{ r: 0, g: 255, b: 0, a: 255 }, true);
}

test "page can render nested widgets" {
    gui_obj_reset_registry();

    var bytes: [byte: 8192] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 48, 32, 192, PixelFormat.ARGB8888));
    var page: Page = Page.new("Page");
    var panel: Panel = Panel.new();
    var button: Button = Button.filled("A");

    page.widget.size(48, 32);
    page.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
    panel.widget.at(2, 2);
    panel.widget.size(28, 18);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 2u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 2u32);
    button.widget.at(4, 4);
    button.widget.size(20, 12);

    page.add(panel.obj());
    panel.add(button.obj());
    page.render(&ctx);

    try assert_eq_bool(ctx_pixel(&ctx, 9, 10) == Color{ r: 33, g: 126, b: 227, a: 255 }, true);
    try assert_eq_bool(ctx.stats.text_ops > 0u32, true);
}

test "page culls fully occluded lower sibling subtree when later sibling is opaque" {
    gui_obj_reset_registry();

    var bytes: [byte: 8192] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 40, 40, 160, PixelFormat.ARGB8888));
    var page: Page = Page.new("CullPage");
    var bottom: Panel = Panel.new();
    var top: Panel = Panel.new();
    var label: Label = Label.new("Hidden");
    const top_color_draw: Color = Color{ r: 24, g: 32, b: 48, a: 255 };
    const top_color_expect: Color = Color{ r: 24, g: 32, b: 48, a: 255 };

    page.widget.size(40, 40);
    page.widget.base.style.set_color(StyleProp.BgColor, Color{ r: 0, g: 0, b: 0, a: 0 });
    page.widget.base.style.set_u32(StyleProp.BorderWidth, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);

    bottom.widget.at(4, 4);
    bottom.widget.size(24, 24);
    bottom.widget.base.style.set_u32(StyleProp.Radius, 0u32);
    bottom.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    bottom.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    bottom.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    bottom.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);

    label.widget.at(4, 8);
    label.widget.size(16, 8);
    bottom.add(label.obj());

    top.widget.at(4, 4);
    top.widget.size(24, 24);
    top.widget.base.style.set_color(StyleProp.BgColor, top_color_draw);
    top.widget.base.style.set_u32(StyleProp.Radius, 0u32);

    page.add(bottom.obj());
    page.add(top.obj());
    page.render(&ctx);

    try assert_eq_i32(ctx.stats.text_ops as i32, 0);
    try assert_eq_bool(ctx_pixel(&ctx, 10, 10) == top_color_expect, true);
}

test "scrollable page also culls fully occluded lower sibling subtree" {
