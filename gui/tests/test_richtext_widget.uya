export const TEST_RICHTEXT_WIDGET_MODULE: i32 = 1;

struct RichTextInputValueRecorder : IWidgetValueCallback {
    value_ref: &i32,
}

RichTextInputValueRecorder {
    fn invoke(self: &Self, widget: &Widget, value: i32, user_data: &void) void {
        _ = widget;
        _ = user_data;
        self.value_ref[0] = value;
    }
}

test "rich text input plain text delta html and on_change work" {
    var input: RichTextInput = RichTextInput.new("Type here");
    defer input.dispose();

    var last_value: i32 = -1;
    var recorder: RichTextInputValueRecorder = RichTextInputValueRecorder{ value_ref: &last_value };
    var callback: IWidgetValueCallback = recorder;
    input.on_change(&callback, null);

    try input.set_plain_text("Hello\nworld" as &const byte);

    var plain: [byte: 32] = [];
    const plain_written: usize = input.plain_text(&plain[0], 32usize);
    try assert_eq_i32(plain_written as i32, 11);
    try assert_eq_bool(strncmp(&plain[0] as *const byte, "Hello\nworld" as *const byte, 11usize) == 0, true);
    try assert_eq_i32(last_value, 11);

    var delta: RichDelta = rich_delta_new();
    defer delta.dispose();
    try input.export_delta(&delta);
    try assert_eq_bool(delta.op_count >= 2u32, true);
    try assert_eq_bool(delta.ops[0].kind == RichOpKind.InsertText, true);

    var clone: RichTextInput = RichTextInput.new("" as &const byte);
    defer clone.dispose();
    try clone.set_delta(&delta);
    var clone_plain: [byte: 32] = [];
    const clone_written: usize = clone.plain_text(&clone_plain[0], 32usize);
    try assert_eq_i32(clone_written as i32, 11);
    try assert_eq_bool(strncmp(&clone_plain[0] as *const byte, "Hello\nworld" as *const byte, 11usize) == 0, true);

    var html: [byte: 128] = [];
    const html_written: usize = input.export_html(&html[0], 128usize);
    try assert_eq_i32(html_written as i32, 24);
    try assert_eq_bool(strncmp(&html[0] as *const byte, "<p>Hello</p><p>world</p>" as *const byte, 24usize) == 0, true);
}

test "rich text input export_html only emits whitelisted links" {
    var input: RichTextInput = RichTextInput.new("" as &const byte);
    defer input.dispose();

    try input.set_plain_text("safe\nunsafe" as &const byte);
    try assert_eq_bool(try input.doc.set_span_link(0u32, 0u16, "https://example.com?q=1&v=2" as &const byte, 27usize), true);
    try assert_eq_bool(try input.doc.set_span_link(1u32, 0u16, "javascript:alert(1)" as &const byte, 19usize), true);

    var delta: RichDelta = rich_delta_new();
    defer delta.dispose();
    try input.export_delta(&delta);

    var clone: RichTextInput = RichTextInput.new("" as &const byte);
    defer clone.dispose();
    try clone.set_delta(&delta);

    const expected_html: &const byte =
        "<p><a href=\"https://example.com?q=1&amp;v=2\">safe</a></p><p>unsafe</p>" as &const byte;
    const expected_len: usize = widget_text_len(expected_html);
    var html: [byte: 192] = [];
    const html_written: usize = clone.export_html(&html[0], 192usize);
    try assert_eq_i32(html_written as i32, expected_len as i32);
    try assert_eq_bool(strncmp(&html[0] as *const byte, expected_html as *const byte, expected_len) == 0, true);
}

test "rich text input handles text events undo redo and drag selection" {
    var input: RichTextInput = RichTextInput.new("" as &const byte);
    defer input.dispose();
    input.widget.at(0, 0);
    input.widget.size(180, 72);

    var focus_evt: Event = event_point(EventType.FocusIn, InputDev.Keypad, 1, 1u32, Point{ x: 0, y: 0 });
    var text_evt: Event = event_text_input(InputDev.Text, 1, 2u32, "ab" as &const byte, 2usize);
    var enter_evt: Event = event_key(EventType.KeyDown, InputDev.Keypad, 1, 3u32, 13u16);
    var line_evt: Event = event_text_input(InputDev.Text, 1, 4u32, "cd" as &const byte, 2usize);

    try assert_eq_bool(input.handle_event(&focus_evt), true);
    try assert_eq_bool(input.handle_event(&text_evt), true);
    try assert_eq_bool(input.handle_event(&enter_evt), true);
    try assert_eq_bool(input.handle_event(&line_evt), true);

    var out: [byte: 32] = [];
    const written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(written as i32, 5);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "ab\ncd" as *const byte, 5usize) == 0, true);

    try assert_eq_bool(input.exec(RichCommand{
        kind: RichCommandKind.Undo,
        text_ptr: null,
        text_len: 0usize,
    }), true);
    const undone_written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(undone_written as i32, 3);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "ab\n" as *const byte, 3usize) == 0, true);

    try assert_eq_bool(input.exec(RichCommand{
        kind: RichCommandKind.Redo,
        text_ptr: null,
        text_len: 0usize,
    }), true);
    const redone_written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(redone_written as i32, 5);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "ab\ncd" as *const byte, 5usize) == 0, true);

    try input.set_plain_text("alpha beta\ngamma" as &const byte);

    var bytes: [byte: 32768] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 128, 64, 512, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    input.render(&ctx);

    const inner: Rect = widget_inner_rect(&input.widget);
    const font: &Font = widget_font(&input.widget.base.style);
    try assert_eq_i32(input.layout.line_count as i32, 2);

    var press_evt: Event = event_point(
        EventType.Press,
        InputDev.Touch,
        1,
        10u32,
        Point{
            x: inner.x + input.layout.lines[0].x + text_width("a" as &const byte, 1usize, font) + 2i16,
            y: inner.y + input.layout.lines[0].y + 1i16,
        },
    );
    var drag_evt: Event = event_point(
        EventType.Drag,
        InputDev.Touch,
        1,
        11u32,
        Point{
            x: inner.x + input.layout.lines[1].x + text_width("ga" as &const byte, 2usize, font) + 2i16,
            y: inner.y + input.layout.lines[1].y + 1i16,
        },
    );
    var release_evt: Event = event_point(EventType.Release, InputDev.Touch, 1, 12u32, Point{ x: 0, y: 0 });

    try assert_eq_bool(input.handle_event(&press_evt), true);
    try assert_eq_bool(input.handle_event(&drag_evt), true);
    try assert_eq_bool(input.handle_event(&release_evt), true);
    try assert_eq_i32((try input.doc.pos_to_linear_offset(input.selection().anchor)) as i32, 2);
    try assert_eq_i32((try input.doc.pos_to_linear_offset(input.selection().focus)) as i32, 13);
}

test "rich text input paste plain normalizes newlines and tabs" {
    var input: RichTextInput = RichTextInput.new("" as &const byte);
    defer input.dispose();
    try input.set_plain_text("" as &const byte);

    try assert_eq_bool(input.exec(RichCommand{
        kind: RichCommandKind.PastePlain,
        text_ptr: "A\tB\r\nC" as &const byte,
        text_len: 6usize,
    }), true);

    var out: [byte: 32] = [];
    const written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(written as i32, 8);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "A    B\nC" as *const byte, 8usize) == 0, true);
}

test "rich text input consumes host bridge paste and cut commands" {
    var input: RichTextInput = RichTextInput.new("" as &const byte);
    defer input.dispose();
    input.widget.at(0, 0);
    input.widget.size(140, 48);

    var focus_evt: Event = event_point(EventType.FocusIn, InputDev.Keypad, 1, 1u32, Point{ x: 0, y: 0 });
    try assert_eq_bool(input.handle_event(&focus_evt), true);

    var bytes: [byte: 16384] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 64, 64, 256, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    input.render(&ctx);

    try assert_eq_i32(rich_text_host_active_session() as i32, input.session_id as i32);
    try assert_eq_bool(rich_text_host_feed_text_command(RICH_TEXT_HOST_CMD_PASTE_TEXT, "A\tB" as &const byte, 3usize), true);
    input.render(&ctx);

    var out: [byte: 32] = [];
    const pasted_written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(pasted_written as i32, 6);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "A    B" as *const byte, 6usize) == 0, true);

    input.selection_range = RichRange{
        anchor: try input.doc.linear_offset_to_pos(1u32),
        focus: try input.doc.linear_offset_to_pos(6u32),
    };
    input.render(&ctx);
    try assert_eq_bool(rich_text_host_feed_command(RICH_TEXT_HOST_CMD_CUT), true);
    input.render(&ctx);

    const cut_written: usize = input.plain_text(&out[0], 32usize);
    try assert_eq_i32(cut_written as i32, 1);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "A" as *const byte, 1usize) == 0, true);
}

test "rich text input host bridge keeps long paste and composition lifecycle intact" {
    var input: RichTextInput = RichTextInput.new("" as &const byte);
    defer input.dispose();
    input.widget.at(0, 0);
    input.widget.size(140, 48);

    var focus_evt: Event = event_point(EventType.FocusIn, InputDev.Keypad, 1, 1u32, Point{ x: 0, y: 0 });
    try assert_eq_bool(input.handle_event(&focus_evt), true);

    var bytes: [byte: 16384] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 64, 64, 256, PixelFormat.ARGB8888));
    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    input.render(&ctx);

    var long_text: [byte: 121] = [];
    var idx: usize = 0usize;
    while idx < 120usize {
        long_text[idx] = 'x' as byte;
        idx = idx + 1usize;
    }
    long_text[120] = 0u8;
    try assert_eq_bool(rich_text_host_feed_text_command(RICH_TEXT_HOST_CMD_PASTE_TEXT, &long_text[0], 120usize), true);
    input.render(&ctx);

    var out: [byte: 160] = [];
    const long_written: usize = input.plain_text(&out[0], 160usize);
    try assert_eq_i32(long_written as i32, 120);

    try input.set_plain_text("" as &const byte);
    input.render(&ctx);
    try assert_eq_bool(rich_text_host_feed_command(RICH_TEXT_HOST_CMD_COMPOSITION_START), true);
    try assert_eq_bool(rich_text_host_feed_text_command(RICH_TEXT_HOST_CMD_COMPOSITION_UPDATE, "中" as &const byte, 3usize), true);
    input.render(&ctx);
    const preedit_written: usize = input.plain_text(&out[0], 160usize);
    try assert_eq_i32(preedit_written as i32, 0);

    try assert_eq_bool(rich_text_host_feed_text_command(RICH_TEXT_HOST_CMD_COMPOSITION_END, "中" as &const byte, 3usize), true);
    input.render(&ctx);
    const committed_written: usize = input.plain_text(&out[0], 160usize);
    try assert_eq_i32(committed_written as i32, 3);
    try assert_eq_bool(strncmp(&out[0] as *const byte, "中" as *const byte, 3usize) == 0, true);
}

test "rich text input scrolls caret into view and renders inside panel and page" {
    var scrolling: RichTextInput = RichTextInput.new("" as &const byte);
    defer scrolling.dispose();
    scrolling.widget.at(0, 0);
    scrolling.widget.size(90, 28);
    try scrolling.set_plain_text("one\ntwo\nthree\nfour" as &const byte);
    try assert_eq_bool(scrolling.scroll_y > 0, true);

    var panel_bytes: [byte: 16384] = [];
    var panel_ctx: RenderCtx = render_ctx_new(framebuffer_new(&panel_bytes[0], 64, 64, 256, PixelFormat.ARGB8888));
    panel_ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var panel: Panel = Panel.new();
    panel.widget.at(0, 0);
    panel.widget.size(64, 40);
    panel.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    panel.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
    var panel_input: RichTextInput = RichTextInput.new("" as &const byte);
    defer panel_input.dispose();
    panel_input.widget.at(0, 0);
    panel_input.widget.size(40, 24);
    try panel_input.set_plain_text("I" as &const byte);
    _ = panel.add(panel_input.obj());
    panel.render(&panel_ctx);
    const panel_inner: Rect = widget_inner_rect(&panel_input.widget);
    try assert_eq_bool(ctx_pixel(&panel_ctx, panel_inner.x + 2i16, panel_inner.y + 3i16) == Color{ r: 15, g: 23, b: 42, a: 255 }, true);

    var page_bytes: [byte: 16384] = [];
    var page_ctx: RenderCtx = render_ctx_new(framebuffer_new(&page_bytes[0], 64, 64, 256, PixelFormat.ARGB8888));
    page_ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });

    var page: Page = Page.new("RichPage" as &const byte);
    page.widget.at(0, 0);
    page.widget.size(64, 40);
    page.widget.base.style.set_u32(StyleProp.PaddingLeft, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingRight, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingTop, 0u32);
    page.widget.base.style.set_u32(StyleProp.PaddingBottom, 0u32);
    var page_input: RichTextInput = RichTextInput.new("" as &const byte);
    defer page_input.dispose();
    page_input.widget.at(0, 0);
    page_input.widget.size(40, 24);
    try page_input.set_plain_text("I" as &const byte);
    _ = page.add(page_input.obj());
    page.render(&page_ctx);
    const page_inner: Rect = widget_inner_rect(&page_input.widget);
    try assert_eq_bool(ctx_pixel(&page_ctx, page_inner.x + 2i16, page_inner.y + 3i16) == Color{ r: 15, g: 23, b: 42, a: 255 }, true);
}
