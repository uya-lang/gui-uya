use examples.doudizhu.ai.DdzAiStatus;
use examples.doudizhu.ai.DdzAiDecision;
use examples.doudizhu.ai.DdzAiSource;
use examples.doudizhu.ai.DdzAiState;
use examples.doudizhu.ai.ddz_ai_bid_score;
use examples.doudizhu.ai.ddz_ai_choose_action;
use examples.doudizhu.ai.ddz_ai_state_new;
use examples.doudizhu.rules.DdzAction;
use examples.doudizhu.rules.DdzActionKind;
use examples.doudizhu.rules.DDZ_NO_PLAYER;
use examples.doudizhu.rules.DdzCard;
use examples.doudizhu.rules.DdzCombo;
use examples.doudizhu.rules.DdzComboKind;
use examples.doudizhu.rules.DdzGamePhase;
use examples.doudizhu.rules.DdzGameState;
use examples.doudizhu.rules.ddz_combo_detect;
use examples.doudizhu.rules.ddz_game_apply_action;
use examples.doudizhu.rules.ddz_game_new;
use examples.doudizhu.rules.ddz_game_restart;
use examples.doudizhu.rules.ddz_hand_recount;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_DOUDIZHU_AI_MODULE: i32 = 1;

fn ddz_ai_test_game() DdzGameState {
    var game: DdzGameState = ddz_game_new();
    game.phase = DdzGamePhase.Playing;
    game.landlord = 0;
    game.current_player = 0;
    game.players[1].count = 6;
    game.players[2].count = 6;
    game.last_combo = DdzCombo{ kind: DdzComboKind.Invalid, main_rank: -1, card_count: 0, kick_rank: -1, chain_len: 0, ranks: [], rank_count: 0 };
    game.last_combo_player = DDZ_NO_PLAYER;
    return game;
}

test "doudizhu ai strong hand bids high and weak hand stays low" {
    var strong: DdzGameState = ddz_game_new();
    strong.players[0].count = 8;
    strong.players[0].cards[0] = DdzCard{ id: 1, rank: 12, suit: 0 };
    strong.players[0].cards[1] = DdzCard{ id: 2, rank: 12, suit: 1 };
    strong.players[0].cards[2] = DdzCard{ id: 3, rank: 12, suit: 2 };
    strong.players[0].cards[3] = DdzCard{ id: 4, rank: 13, suit: 4 };
    strong.players[0].cards[4] = DdzCard{ id: 5, rank: 14, suit: 4 };
    strong.players[0].cards[5] = DdzCard{ id: 6, rank: 11, suit: 0 };
    strong.players[0].cards[6] = DdzCard{ id: 7, rank: 11, suit: 1 };
    strong.players[0].cards[7] = DdzCard{ id: 8, rank: 11, suit: 2 };
    ddz_hand_recount(&strong.players[0]);
    const strong_ok: bool = ddz_ai_bid_score(&strong.players[0]) >= 2;
    try assert_eq_bool(strong_ok, true);

    var weak: DdzGameState = ddz_game_new();
    weak.players[0].count = 5;
    weak.players[0].cards[0] = DdzCard{ id: 21, rank: 0, suit: 0 };
    weak.players[0].cards[1] = DdzCard{ id: 22, rank: 2, suit: 0 };
    weak.players[0].cards[2] = DdzCard{ id: 23, rank: 4, suit: 0 };
    weak.players[0].cards[3] = DdzCard{ id: 24, rank: 6, suit: 0 };
    weak.players[0].cards[4] = DdzCard{ id: 25, rank: 8, suit: 0 };
    ddz_hand_recount(&weak.players[0]);
    const weak_ok: bool = ddz_ai_bid_score(&weak.players[0]) <= 1;
    try assert_eq_bool(weak_ok, true);
}

test "doudizhu ai leads smallest normal action" {
    var game: DdzGameState = ddz_ai_test_game();
    game.players[0].count = 3;
    game.players[0].cards[0] = DdzCard{ id: 31, rank: 0, suit: 0 };
    game.players[0].cards[1] = DdzCard{ id: 32, rank: 3, suit: 0 };
    game.players[0].cards[2] = DdzCard{ id: 33, rank: 8, suit: 0 };
    ddz_hand_recount(&game.players[0]);
    var ai: DdzAiState = ddz_ai_state_new();
    const decision: DdzAiDecision = ddz_ai_choose_action(&ai, &game, 0);
    try assert_eq_i32(decision.status as i32, DdzAiStatus.Ok as i32);
    try assert_eq_i32(decision.action.combo.kind as i32, DdzComboKind.Single as i32);
    try assert_eq_i32(decision.action.combo.main_rank, 0);
}

test "doudizhu ai follows with smallest beating action and avoids bomb early" {
    var game: DdzGameState = ddz_ai_test_game();
    game.players[0].count = 6;
    game.players[0].cards[0] = DdzCard{ id: 41, rank: 4, suit: 0 };
    game.players[0].cards[1] = DdzCard{ id: 42, rank: 5, suit: 0 };
    game.players[0].cards[2] = DdzCard{ id: 43, rank: 9, suit: 0 };
    game.players[0].cards[3] = DdzCard{ id: 44, rank: 9, suit: 1 };
    game.players[0].cards[4] = DdzCard{ id: 45, rank: 9, suit: 2 };
    game.players[0].cards[5] = DdzCard{ id: 46, rank: 9, suit: 3 };
    ddz_hand_recount(&game.players[0]);
    var ranks: [i32: 20] = [];
    ranks[0] = 3;
    game.last_combo = ddz_combo_detect(&ranks[0], 1);
    game.last_combo_player = 1;
    var ai: DdzAiState = ddz_ai_state_new();
    const decision: DdzAiDecision = ddz_ai_choose_action(&ai, &game, 0);
    try assert_eq_i32(decision.status as i32, DdzAiStatus.Ok as i32);
    try assert_eq_i32(decision.action.combo.kind as i32, DdzComboKind.Single as i32);
    try assert_eq_i32(decision.action.combo.main_rank, 4);
}

test "doudizhu ai spends bomb when it can nearly finish" {
    var game: DdzGameState = ddz_ai_test_game();
    game.players[0].count = 4;
    game.players[0].cards[0] = DdzCard{ id: 51, rank: 6, suit: 0 };
    game.players[0].cards[1] = DdzCard{ id: 52, rank: 6, suit: 1 };
    game.players[0].cards[2] = DdzCard{ id: 53, rank: 6, suit: 2 };
    game.players[0].cards[3] = DdzCard{ id: 54, rank: 6, suit: 3 };
    ddz_hand_recount(&game.players[0]);
    var last_ranks: [i32: 20] = [];
    last_ranks[0] = 5;
    last_ranks[1] = 5;
    last_ranks[2] = 5;
    last_ranks[3] = 5;
    game.last_combo = ddz_combo_detect(&last_ranks[0], 4);
    game.last_combo_player = 1;
    var ai: DdzAiState = ddz_ai_state_new();
    const decision: DdzAiDecision = ddz_ai_choose_action(&ai, &game, 0);
    try assert_eq_i32(decision.status as i32, DdzAiStatus.Ok as i32);
    try assert_eq_i32(decision.action.combo.kind as i32, DdzComboKind.Bomb as i32);
    try assert_eq_i32(decision.action.combo.main_rank, 6);
}

test "doudizhu ai self play reaches game over across seeds" {
    var seeds: [u32: 6] = [7u32, 19u32, 101u32, 20260517u32, 20260518u32, 20260519u32];
    var si: i32 = 0;
    while si < 6 {
        var game: DdzGameState = ddz_game_new();
        try assert_eq_bool(ddz_game_restart(&game, seeds[si as usize]), true);
        var ai0: DdzAiState = ddz_ai_state_new();
        var ai1: DdzAiState = ddz_ai_state_new();
        var ai2: DdzAiState = ddz_ai_state_new();
        var guard: i32 = 0;
        while guard < 2048 && game.phase != DdzGamePhase.GameOver {
            var decision: DdzAiDecision = DdzAiDecision{
                status: DdzAiStatus.NoLegalActions,
                source: 0 as DdzAiSource,
                action_index: -1,
                action: DdzAction{
                    kind: 0 as DdzActionKind,
                    bid: 0,
                    combo: DdzCombo{ kind: DdzComboKind.Invalid, main_rank: -1, card_count: 0, kick_rank: -1, chain_len: 0, ranks: [], rank_count: 0 },
                    card_ids: [],
                    card_count: 0,
                    label: [],
                },
            };
            if game.current_player == 0 {
                decision = ddz_ai_choose_action(&ai0, &game, 0);
            } else if game.current_player == 1 {
                decision = ddz_ai_choose_action(&ai1, &game, 1);
            } else {
                decision = ddz_ai_choose_action(&ai2, &game, 2);
            }
            try assert_eq_i32(decision.status as i32, DdzAiStatus.Ok as i32);
            try assert_eq_bool(ddz_game_apply_action(&game, game.current_player, &decision.action), true);
            guard = guard + 1;
        }
        try assert_eq_i32(game.phase as i32, DdzGamePhase.GameOver as i32);
        si = si + 1;
    }
}
