use core.event.Event;
use core.event.EventOption;
use core.event.EventPhase;
use core.event.EventQueue;
use core.event.EventType;
use core.event.EVENT_QUEUE_SIZE;
use core.event.GestureDetector;
use core.event.GestureConfig;
use core.event.InputDev;
use core.event.event_none;
use core.event.event_focus;
use core.event.event_key;
use core.event.event_point;
use core.event.event_queue_new;
use core.event.event_value;
use core.event.event_with_phase;
use core.event.gesture_config_default;
use core.event.gesture_detector_new;
use core.event.gesture_detector_with_config;
use core.point.POINT_ZERO;
use core.point.Point;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.expect;

export const TEST_EVENT_MODULE: i32 = 1;

struct SwipeCase {
    start: Point,
    end: Point,
    expected: EventType,
}

fn unwrap_event(opt: EventOption) !Event {
    if !opt.has_value {
        return error.AssertionFailed;
    }
    return opt.value;
}

test "event queue push pop order" {
    var queue: EventQueue = event_queue_new();

    try assert_eq_bool(queue.is_empty(), true);
    try assert_eq_bool(queue.push(event_point(EventType.Press, InputDev.Touch, 1, 10, Point{ x: 1, y: 2 })), true);
    try assert_eq_bool(queue.push(event_point(EventType.Release, InputDev.Touch, 1, 20, Point{ x: 3, y: 4 })), true);
    try assert_eq_i32(queue.len(), 2);

    const first: Event = try unwrap_event(queue.pop());
    const second: Event = try unwrap_event(queue.pop());

    try expect(first.event_type == EventType.Press);
    try expect(second.event_type == EventType.Release);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector click sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 10, y: 10 }, true, 100, 7, &queue);
    detector.process_touch(Point{ x: 12, y: 12 }, false, 180, 7, &queue);

    const press_evt: Event = try unwrap_event(queue.pop());
    const release_evt: Event = try unwrap_event(queue.pop());
    const click_evt: Event = try unwrap_event(queue.pop());

    try expect(press_evt.event_type == EventType.Press);
    try expect(release_evt.event_type == EventType.Release);
    try expect(click_evt.event_type == EventType.Click);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector swipe sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();
    var evt: Event = event_none();

    detector.process_touch(Point{ x: 0, y: 0 }, true, 100, 3, &queue);
    detector.process_touch(Point{ x: 30, y: 0 }, false, 200, 3, &queue);

    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Press);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Release);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.SwipeRight);
}

test "gesture detector long press sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 8, y: 9 }, true, 100, 5, &queue);
    detector.process_touch(Point{ x: 8, y: 9 }, true, 950, 5, &queue);
    detector.process_touch(Point{ x: 8, y: 9 }, false, 980, 5, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Press);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.LongPress);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Release);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector drag sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 0, y: 0 }, true, 100, 9, &queue);
    detector.process_touch(Point{ x: 20, y: 0 }, true, 120, 9, &queue);
    detector.process_touch(Point{ x: 30, y: 5 }, true, 140, 9, &queue);
    detector.process_touch(Point{ x: 30, y: 5 }, false, 170, 9, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Press);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.DragStart);
    try assert_eq_i32(evt.point().x as i32, 0);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Drag);
    try assert_eq_i32(evt.point().x as i32, 20);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Drag);
    try assert_eq_i32(evt.point().x as i32, 30);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Release);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.DragEnd);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector double click sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 12, y: 16 }, true, 100, 11, &queue);
    detector.process_touch(Point{ x: 12, y: 16 }, false, 150, 11, &queue);
    detector.process_touch(Point{ x: 13, y: 15 }, true, 260, 11, &queue);
    detector.process_touch(Point{ x: 13, y: 15 }, false, 300, 11, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Press);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Release);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Click);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Press);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Release);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.DoubleClick);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector pinch sequence" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 10, y: 0 }, true, 100, 13, &queue);
    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 30, y: 0 }, true, 150, 13, &queue);
    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 30, y: 0 }, false, 180, 13, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.PinchStart);
    try assert_eq_i32(evt.point().x as i32, 5);
    try assert_eq_i32(evt.value(), 100);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.Pinch);
    try assert_eq_i32(evt.point().x as i32, 15);
    try assert_eq_i32(evt.value(), 900);
    evt = try unwrap_event(queue.pop());
    try expect(evt.event_type == EventType.PinchEnd);
    try assert_eq_i32(evt.value(), 900);
    try assert_eq_bool(queue.is_empty(), true);
}

test "event carries point payload" {
    const evt: Event = event_point(EventType.Press, InputDev.Touch, 2, 42, Point{ x: 9, y: 11 });
    try assert_eq_i32(evt.point().x as i32, 9);
    try assert_eq_i32(evt.point().y as i32, 11);
}

test "event queue fills overflows and wraps after partial drain" {
    var queue: EventQueue = event_queue_new();
    var i: i32 = 0;
    while i < EVENT_QUEUE_SIZE {
        try assert_eq_bool(queue.push(event_value(EventType.ValueChange, InputDev.Encoder, 4, (i as! u32).value, i)), true);
        i = i + 1;
    }

    try assert_eq_bool(queue.is_full(), true);
    try assert_eq_bool(queue.push(event_value(EventType.ValueChange, InputDev.Encoder, 4, 999u32, 999)), false);
    try assert_eq_i32(queue.overflow as i32, 1);

    i = 0;
    while i < 16 {
        const evt: Event = try unwrap_event(queue.pop());
        try assert_eq_i32(evt.value(), i);
        i = i + 1;
    }

    i = 0;
    while i < 16 {
        const next_value: i32 = 64 + i;
        try assert_eq_bool(queue.push(event_value(EventType.ValueChange, InputDev.Encoder, 4, (next_value as! u32).value, next_value)), true);
        i = i + 1;
    }

    i = 16;
    while i < 80 {
        const evt: Event = try unwrap_event(queue.pop());
        try assert_eq_i32(evt.value(), i);
        i = i + 1;
    }
    try assert_eq_bool(queue.is_empty(), true);
}

test "event helper payloads expose key value focus and phase fields" {
    const key_evt: Event = event_key(EventType.KeyDown, InputDev.Keypad, 7, 11u32, 66u16);
    const value_evt: Event = event_value(EventType.ValueChange, InputDev.Encoder, 8, 12u32, -3);
    const focus_evt: Event = event_focus(EventType.FocusIn, 9, 13u32);
    const bubbled: Event = event_with_phase(key_evt, EventPhase.Bubble);
    const none_evt: Event = event_none();

    try assert_eq_i32(key_evt.key_code() as i32, 66);
    try assert_eq_i32(value_evt.value(), -3);
    try assert_eq_bool(focus_evt.dev_type == InputDev.Keypad, true);
    try assert_eq_bool(focus_evt.event_type == EventType.FocusIn, true);
    try assert_eq_bool(bubbled.phase == EventPhase.Bubble, true);
    try assert_eq_bool(none_evt.point() == POINT_ZERO, true);
}

test "gesture detector swipe direction matrix covers all four directions" {
    var cases: [SwipeCase: 4] = [
        SwipeCase{ start: Point{ x: 0, y: 0 }, end: Point{ x: 40, y: 0 }, expected: EventType.SwipeRight },
        SwipeCase{ start: Point{ x: 40, y: 0 }, end: Point{ x: 0, y: 0 }, expected: EventType.SwipeLeft },
        SwipeCase{ start: Point{ x: 0, y: 40 }, end: Point{ x: 0, y: 0 }, expected: EventType.SwipeUp },
        SwipeCase{ start: Point{ x: 0, y: 0 }, end: Point{ x: 0, y: 40 }, expected: EventType.SwipeDown },
    ];

    var i: i32 = 0;
    while i < 4 {
        var detector: GestureDetector = gesture_detector_new();
        var queue: EventQueue = event_queue_new();
        detector.process_touch(cases[i].start, true, 100u32, i, &queue);
        detector.process_touch(cases[i].end, false, 180u32, i, &queue);

        var evt: Event = try unwrap_event(queue.pop());
        try assert_eq_bool(evt.event_type == EventType.Press, true);
        evt = try unwrap_event(queue.pop());
        try assert_eq_bool(evt.event_type == EventType.Release, true);
        evt = try unwrap_event(queue.pop());
        try assert_eq_bool(evt.event_type == cases[i].expected, true);
        try assert_eq_bool(queue.is_empty(), true);
        i = i + 1;
    }
}

test "gesture detector long press fires once and suppresses click" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 5, y: 5 }, true, 100u32, 21, &queue);
    detector.process_touch(Point{ x: 5, y: 5 }, true, 950u32, 21, &queue);
    detector.process_touch(Point{ x: 5, y: 5 }, true, 1200u32, 21, &queue);
    detector.process_touch(Point{ x: 5, y: 5 }, false, 1250u32, 21, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.Press, true);
    evt = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.LongPress, true);
    evt = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.Release, true);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector respects click duration threshold" {
    var detector: GestureDetector = gesture_detector_new();
    var queue: EventQueue = event_queue_new();

    detector.process_touch(Point{ x: 6, y: 6 }, true, 100u32, 22, &queue);
    detector.process_touch(Point{ x: 6, y: 6 }, false, 700u32, 22, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.Press, true);
    evt = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.Release, true);
    try assert_eq_bool(queue.is_empty(), true);
}

test "gesture detector pinch threshold waits for significant delta" {
    var cfg: GestureConfig = gesture_config_default();
    cfg.pinch_threshold = 16u16;
    var detector: GestureDetector = gesture_detector_with_config(cfg);
    var queue: EventQueue = event_queue_new();

    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 10, y: 0 }, true, 100u32, 31, &queue);
    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 12, y: 0 }, true, 120u32, 31, &queue);
    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 30, y: 0 }, true, 140u32, 31, &queue);
    detector.process_pinch(Point{ x: 0, y: 0 }, Point{ x: 30, y: 0 }, false, 160u32, 31, &queue);

    var evt: Event = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.PinchStart, true);
    evt = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.Pinch, true);
    try assert_eq_i32(evt.value(), 900);
    evt = try unwrap_event(queue.pop());
    try assert_eq_bool(evt.event_type == EventType.PinchEnd, true);
    try assert_eq_i32(evt.value(), 900);
    try assert_eq_bool(queue.is_empty(), true);
}
