use examples.doudizhu.rules.DDZ_DECK_COUNT;
use examples.doudizhu.rules.DDZ_MAX_HISTORY;
use examples.doudizhu.rules.DDZ_NO_PLAYER;
use examples.doudizhu.rules.DDZ_PLAYER_COUNT;
use examples.doudizhu.rules.DdzAction;
use examples.doudizhu.rules.DdzActionKind;
use examples.doudizhu.rules.DdzActionList;
use examples.doudizhu.rules.DdzCard;
use examples.doudizhu.rules.DdzCombo;
use examples.doudizhu.rules.DdzComboKind;
use examples.doudizhu.rules.DdzGamePhase;
use examples.doudizhu.rules.DdzGameState;
use examples.doudizhu.rules.ddz_action_list_new;
use examples.doudizhu.rules.ddz_combo_can_beat;
use examples.doudizhu.rules.ddz_combo_detect;
use examples.doudizhu.rules.ddz_game_apply_action;
use examples.doudizhu.rules.ddz_game_new;
use examples.doudizhu.rules.ddz_game_restart;
use examples.doudizhu.rules.ddz_generate_play_actions;
use examples.doudizhu.rules.ddz_hand_recount;
use examples.doudizhu.rules.ddz_hand_sort;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_DOUDIZHU_RULES_MODULE: i32 = 1;

fn ddz_test_new_game() DdzGameState {
    var game: DdzGameState = ddz_game_new();
    _ = ddz_game_restart(&game, 123u32);
    return game;
}

test "doudizhu deck unique and deal counts stable" {
    var game: DdzGameState = ddz_test_new_game();
    var seen: [i32: 54] = [];
    var i: i32 = 0;
    while i < DDZ_DECK_COUNT {
        const id: i32 = game.deck[i as usize].id;
        const id_ok: bool = id >= 0 && id < DDZ_DECK_COUNT;
        try assert_eq_bool(id_ok, true);
        if id >= 0 {
            if id < DDZ_DECK_COUNT {
            seen[id as usize] = seen[id as usize] + 1;
            }
        }
        i = i + 1;
    }
    i = 0;
    while i < DDZ_DECK_COUNT {
        try assert_eq_i32(seen[i as usize], 1);
        i = i + 1;
    }
    try assert_eq_i32(game.players[0].count, 17);
    try assert_eq_i32(game.players[1].count, 17);
    try assert_eq_i32(game.players[2].count, 17);
}

test "doudizhu hand recount detects duplicates per rank" {
    var game: DdzGameState = ddz_game_new();
    game.players[0].count = 5;
    game.players[0].cards[0] = DdzCard{ id: 1, rank: 0, suit: 0 };
    game.players[0].cards[1] = DdzCard{ id: 2, rank: 0, suit: 1 };
    game.players[0].cards[2] = DdzCard{ id: 3, rank: 2, suit: 0 };
    game.players[0].cards[3] = DdzCard{ id: 4, rank: 12, suit: 2 };
    game.players[0].cards[4] = DdzCard{ id: 5, rank: 12, suit: 3 };
    ddz_hand_sort(&game.players[0]);
    ddz_hand_recount(&game.players[0]);
    try assert_eq_i32(game.players[0].rank_counts[0], 2);
    try assert_eq_i32(game.players[0].rank_counts[2], 1);
    try assert_eq_i32(game.players[0].rank_counts[12], 2);
}

test "doudizhu combo detect covers core mvp combos" {
    var single: [i32: 20] = [];
    var pair: [i32: 20] = [];
    var triple: [i32: 20] = [];
    var triple_single: [i32: 20] = [];
    var triple_pair: [i32: 20] = [];
    var straight: [i32: 20] = [];
    var pair_chain: [i32: 20] = [];
    var bomb: [i32: 20] = [];
    var rocket: [i32: 20] = [];
    single[0] = 4;
    pair[0] = 5; pair[1] = 5;
    triple[0] = 6; triple[1] = 6; triple[2] = 6;
    triple_single[0] = 6; triple_single[1] = 6; triple_single[2] = 6; triple_single[3] = 9;
    triple_pair[0] = 6; triple_pair[1] = 6; triple_pair[2] = 6; triple_pair[3] = 9; triple_pair[4] = 9;
    straight[0] = 0; straight[1] = 1; straight[2] = 2; straight[3] = 3; straight[4] = 4;
    pair_chain[0] = 0; pair_chain[1] = 0; pair_chain[2] = 1; pair_chain[3] = 1; pair_chain[4] = 2; pair_chain[5] = 2;
    bomb[0] = 8; bomb[1] = 8; bomb[2] = 8; bomb[3] = 8;
    rocket[0] = 13; rocket[1] = 14;
    try assert_eq_i32(ddz_combo_detect(&single[0], 1).kind as i32, DdzComboKind.Single as i32);
    try assert_eq_i32(ddz_combo_detect(&pair[0], 2).kind as i32, DdzComboKind.Pair as i32);
    try assert_eq_i32(ddz_combo_detect(&triple[0], 3).kind as i32, DdzComboKind.Triple as i32);
    try assert_eq_i32(ddz_combo_detect(&triple_single[0], 4).kind as i32, DdzComboKind.TripleSingle as i32);
    try assert_eq_i32(ddz_combo_detect(&triple_pair[0], 5).kind as i32, DdzComboKind.TriplePair as i32);
    try assert_eq_i32(ddz_combo_detect(&straight[0], 5).kind as i32, DdzComboKind.Straight as i32);
    try assert_eq_i32(ddz_combo_detect(&pair_chain[0], 6).kind as i32, DdzComboKind.StraightPairs as i32);
    try assert_eq_i32(ddz_combo_detect(&bomb[0], 4).kind as i32, DdzComboKind.Bomb as i32);
    try assert_eq_i32(ddz_combo_detect(&rocket[0], 2).kind as i32, DdzComboKind.Rocket as i32);
}

test "doudizhu combo rejects invalid straight and pair chain" {
    var bad_straight: [i32: 20] = [];
    var bad_pairs: [i32: 20] = [];
    bad_straight[0] = 8; bad_straight[1] = 9; bad_straight[2] = 10; bad_straight[3] = 11; bad_straight[4] = 12;
    bad_pairs[0] = 0; bad_pairs[1] = 0; bad_pairs[2] = 1; bad_pairs[3] = 1; bad_pairs[4] = 12; bad_pairs[5] = 12;
    try assert_eq_i32(ddz_combo_detect(&bad_straight[0], 5).kind as i32, DdzComboKind.Invalid as i32);
    try assert_eq_i32(ddz_combo_detect(&bad_pairs[0], 6).kind as i32, DdzComboKind.Invalid as i32);
}

test "doudizhu bombs and rocket compare correctly" {
    var a: [i32: 20] = [];
    var b: [i32: 20] = [];
    var rocket: [i32: 20] = [];
    a[0] = 8; a[1] = 8; a[2] = 8; a[3] = 8;
    b[0] = 7; b[1] = 7; b[2] = 7; b[3] = 7;
    rocket[0] = 13; rocket[1] = 14;
    try assert_eq_bool(ddz_combo_can_beat(ddz_combo_detect(&a[0], 4), ddz_combo_detect(&b[0], 4)), true);
    try assert_eq_bool(ddz_combo_can_beat(ddz_combo_detect(&rocket[0], 2), ddz_combo_detect(&a[0], 4)), true);
}

test "doudizhu apply action updates hand turn and game over" {
    var game: DdzGameState = ddz_game_new();
    game.phase = DdzGamePhase.Playing;
    game.current_player = 0;
    game.landlord = 0;
    game.last_combo = DdzCombo{ kind: DdzComboKind.Invalid, main_rank: -1, card_count: 0, kick_rank: -1, chain_len: 0, ranks: [], rank_count: 0 };
    game.last_combo_player = DDZ_NO_PLAYER;
    game.players[0].count = 1;
    game.players[0].cards[0] = DdzCard{ id: 10, rank: 4, suit: 0 };
    ddz_hand_recount(&game.players[0]);
    var single_rank: [i32: 20] = [];
    single_rank[0] = 4;
    var action: DdzAction = DdzAction{
        kind: DdzActionKind.Play,
        bid: 0,
        combo: ddz_combo_detect(&single_rank[0], 1),
        card_ids: [],
        card_count: 1,
        label: [],
    };
    action.card_ids[0] = 10;
    try assert_eq_bool(ddz_game_apply_action(&game, 0, &action), true);
    try assert_eq_i32(game.players[0].count, 0);
    try assert_eq_i32(game.phase as i32, DdzGamePhase.GameOver as i32);
    try assert_eq_i32(game.winner, 0);
    try assert_eq_i32(game.history_count, 1);
    try assert_eq_i32(game.history[0].player, 0);
    try assert_eq_i32(game.history[0].action.combo.kind as i32, DdzComboKind.Single as i32);
    try assert_eq_i32(game.history[0].hand_counts[0], 0);
}

test "doudizhu generate play actions includes pass only when responding" {
    var game: DdzGameState = ddz_game_new();
    game.phase = DdzGamePhase.Playing;
    game.current_player = 1;
    var ranks: [i32: 20] = [];
    ranks[0] = 3;
    game.last_combo = ddz_combo_detect(&ranks[0], 1);
    game.last_combo_player = 0;
    game.players[1].count = 1;
    game.players[1].cards[0] = DdzCard{ id: 20, rank: 2, suit: 0 };
    ddz_hand_recount(&game.players[1]);
    var legal: DdzActionList = ddz_action_list_new();
    try assert_eq_bool(ddz_generate_play_actions(&game, 1, &legal), true);
    try assert_eq_i32(legal.items[0].combo.kind as i32, DdzComboKind.Pass as i32);
}

test "doudizhu history records bid pass and restart resets history" {
    var game: DdzGameState = ddz_game_new();
    game.phase = DdzGamePhase.Bidding;
    game.current_player = 0;
    var bid_action: DdzAction = DdzAction{
        kind: DdzActionKind.Bid,
        bid: 1,
        combo: DdzCombo{ kind: DdzComboKind.Invalid, main_rank: -1, card_count: 0, kick_rank: -1, chain_len: 0, ranks: [], rank_count: 0 },
        card_ids: [],
        card_count: 0,
        label: [],
    };
    try assert_eq_bool(ddz_game_apply_action(&game, 0, &bid_action), true);
    try assert_eq_i32(game.history_count, 1);
    try assert_eq_i32(game.history[0].action.bid, 1);

    game.phase = DdzGamePhase.Playing;
    game.current_player = 1;
    game.last_combo_player = 0;
    var ranks: [i32: 20] = [];
    ranks[0] = 4;
    game.last_combo = ddz_combo_detect(&ranks[0], 1);
    game.players[1].count = 1;
    game.players[1].cards[0] = DdzCard{ id: 99, rank: 5, suit: 0 };
    ddz_hand_recount(&game.players[1]);
    var legal: DdzActionList = ddz_action_list_new();
    try assert_eq_bool(ddz_generate_play_actions(&game, 1, &legal), true);
    try assert_eq_bool(ddz_game_apply_action(&game, 1, &legal.items[0]), true);
    try assert_eq_i32(game.history_count, 2);
    try assert_eq_i32(game.history[1].action.combo.kind as i32, DdzComboKind.Pass as i32);

    try assert_eq_bool(ddz_game_restart(&game, 77u32), true);
    try assert_eq_i32(game.history_count, 0);
    try assert_eq_bool(DDZ_MAX_HISTORY >= 128, true);
}
