use core.dirty_region.DirtyRegion;
use core.dirty_region.DirtyRegionIter;
use core.dirty_region.DirtyRegionView;
use core.dirty_region.dirty_region_new;
use core.rect.Rect;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_DIRTY_REGION_MODULE: i32 = 1;

test "dirty region merges overlapping rects" {
    var dirty: DirtyRegion = dirty_region_new();
    dirty.add(Rect{ x: 0, y: 0, w: 10, h: 10 });
    dirty.add(Rect{ x: 5, y: 5, w: 10, h: 10 });
    dirty.merge();

    const view: DirtyRegionView = dirty.get_regions();
    try assert_eq_i32(view.len, 1);
    try assert_eq_i32(view.at(0).w as i32, 15);
    try assert_eq_i32(view.at(0).h as i32, 15);
}

test "dirty region full refresh heuristic" {
    var dirty: DirtyRegion = dirty_region_new();
    dirty.add(Rect{ x: 0, y: 0, w: 90, h: 90 });
    try assert_eq_bool(dirty.should_full_refresh(Rect{ x: 0, y: 0, w: 100, h: 100 }), true);
    dirty.clear();
    const view: DirtyRegionView = dirty.get_regions();
    try assert_eq_bool(view.is_empty(), true);
}

test "dirty region view exposes zero copy iterator" {
    var dirty: DirtyRegion = dirty_region_new();
    dirty.add(Rect{ x: 1, y: 2, w: 3, h: 4 });
    dirty.add(Rect{ x: 10, y: 20, w: 5, h: 6 });
    dirty.merge();

    const view: DirtyRegionView = dirty.get_regions();
    var it: DirtyRegionIter = view.iter();
    var first: Rect = Rect{ x: 0, y: 0, w: 0, h: 0 };
    var second: Rect = Rect{ x: 0, y: 0, w: 0, h: 0 };

    try assert_eq_bool(view.is_empty(), false);
    try assert_eq_bool(it.next(&first), true);
    try assert_eq_bool(it.next(&second), true);
    try assert_eq_bool(it.next(&second), false);
    try assert_eq_i32(first.x as i32, 1);
    try assert_eq_i32(first.y as i32, 2);
    try assert_eq_i32(second.x as i32, 10);
    try assert_eq_i32(second.y as i32, 20);
}
