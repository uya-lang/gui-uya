use core.color.BLUE;
use core.color.Color;
use core.color.GREEN;
use core.color.RED;
use core.color.WHITE;
use core.rect.Rect;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_get_pixel;
use platform.disp.framebuffer_new;
use render.ctx.RenderCtx;
use render.ctx.ctx_pixel;
use render.ctx.render_ctx_new;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_RENDER_CTX_MODULE: i32 = 1;

test "render ctx draws pixels and clips rects" {
    var bytes: [byte: 64] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 4, 4, 8, PixelFormat.RGB565));
    const red1: Color = Color{ r: 255, g: 0, b: 0, a: 255 };
    const green0: Color = Color{ r: 0, g: 255, b: 0, a: 255 };
    const green1: Color = Color{ r: 0, g: 255, b: 0, a: 255 };

    ctx.draw_pixel(1, 1, RED);
    try assert_eq_bool(ctx_pixel(&ctx, 1, 1) == red1, true);

    ctx.push_clip(Rect{ x: 0, y: 0, w: 2, h: 2 });
    ctx.fill_rect(Rect{ x: 0, y: 0, w: 4, h: 4 }, green0);
    ctx.pop_clip();

    try assert_eq_bool(ctx_pixel(&ctx, 0, 0) == green1, true);
    try assert_eq_bool(ctx_pixel(&ctx, 3, 3) == Color{ r: 0, g: 0, b: 0, a: 255 }, true);
}

test "render ctx draws line circle and arc" {
    var bytes: [byte: 256] = [];
    const fb: FrameBuffer = framebuffer_new(&bytes[0], 8, 8, 32, PixelFormat.ARGB8888);
    var ctx: RenderCtx = render_ctx_new(fb);
    const blue1: Color = Color{ r: 0, g: 0, b: 255, a: 255 };

    ctx.draw_line(0, 0, 7, 7, BLUE, 1);
    ctx.draw_circle(4, 4, 2, WHITE);
    ctx.fill_arc(4, 4, 2, 0, 90, GREEN);

    try assert_eq_bool(ctx_pixel(&ctx, 0, 0) == blue1, true);
    try assert_eq_bool(ctx.stats.line_ops >= 1u32, true);
    try assert_eq_bool(ctx.stats.circle_ops >= 1u32, true);
}

test "draw round rect clips corner arcs to quadrants" {
    var bytes: [byte: 576] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 12, 12, 48, PixelFormat.ARGB8888));
    const white0: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white1: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const black_clear: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const black_expect0: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const black_expect1: Color = Color{ r: 0, g: 0, b: 0, a: 255 };

    ctx.clear(black_clear);
    ctx.draw_round_rect(Rect{ x: 1, y: 1, w: 8, h: 8 }, 2, white0, 1);

    try assert_eq_bool(ctx_pixel(&ctx, 3, 1) == white1, true);
    try assert_eq_bool(ctx_pixel(&ctx, 1, 3) == white1, true);
    try assert_eq_bool(ctx_pixel(&ctx, 4, 2) == black_expect0, true);
    try assert_eq_bool(ctx_pixel(&ctx, 2, 4) == black_expect1, true);
    try assert_eq_bool(ctx_pixel(&ctx, 4, 4) == black_expect1, true);
}

test "draw round rect keeps bottom edge visible on wide rounded outlines" {
    var bytes: [byte: 20480] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 128, 40, 512, PixelFormat.ARGB8888));
    const bg: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const blue_draw: Color = Color{ r: 33, g: 126, b: 227, a: 255 };
    const blue_expect: Color = Color{ r: 33, g: 126, b: 227, a: 255 };

    ctx.clear(bg);
    ctx.draw_round_rect(Rect{ x: 8, y: 4, w: 112, h: 36 }, 10u8, blue_draw, 1u8);

    try assert_eq_bool(ctx_pixel(&ctx, 64, 39) == blue_expect, true);
}

test "render ctx blends alpha on i4 framebuffer" {
    var bytes: [byte: 8] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 4, 4, 2, PixelFormat.I4));
    const half_white: Color = Color{ r: 255, g: 255, b: 255, a: 96 };

    ctx.clear(Color{ r: 0, g: 0, b: 0, a: 255 });
    ctx.draw_pixel(1, 1, half_white);

    const pixel: Color = ctx_pixel(&ctx, 1, 1);
    try assert_eq_bool(pixel.r > 0u8, true);
    try assert_eq_bool(pixel.r < 255u8, true);
}

test "fill round rect antialiases corners" {
    var bytes: [byte: 1024] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 16, 16, 64, PixelFormat.ARGB8888));
    const aa_clear: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const aa_black_expect: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const white_fill: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const white_expect: Color = Color{ r: 255, g: 255, b: 255, a: 255 };

    ctx.clear(aa_clear);
    ctx.fill_round_rect(Rect{ x: 1, y: 1, w: 8, h: 8 }, 3, white_fill);

    const edge: Color = ctx_pixel(&ctx, 2, 1);
    try assert_eq_bool(ctx_pixel(&ctx, 1, 1) == aa_black_expect, true);
    try assert_eq_bool(edge.r > 0u8, true);
    try assert_eq_bool(edge.r < 255u8, true);
    try assert_eq_bool(ctx_pixel(&ctx, 4, 4) == white_expect, true);
}

test "round shadow and gradients render soft transitions" {
    var bytes: [byte: 1600] = [];
    var ctx: RenderCtx = render_ctx_new(framebuffer_new(&bytes[0], 20, 20, 80, PixelFormat.ARGB8888));
    const fx_clear: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const fx_black_expect: Color = Color{ r: 0, g: 0, b: 0, a: 255 };
    const shadow_color: Color = Color{ r: 255, g: 255, b: 255, a: 180 };
    const red_start: Color = Color{ r: 255, g: 0, b: 0, a: 255 };
    const blue_end: Color = Color{ r: 0, g: 0, b: 255, a: 255 };
    const red_expect: Color = Color{ r: 255, g: 0, b: 0, a: 255 };
    const blue_expect: Color = Color{ r: 0, g: 0, b: 255, a: 255 };
    const white_inner: Color = Color{ r: 255, g: 255, b: 255, a: 255 };
    const black_outer: Color = Color{ r: 0, g: 0, b: 0, a: 255 };

    ctx.clear(fx_clear);
    ctx.fill_round_shadow(Rect{ x: 6, y: 6, w: 6, h: 6 }, 2, 3, shadow_color);
    const shadow_edge: Color = ctx_pixel(&ctx, 4, 9);
    try assert_eq_bool(shadow_edge.r > 0u8, true);
    try assert_eq_bool(shadow_edge.r < 255u8, true);
    try assert_eq_bool(ctx_pixel(&ctx, 0, 0) == fx_black_expect, true);

    ctx.fill_linear_gradient(Rect{ x: 0, y: 14, w: 5, h: 2 }, red_start, blue_end, true);
    try assert_eq_bool(ctx_pixel(&ctx, 0, 14) == red_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 4, 14) == blue_expect, true);
    try assert_eq_bool(ctx_pixel(&ctx, 2, 14).r > 0u8, true);
    try assert_eq_bool(ctx_pixel(&ctx, 2, 14).b > 0u8, true);

    ctx.fill_radial_gradient(Rect{ x: 12, y: 12, w: 6, h: 6 }, white_inner, black_outer);
    try assert_eq_bool(ctx_pixel(&ctx, 15, 15).r > ctx_pixel(&ctx, 12, 12).r, true);
}
