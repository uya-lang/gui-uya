use core.point.Point;
use core.rect.Rect;
use richtext.delta.rich_insert_break;
use richtext.layout.RichLayoutCache;
use richtext.layout.rich_layout_cache_new;
use richtext.document.RichBlockType;
use richtext.document.RichDocument;
use richtext.document.rich_document_new;
use render.font.Font;
use render.font.font_system_default;
use render.font.text_width;
use richtext.selection.RichPos;
use richtext.selection.RichRange;
use richtext.selection.rich_range_collapsed;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_RICHTEXT_LAYOUT_MODULE: i32 = 1;

fn assert_layout_matches(actual: &RichLayoutCache, expected: &RichLayoutCache, doc: &RichDocument) !void {
    try assert_eq_i32(actual.line_count as i32, expected.line_count as i32);
    try assert_eq_i32(actual.total_height as i32, expected.total_height as i32);

    var line_idx: u32 = 0u32;
    while line_idx < actual.line_count {
        try assert_eq_i32(actual.lines[line_idx as usize].block_index as i32, expected.lines[line_idx as usize].block_index as i32);
        try assert_eq_i32(actual.lines[line_idx as usize].x as i32, expected.lines[line_idx as usize].x as i32);
        try assert_eq_i32(actual.lines[line_idx as usize].y as i32, expected.lines[line_idx as usize].y as i32);
        try assert_eq_i32(actual.lines[line_idx as usize].w as i32, expected.lines[line_idx as usize].w as i32);
        try assert_eq_i32(actual.lines[line_idx as usize].h as i32, expected.lines[line_idx as usize].h as i32);
        try assert_eq_i32(actual.lines[line_idx as usize].baseline as i32, expected.lines[line_idx as usize].baseline as i32);
        try assert_eq_i32((try doc.pos_to_linear_offset(actual.lines[line_idx as usize].start)) as i32, (try doc.pos_to_linear_offset(expected.lines[line_idx as usize].start)) as i32);
        try assert_eq_i32((try doc.pos_to_linear_offset(actual.lines[line_idx as usize].end)) as i32, (try doc.pos_to_linear_offset(expected.lines[line_idx as usize].end)) as i32);
        line_idx = line_idx + 1u32;
    }
}

test "layout cache builds visual lines with soft wrap across blocks" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 7u32);

    try assert_eq_i32(layout.line_count as i32, 3);
    try assert_eq_i32(layout.max_width as i32, 35);
    try assert_eq_i32(layout.doc_revision as i32, doc.revision as i32);
    try assert_eq_i32(layout.theme_revision as i32, 7);

    try assert_eq_i32(layout.lines[0].block_index as i32, 0);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[0].start)) as i32, 0);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[0].end)) as i32, 5);

    try assert_eq_i32(layout.lines[1].block_index as i32, 0);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[1].start)) as i32, 6);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[1].end)) as i32, 10);

    try assert_eq_i32(layout.lines[2].block_index as i32, 1);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[2].start)) as i32, 11);
    try assert_eq_i32((try doc.pos_to_linear_offset(layout.lines[2].end)) as i32, 16);
    try assert_eq_i32(layout.lines[1].y as i32, font.line_height as i32);
    try assert_eq_i32(layout.lines[2].y as i32, font.line_height as i32 * 2);
    try assert_eq_i32(layout.total_height as i32, font.line_height as i32 * 3);
}

test "layout cache applies basic block style insets and heights" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("head\nquote\nitem\ncode" as &const byte);
    doc.blocks[0].block_type = RichBlockType.Heading1;
    doc.blocks[1].block_type = RichBlockType.Quote;
    doc.blocks[2].block_type = RichBlockType.BulletItem;
    doc.blocks[3].block_type = RichBlockType.CodeBlock;

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 160u16, 0u32);

    try assert_eq_i32(layout.line_count as i32, 4);
    try assert_eq_bool(layout.lines[0].h as i32 > font.line_height as i32, true);
    try assert_eq_bool(layout.lines[1].x as i32 > 0, true);
    try assert_eq_bool(layout.lines[2].x as i32 > layout.lines[1].x as i32, true);
    try assert_eq_bool(layout.lines[3].x as i32 > 0, true);
    try assert_eq_bool(layout.lines[1].y as i32 > layout.lines[0].y as i32 + layout.lines[0].h as i32, true);
    try assert_eq_bool(layout.lines[3].y as i32 > layout.lines[2].y as i32 + layout.lines[2].h as i32 - 1, true);
}

test "layout cache splits selection into visual line rects" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 0u32);

    var rects: [Rect: 4] = [];
    const rect_count: u32 = try layout.selection_rects(&doc, &font, RichRange{
        anchor: try doc.linear_offset_to_pos(3u32),
        focus: try doc.linear_offset_to_pos(8u32),
    }, &rects[0], 4u32);
    const first_end_x: i16 = try layout.line_x_for_pos(&doc, &font, 0u32, try doc.linear_offset_to_pos(5u32));
    const second_end_x: i16 = try layout.line_x_for_pos(&doc, &font, 1u32, try doc.linear_offset_to_pos(8u32));

    try assert_eq_i32(rect_count as i32, 2);
    try assert_eq_i32(rects[0].x as i32, layout.lines[0].x as i32 + text_width("alp" as &const byte, 3usize, &font) as i32);
    try assert_eq_i32(rects[0].y as i32, layout.lines[0].y as i32);
    try assert_eq_i32((rects[0].x as i32 + rects[0].w as i32), first_end_x as i32);
    try assert_eq_i32(rects[0].h as i32, layout.lines[0].h as i32);

    try assert_eq_i32(rects[1].x as i32, layout.lines[1].x as i32);
    try assert_eq_i32(rects[1].y as i32, layout.lines[1].y as i32);
    try assert_eq_i32((rects[1].x as i32 + rects[1].w as i32), second_end_x as i32);
    try assert_eq_i32(rects[1].h as i32, layout.lines[1].h as i32);
}

test "layout cache includes trailing block break in selection rects" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("ab\ncd" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 160u16, 0u32);

    var rects: [Rect: 2] = [];
    const rect_count: u32 = try layout.selection_rects(&doc, &font, RichRange{
        anchor: try doc.linear_offset_to_pos(1u32),
        focus: try doc.linear_offset_to_pos(3u32),
    }, &rects[0], 2u32);
    const break_end_x: i32 = layout.lines[0].x as i32 + layout.lines[0].w as i32 + text_width(" " as &const byte, 1usize, &font) as i32;

    try assert_eq_i32(rect_count as i32, 1);
    try assert_eq_i32(rects[0].x as i32, layout.lines[0].x as i32 + text_width("a" as &const byte, 1usize, &font) as i32);
    try assert_eq_i32(rects[0].y as i32, layout.lines[0].y as i32);
    try assert_eq_i32((rects[0].x as i32 + rects[0].w as i32), break_end_x);
    try assert_eq_i32(rects[0].h as i32, layout.lines[0].h as i32);
}

test "layout cache incremental relayout matches full relayout for block text edits" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma delta" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 0u32);

    _ = try doc.set_span_text(1u32, 0u16, "tiny words" as &const byte, 10usize);
    try layout.relayout_block_range(&doc, &font, 35u16, 0u32, 1u32, 1u32, 1u32);

    var full: RichLayoutCache = rich_layout_cache_new();
    defer full.dispose();
    try full.relayout(&doc, &font, 35u16, 0u32);

    try assert_layout_matches(&layout, &full, &doc);
}

test "layout cache incremental relayout shifts tail blocks after split" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 0u32);

    const caret: RichPos = try rich_insert_break(&doc, rich_range_collapsed(try doc.linear_offset_to_pos(5u32)));
    _ = caret;
    try layout.relayout_block_range(&doc, &font, 35u16, 0u32, 0u32, 1u32, 2u32);

    var full: RichLayoutCache = rich_layout_cache_new();
    defer full.dispose();
    try full.relayout(&doc, &font, 35u16, 0u32);

    try assert_layout_matches(&layout, &full, &doc);
}

test "layout cache point hit testing maps points to rich positions" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta\ngamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();
    try layout.relayout(&doc, &font, 35u16, 0u32);

    const line0_mid: RichPos = try layout.point_to_pos(&doc, &font, Point{
        x: layout.lines[0].x + text_width("alp" as &const byte, 3usize, &font) + 2i16,
        y: layout.lines[0].y + 1i16,
    });
    const line1_left: RichPos = try layout.hit_test(&doc, &font, Point{
        x: layout.lines[1].x - 4i16,
        y: layout.lines[1].y + 1i16,
    });
    const block_end: RichPos = try layout.point_to_pos(&doc, &font, Point{
        x: layout.lines[0].x + layout.lines[0].w as i16 + 4i16,
        y: layout.lines[0].y + 1i16,
    });
    const bottom_clamped: RichPos = try layout.point_to_pos(&doc, &font, Point{
        x: layout.lines[2].x + layout.lines[2].w as i16 + 8i16,
        y: layout.lines[2].y + layout.lines[2].h as i16 + 12i16,
    });

    try assert_eq_i32((try doc.pos_to_linear_offset(line0_mid)) as i32, 3);
    try assert_eq_i32((try doc.pos_to_linear_offset(line1_left)) as i32, 6);
    try assert_eq_i32((try doc.pos_to_linear_offset(block_end)) as i32, 5);
    try assert_eq_i32((try doc.pos_to_linear_offset(bottom_clamped)) as i32, 16);
}

test "layout cache recomputes when width changes" {
    var doc: RichDocument = rich_document_new();
    defer doc.dispose();
    try doc.set_plain_text("alpha beta gamma" as &const byte);

    var font: Font = font_system_default();
    var layout: RichLayoutCache = rich_layout_cache_new();
    defer layout.dispose();

    try layout.relayout(&doc, &font, 80u16, 0u32);
    const wide_line_count: u32 = layout.line_count;
    const wide_total_height: u16 = layout.total_height;

    try layout.relayout(&doc, &font, 35u16, 0u32);

    try assert_eq_bool(layout.line_count > wide_line_count, true);
    try assert_eq_bool(layout.total_height > wide_total_height, true);
    try assert_eq_i32(layout.max_width as i32, 35);
}
