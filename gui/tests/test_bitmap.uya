use core.bitmap.BitmapAllocator;
use core.bitmap.bitmap_allocator_alloc;
use core.bitmap.bitmap_allocator_find_first_zero;
use core.bitmap.bitmap_allocator_free;
use core.bitmap.bitmap_allocator_free_slots;
use core.bitmap.bitmap_allocator_is_used;
use core.bitmap.bitmap_allocator_new;
use core.bitmap.bitmap_allocator_used;
use libc.pthread;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_BITMAP_MODULE: i32 = 1;

const BITMAP_CONCURRENT_WORKERS: i32 = 4;
const BITMAP_CONCURRENT_CAPACITY: i32 = 16;

var _bitmap_shared: &BitmapAllocator = null;
var _bitmap_start_flag: atomic i32 = 0;
var _bitmap_worker_success: [i32: 4] = [];

fn bitmap_alloc_worker(arg: &void) &void {
    const worker_idx: i32 = (@usize_from_ptr(arg as &void) as! i32).value;

    while _bitmap_start_flag == 0 {
        _ = pthread_yield();
    }

    var local_count: i32 = 0;
    while true {
        const idx: i32 = bitmap_allocator_alloc(_bitmap_shared);
        if idx < 0 {
            break;
        }
        local_count = local_count + 1;
    }

    _bitmap_worker_success[worker_idx as usize] = local_count;
    return null;
}

test "bitmap allocator alloc free cycle" {
    var bitmap: BitmapAllocator = bitmap_allocator_new(8);

    try assert_eq_i32(bitmap_allocator_find_first_zero(&bitmap), 0);
    try assert_eq_i32(bitmap_allocator_used(&bitmap), 0);
    try assert_eq_i32(bitmap_allocator_free_slots(&bitmap), 8);

    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 0);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 1);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 2);
    try assert_eq_bool(bitmap_allocator_is_used(&bitmap, 1), true);
    try assert_eq_i32(bitmap_allocator_used(&bitmap), 3);

    bitmap_allocator_free(&bitmap, 1);
    try assert_eq_bool(bitmap_allocator_is_used(&bitmap, 1), false);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 1);
    try assert_eq_i32(bitmap_allocator_used(&bitmap), 3);
}

test "bitmap allocator exhaustion" {
    var bitmap: BitmapAllocator = bitmap_allocator_new(4);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 0);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 1);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 2);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), 3);
    try assert_eq_i32(bitmap_allocator_alloc(&bitmap), -1);
    try assert_eq_i32(bitmap_allocator_find_first_zero(&bitmap), -1);
}

test "bitmap allocator concurrent allocation" {
    var bitmap: BitmapAllocator = bitmap_allocator_new(BITMAP_CONCURRENT_CAPACITY);
    var workers: [pthread_t: 4] = [];
    var i: i32 = 0;

    _bitmap_shared = &bitmap;
    _bitmap_start_flag = 0;
    while i < BITMAP_CONCURRENT_WORKERS {
        _bitmap_worker_success[i as usize] = 0;
        i = i + 1;
    }

    i = 0;
    while i < BITMAP_CONCURRENT_WORKERS {
        const arg: &void = @ptr_from_usize(i as usize) as &void;
        try assert_eq_i32(pthread_create(&workers[i as usize], null as &const pthread_attr_t, &bitmap_alloc_worker as &void, arg), 0);
        i = i + 1;
    }

    _bitmap_start_flag = 1;

    i = 0;
    while i < BITMAP_CONCURRENT_WORKERS {
        try assert_eq_i32(pthread_join(&workers[i as usize], null as & &void), 0);
        i = i + 1;
    }

    var total: i32 = 0;
    i = 0;
    while i < BITMAP_CONCURRENT_WORKERS {
        total = total + _bitmap_worker_success[i as usize];
        i = i + 1;
    }

    try assert_eq_i32(total, BITMAP_CONCURRENT_CAPACITY);
    try assert_eq_i32(bitmap_allocator_used(&bitmap), BITMAP_CONCURRENT_CAPACITY);
    try assert_eq_i32(bitmap_allocator_find_first_zero(&bitmap), -1);
}
