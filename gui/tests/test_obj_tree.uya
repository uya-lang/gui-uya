use core.dirty_region.DirtyRegion;
use core.dirty_region.DirtyRegionView;
use core.dirty_region.dirty_region_new;
use core.color.Color;
use core.obj.GuiObj;
use core.obj.IGuiRenderCallback;
use core.obj.gui_obj_default;
use core.obj.gui_obj_register;
use core.obj.gui_obj_get;
use core.obj.gui_obj_reset_registry;
use core.obj_tree.BubblePath;
use core.obj_tree.ObjTreeDirtyRenderPlan;
use core.obj_tree.ObjTree;
use core.obj_tree.obj_tree_new;
use core.point.Point;
use core.rect.Rect;
use platform.disp.FrameBuffer;
use platform.disp.PixelFormat;
use platform.disp.framebuffer_copy;
use platform.disp.framebuffer_new;
use render.ctx.RenderCtx;
use render.ctx.ctx_pixel;
use render.ctx.render_ctx_new;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

export const TEST_OBJ_TREE_MODULE: i32 = 1;

struct TestLeafRenderSpec {
    color: Color,
}

struct TestRootRenderSpec {
    color: Color,
    child: &GuiObj,
}

struct TestLeafRenderAdapter : IGuiRenderCallback {}
struct TestRootRenderAdapter : IGuiRenderCallback {}

var TEST_LEAF_RENDER_ADAPTER: IGuiRenderCallback = TestLeafRenderAdapter{};
var TEST_ROOT_RENDER_ADAPTER: IGuiRenderCallback = TestRootRenderAdapter{};

TestLeafRenderAdapter {
    fn invoke(self: &Self, obj: &GuiObj, ctx: &RenderCtx, user_data: &void) void {
        _ = self;
        const spec: &TestLeafRenderSpec = user_data as &TestLeafRenderSpec;
        if obj == null || spec == null {
            return;
        }
        ctx.fill_rect(obj.screen_area(), spec.color);
    }
}

TestRootRenderAdapter {
    fn invoke(self: &Self, obj: &GuiObj, ctx: &RenderCtx, user_data: &void) void {
        _ = self;
        const spec: &TestRootRenderSpec = user_data as &TestRootRenderSpec;
        if obj == null || spec == null {
            return;
        }
        ctx.fill_rect(obj.screen_area(), spec.color);
        if spec.child != null {
            spec.child.render(ctx);
        }
    }
}

test "obj tree attach detach and bubble path" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    var leaf: GuiObj = gui_obj_default();

    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 10, y: 10, w: 50, h: 50 });
    leaf.set_area(Rect{ x: 5, y: 5, w: 10, h: 10 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);
    _ = gui_obj_register(2, &leaf);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(1, 2);

    try assert_eq_i32(root.child_count(), 1);
    try assert_eq_i32(child.child_count(), 1);
    try assert_eq_i32(child.parent_idx, 0);
    try assert_eq_i32(leaf.parent_idx, 1);

    const path: BubblePath = tree.bubble_path(2);
    try assert_eq_i32(path.len, 3);
    try assert_eq_i32(path.nodes[0], 2);
    try assert_eq_i32(path.nodes[1], 1);
    try assert_eq_i32(path.nodes[2], 0);

    tree.detach(2);
    try assert_eq_i32(child.child_count(), 0);
    try assert_eq_i32(leaf.parent_idx, -1);
}

test "obj tree traversal order" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var left: GuiObj = gui_obj_default();
    var right: GuiObj = gui_obj_default();

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &left);
    _ = gui_obj_register(2, &right);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(0, 2);

    const pre_path: BubblePath = tree.pre_order(0);
    const post_path: BubblePath = tree.post_order(0);

    try assert_eq_i32(pre_path.len, 3);
    try assert_eq_i32(pre_path.nodes[0], 0);
    try assert_eq_i32(pre_path.nodes[1], 1);
    try assert_eq_i32(pre_path.nodes[2], 2);

    try assert_eq_i32(post_path.len, 3);
    try assert_eq_i32(post_path.nodes[0], 1);
    try assert_eq_i32(post_path.nodes[1], 2);
    try assert_eq_i32(post_path.nodes[2], 0);
}

test "obj tree hit testing prefers deepest child" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    var leaf: GuiObj = gui_obj_default();

    root.set_area(Rect{ x: 0, y: 0, w: 200, h: 200 });
    child.set_area(Rect{ x: 20, y: 20, w: 80, h: 80 });
    leaf.set_area(Rect{ x: 10, y: 10, w: 30, h: 30 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);
    _ = gui_obj_register(2, &leaf);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(1, 2);

    try assert_eq_i32(tree.find_at_point(0, Point{ x: 5, y: 5 }), 0);
    try assert_eq_i32(tree.find_at_point(0, Point{ x: 25, y: 25 }), 1);
    try assert_eq_i32(tree.find_at_point(0, Point{ x: 35, y: 35 }), 2);
    try assert_eq_i32(tree.find_at_point(0, Point{ x: 250, y: 250 }), -1);
}

test "gui obj drop unregisters from registry" {
    gui_obj_reset_registry();
    {
        var temp: GuiObj = gui_obj_default();
        _ = gui_obj_register(7, &temp);
        try assert_eq_bool(gui_obj_get(7) != null, true);
    }
    try assert_eq_bool(gui_obj_get(7) == null, true);
}

test "obj tree collects precise invalid region from leaf change" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 12, y: 18, w: 24, h: 16 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.clear_invalid_regions();

    child.invalidate();

    var dirty: DirtyRegion = dirty_region_new();
    tree.collect_invalid_regions(&dirty);
    dirty.merge();
    const view: DirtyRegionView = dirty.get_regions();
    try assert_eq_bool(tree.has_invalid(), true);
    try assert_eq_i32(view.len, 1);
    try assert_eq_i32(view.regions[0].x as i32, 12);
    try assert_eq_i32(view.regions[0].y as i32, 18);
    try assert_eq_i32(view.regions[0].w as i32, 24);
    try assert_eq_i32(view.regions[0].h as i32, 16);

    tree.clear_invalid_regions();
    try assert_eq_bool(tree.has_invalid(), false);
}

test "gui obj move invalidates both old and new bounds" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 120, h: 80 });
    child.set_area(Rect{ x: 10, y: 20, w: 16, h: 12 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.clear_invalid_regions();

    child.move_to(34, 20);

    var dirty: DirtyRegion = dirty_region_new();
    tree.collect_invalid_regions(&dirty);
    dirty.merge();
    const view: DirtyRegionView = dirty.get_regions();
    try assert_eq_i32(view.len, 1);
    try assert_eq_i32(view.regions[0].x as i32, 10);
    try assert_eq_i32(view.regions[0].y as i32, 20);
    try assert_eq_i32(view.regions[0].w as i32, 40);
    try assert_eq_i32(view.regions[0].h as i32, 12);
}

test "obj tree dirty render plan updates only invalid widget region generically" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 24, h: 24 });
    child.set_area(Rect{ x: 6, y: 6, w: 8, h: 8 });

    var root_spec: TestRootRenderSpec = TestRootRenderSpec{
        color: Color{ r: 32, g: 32, b: 32, a: 255 },
        child: &child,
    };
    var child_spec: TestLeafRenderSpec = TestLeafRenderSpec{
        color: Color{ r: 0, g: 96, b: 255, a: 255 },
    };
    root.render_cb = &TEST_ROOT_RENDER_ADAPTER;
    root.user_data = &root_spec as &void;
    child.render_cb = &TEST_LEAF_RENDER_ADAPTER;
    child.user_data = &child_spec as &void;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.clear_invalid_regions();

    var baseline_bytes: [byte: 2304] = [];
    var partial_bytes: [byte: 2304] = [];
    var expected_bytes: [byte: 2304] = [];
    var baseline_ctx: RenderCtx = render_ctx_new(framebuffer_new(&baseline_bytes[0], 24, 24, 96, PixelFormat.ARGB8888));
    root.render(&baseline_ctx);

    child_spec.color = Color{ r: 0, g: 220, b: 120, a: 255 };
    child.invalidate();

    const plan: ObjTreeDirtyRenderPlan = tree.prepare_dirty_render(Rect{ x: 0, y: 0, w: 24, h: 24 }, false);
    try assert_eq_bool(plan.full_refresh, false);
    try assert_eq_i32(plan.request_count, 1);
    try assert_eq_i32(plan.requests[0].region.x as i32, 6);
    try assert_eq_i32(plan.requests[0].region.y as i32, 6);
    try assert_eq_i32(plan.requests[0].region.w as i32, 8);
    try assert_eq_i32(plan.requests[0].region.h as i32, 8);

    var partial_fb: FrameBuffer = framebuffer_new(&partial_bytes[0], 24, 24, 96, PixelFormat.ARGB8888);
    try assert_eq_bool(framebuffer_copy(&partial_fb, &baseline_ctx.fb), true);
    var partial_ctx: RenderCtx = render_ctx_new(partial_fb);
    try assert_eq_bool(tree.render_dirty(&partial_ctx, &plan), true);
    tree.clear_invalid_regions();

    var expected_ctx: RenderCtx = render_ctx_new(framebuffer_new(&expected_bytes[0], 24, 24, 96, PixelFormat.ARGB8888));
    root.render(&expected_ctx);

    var y: i32 = 0;
    while y < 24 {
        var x: i32 = 0;
        while x < 24 {
            try assert_eq_bool(ctx_pixel(&partial_ctx, x as i16, y as i16) == ctx_pixel(&expected_ctx, x as i16, y as i16), true);
            x = x + 1;
        }
        y = y + 1;
    }
    try assert_eq_bool(partial_ctx.stats.pixel_ops < expected_ctx.stats.pixel_ops, true);
}
