use sim.common.sim_cstr_eq;
use sim.config.SimBackendKind;
use sim.config.SimConfig;
use sim.config.sim_backend_name;
use sim.config.sim_config_apply_backend_defaults;
use sim.config.sim_config_default;
use std.testing.assert_eq_bool;

export const TEST_WEB_CONFIG_MODULE: i32 = 1;

test "web config applies browser resource root defaults" {
    var cfg: SimConfig = sim_config_default();
    cfg.backend = SimBackendKind.Web;
    cfg.resource_root = "" as &const byte;
    sim_config_apply_backend_defaults(&cfg);
    try assert_eq_bool(sim_cstr_eq(cfg.resource_root, "/app"), true);
    try assert_eq_bool(cfg.persist_data, false);
    try assert_eq_bool(sim_cstr_eq(sim_backend_name(SimBackendKind.Web), "web"), true);
}

test "desktop config keeps current directory resource root default" {
    var cfg: SimConfig = sim_config_default();
    cfg.backend = SimBackendKind.Sdl2;
    cfg.resource_root = "" as &const byte;
    sim_config_apply_backend_defaults(&cfg);
    try assert_eq_bool(sim_cstr_eq(cfg.resource_root, "."), true);
}
