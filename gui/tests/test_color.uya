use core.color.BLACK;
use core.color.BLUE;
use core.color.Color;
use core.color.GREEN;
use core.color.RED;
use core.color.TRANSPARENT;
use core.color.WHITE;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use std.testing.expect;

export const TEST_COLOR_MODULE: i32 = 1;

fn color_eq(a: Color, b: Color) bool {
    return a.r == b.r && a.g == b.g && a.b == b.b && a.a == b.a;
}

test "color constants and macro" {
    try expect(color_eq(BLACK, Color{ r: 0, g: 0, b: 0, a: 255 }));
    try expect(color_eq(WHITE, Color{ r: 255, g: 255, b: 255, a: 255 }));
    try expect(color_eq(RED, Color{ r: 255, g: 0, b: 0, a: 255 }));
    try expect(color_eq(GREEN, Color{ r: 0, g: 255, b: 0, a: 255 }));
    try expect(color_eq(BLUE, Color{ r: 0, g: 0, b: 255, a: 255 }));
    try expect(color_eq(TRANSPARENT, Color{ r: 0, g: 0, b: 0, a: 0 }));
    try expect(color_eq(Color{ r: 0x11, g: 0x22, b: 0x33, a: 255 }, Color{ r: 0x11, g: 0x22, b: 0x33, a: 255 }));
}

test "color blend" {
    const dst: Color = Color{ r: 10, g: 20, b: 30, a: 255 };
    const src_half: Color = Color{ r: 250, g: 20, b: 30, a: 128 };
    const src_full: Color = Color{ r: 1, g: 2, b: 3, a: 255 };

    try expect(color_eq(dst.blend(src_full), src_full));
    try expect(color_eq(dst.blend(TRANSPARENT), dst));

    const mixed: Color = dst.blend(src_half);
    try assert_eq_i32(mixed.g as i32, 20);
    try assert_eq_i32(mixed.b as i32, 30);
    try assert_eq_bool(mixed.a >= 128u8, true);
    try assert_eq_bool(mixed.r > dst.r, true);
}

test "color conversions and lerp" {
    const c: Color = Color{ r: 255, g: 128, b: 0, a: 255 };
    try assert_eq_i32(c.to_rgb565() as i32, 0xFC00);
    try assert_eq_u64(c.to_argb8888() as u64, 0xFFFF8000u64);

    const mid: Color = BLACK.lerp(WHITE, 0.5);
    try expect(color_eq(mid, Color{ r: 128, g: 128, b: 128, a: 255 }));
    try expect(color_eq(RED.lerp(BLUE, 0.0), RED));
    try expect(color_eq(RED.lerp(BLUE, 1.0), BLUE));
}
