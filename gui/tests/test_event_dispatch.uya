use core.event.Event;
use core.event.EventPhase;
use core.event.EventType;
use core.event.InputDev;
use core.event.event_point;
use core.event.event_point_value;
use core.event_dispatch.EventDispatcher;
use core.event_dispatch.event_dispatcher_new;
use core.obj.GuiObj;
use core.obj.IGuiEventCallback;
use core.obj.gui_obj_default;
use core.obj.gui_obj_register;
use core.obj.gui_obj_reset_registry;
use core.obj_tree.ObjTree;
use core.obj_tree.obj_tree_new;
use core.point.Point;
use core.rect.Rect;
use std.testing.assert_eq_i32;

export const TEST_EVENT_DISPATCH_MODULE: i32 = 1;

struct CountingCallback : IGuiEventCallback {
    count_ref: &i32,
    last_target_ref: &i32,
    last_type_ref: &i32,
}

CountingCallback {
    fn invoke(self: &Self, obj: &GuiObj, evt: &Event, user_data: &void) bool {
        if user_data != null {
            const user_hits: &i32 = user_data as &i32;
            user_hits[0] = user_hits[0] + 1;
        }
        self.count_ref[0] = self.count_ref[0] + 1;
        self.last_target_ref[0] = evt.target;
        self.last_type_ref[0] = evt.event_type as i32;
        return obj.obj_idx == evt.target || evt.phase != EventPhase.Target;
    }
}

test "dispatcher routes click to deepest target callback" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 10, y: 10, w: 30, h: 30 });
    child.flags.clickable = true;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    var click_count: i32 = 0;
    var last_target: i32 = -1;
    var last_type: i32 = -1;
    var user_hits: i32 = 0;
    var cb_impl: CountingCallback = CountingCallback{
        count_ref: &click_count,
        last_target_ref: &last_target,
        last_type_ref: &last_type,
    };
    var cb: IGuiEventCallback = cb_impl;
    child.on_click(&cb, &user_hits as &void);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.dispatch(event_point(EventType.Click, InputDev.Touch, -1, 10, Point{ x: 20, y: 20 }), &tree);

    try assert_eq_i32(click_count, 1);
    try assert_eq_i32(last_target, 1);
    try assert_eq_i32(last_type, EventType.Click as i32);
    try assert_eq_i32(user_hits, 1);
}

test "dispatcher updates focus on press and emits callback" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 10, y: 10, w: 30, h: 30 });
    child.flags.focusable = true;
    child.flags.clickable = true;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    var focus_count: i32 = 0;
    var last_target: i32 = -1;
    var last_type: i32 = -1;
    var user_hits: i32 = 0;
    var cb_impl: CountingCallback = CountingCallback{
        count_ref: &focus_count,
        last_target_ref: &last_target,
        last_type_ref: &last_type,
    };
    var cb: IGuiEventCallback = cb_impl;
    child.on_focus(&cb, &user_hits as &void);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.dispatch(event_point(EventType.Press, InputDev.Touch, -1, 10, Point{ x: 20, y: 20 }), &tree);

    try assert_eq_i32(dispatcher.get_focus(), 1);
    try assert_eq_i32(focus_count, 1);
    try assert_eq_i32(last_target, 1);
    try assert_eq_i32(last_type, EventType.FocusIn as i32);
    try assert_eq_i32(user_hits, 1);
}

test "dispatcher pumps queued touch gestures" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 10, y: 10, w: 30, h: 30 });
    child.flags.clickable = true;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    var click_count: i32 = 0;
    var last_target: i32 = -1;
    var last_type: i32 = -1;
    var user_hits: i32 = 0;
    var cb_impl: CountingCallback = CountingCallback{
        count_ref: &click_count,
        last_target_ref: &last_target,
        last_type_ref: &last_type,
    };
    var cb: IGuiEventCallback = cb_impl;
    child.on_click(&cb, &user_hits as &void);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.process_touch(&tree, Point{ x: 20, y: 20 }, true, 100);
    _ = dispatcher.process_touch(&tree, Point{ x: 20, y: 20 }, false, 180);

    try assert_eq_i32(click_count, 1);
    try assert_eq_i32(last_target, 1);
    try assert_eq_i32(last_type, EventType.Click as i32);
    try assert_eq_i32(user_hits, 1);
}

test "dispatcher emits press release long press and value change callbacks" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 100, h: 100 });
    child.set_area(Rect{ x: 10, y: 10, w: 30, h: 30 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    var press_count: i32 = 0;
    var release_count: i32 = 0;
    var long_press_count: i32 = 0;
    var value_count: i32 = 0;
    var last_target: i32 = -1;
    var press_type: i32 = -1;
    var release_type: i32 = -1;
    var long_press_type: i32 = -1;
    var value_type: i32 = -1;
    var press_user_hits: i32 = 0;
    var release_user_hits: i32 = 0;
    var long_press_user_hits: i32 = 0;
    var value_user_hits: i32 = 0;

    var press_impl: CountingCallback = CountingCallback{
        count_ref: &press_count,
        last_target_ref: &last_target,
        last_type_ref: &press_type,
    };
    var release_impl: CountingCallback = CountingCallback{
        count_ref: &release_count,
        last_target_ref: &last_target,
        last_type_ref: &release_type,
    };
    var long_press_impl: CountingCallback = CountingCallback{
        count_ref: &long_press_count,
        last_target_ref: &last_target,
        last_type_ref: &long_press_type,
    };
    var value_impl: CountingCallback = CountingCallback{
        count_ref: &value_count,
        last_target_ref: &last_target,
        last_type_ref: &value_type,
    };
    var press_cb: IGuiEventCallback = press_impl;
    var release_cb: IGuiEventCallback = release_impl;
    var long_press_cb: IGuiEventCallback = long_press_impl;
    var value_cb: IGuiEventCallback = value_impl;

    child.on_press(&press_cb, &press_user_hits as &void);
    child.on_release(&release_cb, &release_user_hits as &void);
    child.on_long_press(&long_press_cb, &long_press_user_hits as &void);
    child.on_value_change(&value_cb, &value_user_hits as &void);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.dispatch(event_point(EventType.Press, InputDev.Touch, -1, 10, Point{ x: 20, y: 20 }), &tree);
    _ = dispatcher.dispatch(event_point(EventType.Release, InputDev.Touch, -1, 20, Point{ x: 20, y: 20 }), &tree);
    _ = dispatcher.dispatch(event_point(EventType.LongPress, InputDev.Touch, -1, 30, Point{ x: 20, y: 20 }), &tree);
    _ = dispatcher.dispatch(event_point_value(EventType.ValueChange, InputDev.Touch, -1, 40, Point{ x: 20, y: 20 }, 42), &tree);

    try assert_eq_i32(press_count, 1);
    try assert_eq_i32(release_count, 1);
    try assert_eq_i32(long_press_count, 1);
    try assert_eq_i32(value_count, 1);
    try assert_eq_i32(last_target, 1);
    try assert_eq_i32(press_type, EventType.Press as i32);
    try assert_eq_i32(release_type, EventType.Release as i32);
    try assert_eq_i32(long_press_type, EventType.LongPress as i32);
    try assert_eq_i32(value_type, EventType.ValueChange as i32);
    try assert_eq_i32(press_user_hits, 1);
    try assert_eq_i32(release_user_hits, 1);
    try assert_eq_i32(long_press_user_hits, 1);
    try assert_eq_i32(value_user_hits, 1);
}

test "dispatcher process pinch triggers dedicated pinch callbacks" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var child: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 120, h: 120 });
    child.set_area(Rect{ x: 20, y: 20, w: 60, h: 60 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &child);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);

    var pinch_count: i32 = 0;
    var last_target: i32 = -1;
    var last_type: i32 = -1;
    var user_hits: i32 = 0;
    var pinch_impl: CountingCallback = CountingCallback{
        count_ref: &pinch_count,
        last_target_ref: &last_target,
        last_type_ref: &last_type,
    };
    var pinch_cb: IGuiEventCallback = pinch_impl;
    child.on_pinch(&pinch_cb, &user_hits as &void);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.process_pinch(&tree, Point{ x: 30, y: 30 }, Point{ x: 50, y: 30 }, true, 100);
    _ = dispatcher.process_pinch(&tree, Point{ x: 20, y: 30 }, Point{ x: 60, y: 30 }, true, 140);
    _ = dispatcher.process_pinch(&tree, Point{ x: 20, y: 30 }, Point{ x: 60, y: 30 }, false, 180);

    try assert_eq_i32(pinch_count, 3);
    try assert_eq_i32(last_target, 1);
    try assert_eq_i32(last_type, EventType.PinchEnd as i32);
    try assert_eq_i32(user_hits, 3);
}

test "dispatcher capture reroutes events until cleared" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var left: GuiObj = gui_obj_default();
    var right: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 120, h: 60 });
    left.set_area(Rect{ x: 0, y: 0, w: 40, h: 40 });
    right.set_area(Rect{ x: 60, y: 0, w: 40, h: 40 });
    left.flags.clickable = true;
    right.flags.clickable = true;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &left);
    _ = gui_obj_register(2, &right);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(0, 2);

    var left_clicks: i32 = 0;
    var right_clicks: i32 = 0;
    var left_target: i32 = -1;
    var right_target: i32 = -1;
    var left_type: i32 = -1;
    var right_type: i32 = -1;
    var left_impl: CountingCallback = CountingCallback{
        count_ref: &left_clicks,
        last_target_ref: &left_target,
        last_type_ref: &left_type,
    };
    var right_impl: CountingCallback = CountingCallback{
        count_ref: &right_clicks,
        last_target_ref: &right_target,
        last_type_ref: &right_type,
    };
    var left_cb: IGuiEventCallback = left_impl;
    var right_cb: IGuiEventCallback = right_impl;
    left.on_click(&left_cb, null);
    right.on_click(&right_cb, null);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    dispatcher.set_capture(1);
    _ = dispatcher.dispatch(event_point(EventType.Click, InputDev.Touch, -1, 10, Point{ x: 70, y: 10 }), &tree);
    dispatcher.clear_capture();
    _ = dispatcher.dispatch(event_point(EventType.Click, InputDev.Touch, -1, 20, Point{ x: 70, y: 10 }), &tree);

    try assert_eq_i32(left_clicks, 1);
    try assert_eq_i32(left_target, 1);
    try assert_eq_i32(left_type, EventType.Click as i32);
    try assert_eq_i32(right_clicks, 1);
    try assert_eq_i32(right_target, 2);
    try assert_eq_i32(right_type, EventType.Click as i32);
}

test "dispatcher auto capture keeps touch sequence on pressed target" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var left: GuiObj = gui_obj_default();
    var right: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 160, h: 60 });
    left.set_area(Rect{ x: 0, y: 0, w: 40, h: 40 });
    right.set_area(Rect{ x: 80, y: 0, w: 40, h: 40 });
    left.flags.clickable = true;
    right.flags.clickable = true;

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &left);
    _ = gui_obj_register(2, &right);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(0, 2);

    var left_releases: i32 = 0;
    var right_releases: i32 = 0;
    var left_target: i32 = -1;
    var right_target: i32 = -1;
    var left_type: i32 = -1;
    var right_type: i32 = -1;
    var left_impl: CountingCallback = CountingCallback{
        count_ref: &left_releases,
        last_target_ref: &left_target,
        last_type_ref: &left_type,
    };
    var right_impl: CountingCallback = CountingCallback{
        count_ref: &right_releases,
        last_target_ref: &right_target,
        last_type_ref: &right_type,
    };
    var left_cb: IGuiEventCallback = left_impl;
    var right_cb: IGuiEventCallback = right_impl;
    left.on_release(&left_cb, null);
    right.on_release(&right_cb, null);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    _ = dispatcher.process_touch(&tree, Point{ x: 10, y: 10 }, true, 100);
    try assert_eq_i32(dispatcher.get_capture(), 1);
    _ = dispatcher.process_touch(&tree, Point{ x: 90, y: 10 }, true, 130);
    try assert_eq_i32(dispatcher.get_capture(), 1);
    _ = dispatcher.process_touch(&tree, Point{ x: 90, y: 10 }, false, 170);

    try assert_eq_i32(left_releases, 1);
    try assert_eq_i32(left_target, 1);
    try assert_eq_i32(left_type, EventType.Release as i32);
    try assert_eq_i32(right_releases, 0);
    try assert_eq_i32(right_target, -1);
    try assert_eq_i32(dispatcher.get_capture(), -1);
}

test "dispatcher hover tracks enter move leave across targets" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var left: GuiObj = gui_obj_default();
    var right: GuiObj = gui_obj_default();
    root.set_area(Rect{ x: 0, y: 0, w: 160, h: 60 });
    left.set_area(Rect{ x: 0, y: 0, w: 40, h: 40 });
    right.set_area(Rect{ x: 80, y: 0, w: 40, h: 40 });

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &left);
    _ = gui_obj_register(2, &right);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(0, 2);

    var left_hover_count: i32 = 0;
    var right_hover_count: i32 = 0;
    var left_target: i32 = -1;
    var right_target: i32 = -1;
    var left_type: i32 = -1;
    var right_type: i32 = -1;
    var left_impl: CountingCallback = CountingCallback{
        count_ref: &left_hover_count,
        last_target_ref: &left_target,
        last_type_ref: &left_type,
    };
    var right_impl: CountingCallback = CountingCallback{
        count_ref: &right_hover_count,
        last_target_ref: &right_target,
        last_type_ref: &right_type,
    };
    var left_cb: IGuiEventCallback = left_impl;
    var right_cb: IGuiEventCallback = right_impl;
    left.on_hover(&left_cb, null);
    right.on_hover(&right_cb, null);

    var dispatcher: EventDispatcher = event_dispatcher_new();
    try assert_eq_i32(dispatcher.process_hover(&tree, Point{ x: 10, y: 10 }, 100), 1);
    try assert_eq_i32(dispatcher.get_hover(), 1);
    try assert_eq_i32(dispatcher.process_hover(&tree, Point{ x: 12, y: 12 }, 110), 1);
    try assert_eq_i32(dispatcher.process_hover(&tree, Point{ x: 90, y: 10 }, 130), 2);
    try assert_eq_i32(dispatcher.get_hover(), 2);
    try assert_eq_i32(dispatcher.process_hover(&tree, Point{ x: 140, y: 10 }, 150), 0);

    try assert_eq_i32(left_hover_count, 3);
    try assert_eq_i32(left_target, 1);
    try assert_eq_i32(left_type, EventType.HoverLeave as i32);
    try assert_eq_i32(right_hover_count, 2);
    try assert_eq_i32(right_target, 2);
    try assert_eq_i32(right_type, EventType.HoverLeave as i32);
    try assert_eq_i32(dispatcher.get_hover(), 0);
}
