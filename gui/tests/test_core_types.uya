use core.point.POINT_ONE;
use core.point.POINT_ZERO;
use core.point.Point;
use core.size.SIZE_ZERO;
use core.size.Size;
use libc.fabs;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use std.testing.expect;

export const TEST_CORE_TYPES_MODULE: i32 = 1;

fn expect_near(actual: f64, expected: f64, epsilon: f64) !void {
    try expect(fabs(actual - expected) <= epsilon);
}

test "point arithmetic and lerp" {
    const a: Point = Point{ x: 2, y: 3 };
    const b: Point = Point{ x: 5, y: -1 };

    try expect(a.add(b) == Point{ x: 7, y: 2 });
    try expect(a.sub(b) == Point{ x: -3, y: 4 });
    try expect(a.scale(2) == Point{ x: 4, y: 6 });
    try expect(POINT_ZERO.add(POINT_ONE) == POINT_ONE);
    try expect(a.lerp(b, 0.5) == Point{ x: 4, y: 1 });
}

test "point distance" {
    const a: Point = Point{ x: 0, y: 0 };
    const b: Point = Point{ x: 3, y: 4 };
    try expect_near(a.distance(b), 5.0, 0.001);
}

test "size helpers" {
    const panel: Size = Size{ w: 320, h: 240 };
    try assert_eq_bool(SIZE_ZERO.is_empty(), true);
    try assert_eq_bool(panel.is_empty(), false);
    try assert_eq_u64(panel.area() as u64, 76800u64);
    try expect_near(panel.aspect_ratio(), 1.3333333, 0.001);
}
