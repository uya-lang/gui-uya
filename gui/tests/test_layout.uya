    try assert_box(&a, 0, 0, 20, 40);
    try assert_box(&b, 20, 0, 20, 40);
}

test "flex layout align self center overrides align items" {
    var root: GuiObj = layout_box(100, 40);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    a.style.set_u32(StyleProp.AlignSelf, Align.Center as u32);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.End, Align.Start, false, 0, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 15, 20, 10);
    try assert_box(&b, 20, 30, 20, 10);
}

