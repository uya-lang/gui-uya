use core.obj.GuiObj;
use core.obj.gui_obj_default;
use core.obj.gui_obj_register;
use core.obj.gui_obj_reset_registry;
use core.obj_tree.ObjTree;
use core.obj_tree.obj_tree_new;
use layout.auto.AutoLayout;
use layout.auto.LayoutMode;
use layout.auto.auto_layout_new;
use layout.flex.Align;
use layout.flex.FlexConfig;
use layout.flex.FlexDir;
use layout.flex.FlexLayout;
use layout.flex.Justify;
use layout.flex.flex_config_column;
use layout.flex.flex_config_row;
use layout.grid.GridConfig;
use layout.grid.GridAutoFlow;
use layout.grid.GridLayout;
use style.StyleBuilder;
use style.StyleProp;
use style.style_builder_new;
use std.testing.assert_eq_i32;

export const TEST_LAYOUT_MODULE: i32 = 1;

fn layout_box(w: u16, h: u16) GuiObj {
    var obj: GuiObj = gui_obj_default();
    obj.w = w;
    obj.h = h;
    return obj;
}

fn assert_box(obj: &GuiObj, x: i32, y: i32, w: i32, h: i32) !void {
    try assert_eq_i32(obj.x as i32, x);
    try assert_eq_i32(obj.y as i32, y);
    try assert_eq_i32(obj.w as i32, w);
    try assert_eq_i32(obj.h as i32, h);
}

fn flex_row_config(justify: Justify, align_items: Align, align_content: Align, wrap: bool, gap: u8, row_gap: u8, col_gap: u8) FlexConfig {
    return FlexConfig{
        direction: FlexDir.Row,
        justify: justify,
        align_items: align_items,
        align_content: align_content,
        wrap: wrap,
        gap: gap,
        row_gap: row_gap,
        col_gap: col_gap,
        padding: [0, 0, 0, 0],
    };
}

fn flex_column_config(justify: Justify, align_items: Align, align_content: Align, wrap: bool, gap: u8, row_gap: u8, col_gap: u8) FlexConfig {
    return FlexConfig{
        direction: FlexDir.Column,
        justify: justify,
        align_items: align_items,
        align_content: align_content,
        wrap: wrap,
        gap: gap,
        row_gap: row_gap,
        col_gap: col_gap,
        padding: [0, 0, 0, 0],
    };
}

test "flex layout arranges row children" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 40;
    a.w = 20;
    a.h = 10;
    b.w = 30;
    b.h = 10;
    root.add_child(&a);
    root.add_child(&b);

    var cfg: FlexConfig = flex_config_row();
    cfg.gap = 5;
    cfg.align_items = Align.Center;
    var layout: FlexLayout = FlexLayout{ config: cfg };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(b.x as i32, 25);
    try assert_eq_i32(a.y as i32, 15);
}

test "flex layout supports row reverse order" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 40;
    a.w = 20;
    a.h = 10;
    b.w = 30;
    b.h = 10;
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.RowReverse,
            justify: Justify.Start,
            align_items: Align.Center,
            align_content: Align.Start,
            wrap: false,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [0, 0, 0, 0],
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 80);
    try assert_eq_i32(b.x as i32, 45);
    try assert_eq_i32(a.y as i32, 15);
    try assert_eq_i32(b.y as i32, 15);
}

