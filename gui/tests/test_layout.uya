    var root: GuiObj = layout_box(60, 100);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    a.style.set_i32(StyleProp.FlexBasis, 30);
    b.style.set_i32(StyleProp.FlexBasis, 20);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_column() };
