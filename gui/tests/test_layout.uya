test "flex layout distributes grow by flex grow weights" {
    var root: GuiObj = layout_box(100, 30);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    a.style.set_i32(StyleProp.FlexGrow, 1);
    b.style.set_i32(StyleProp.FlexGrow, 3);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_row() };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 35, 10);
    try assert_box(&b, 35, 0, 65, 10);
}

