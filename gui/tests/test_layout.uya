test "flex layout distributes column shrink by weights" {
    var root: GuiObj = layout_box(60, 60);
    var a: GuiObj = layout_box(20, 40);
    var b: GuiObj = layout_box(20, 40);

    a.style.set_i32(StyleProp.FlexShrink, 1);
    b.style.set_i32(StyleProp.FlexShrink, 3);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_column() };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 20, 35);
    try assert_box(&b, 0, 35, 20, 25);
}

test "flex layout clamps child width to min width" {
    var root: GuiObj = layout_box(100, 30);
    var a: GuiObj = layout_box(10, 10);
    var b: GuiObj = layout_box(10, 10);

    a.style.set_u32(StyleProp.MinWidth, 25u32);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_row() };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 25, 10);
    try assert_box(&b, 25, 0, 10, 10);
}

test "flex layout clamps child width to max width" {
    var root: GuiObj = layout_box(100, 30);
    var a: GuiObj = layout_box(50, 10);
    var b: GuiObj = layout_box(10, 10);

    a.style.set_u32(StyleProp.MaxWidth, 30u32);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_row() };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 30, 10);
    try assert_box(&b, 30, 0, 10, 10);
}

test "flex layout skips hidden children" {
    var root: GuiObj = layout_box(100, 30);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);
    var c: GuiObj = layout_box(20, 10);

    b.flags.visible = false;
    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.Start, Align.Start, false, 5, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 20, 10);
    try assert_box(&c, 25, 0, 20, 10);
}

test "flex layout aligns wrapped lines to content end" {
    var root: GuiObj = layout_box(100, 60);
    var a: GuiObj = layout_box(40, 10);
    var b: GuiObj = layout_box(40, 10);
    var c: GuiObj = layout_box(40, 10);

    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.Start, Align.End, true, 5, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 35, 40, 10);
    try assert_box(&b, 45, 35, 40, 10);
    try assert_box(&c, 0, 50, 40, 10);
}

test "flex layout stretches wrapped lines across content space" {
    var root: GuiObj = layout_box(100, 60);
    var a: GuiObj = layout_box(40, 10);
    var b: GuiObj = layout_box(40, 10);
    var c: GuiObj = layout_box(40, 10);

    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.Stretch, Align.Stretch, true, 5, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 40, 27);
    try assert_box(&b, 45, 0, 40, 27);
    try assert_box(&c, 0, 32, 40, 27);
}

test "flex layout centers wrapped column tracks with align content" {
    var root: GuiObj = layout_box(80, 100);
    var a: GuiObj = layout_box(20, 40);
    var b: GuiObj = layout_box(20, 40);
    var c: GuiObj = layout_box(20, 40);

    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: flex_column_config(Justify.Start, Align.Start, Align.Center, true, 5, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 17, 0, 20, 40);
    try assert_box(&b, 17, 45, 20, 40);
    try assert_box(&c, 42, 0, 20, 40);
}

test "grid layout places items by column row" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.add_child(&a);
    root.add_child(&b);
    a.style.set_u32(StyleProp.GridColumn, 1u32);
    a.style.set_u32(StyleProp.GridRow, 0u32);
    b.style.set_u32(StyleProp.GridColumn, 0u32);
    b.style.set_u32(StyleProp.GridRow, 1u32);

    var layout: GridLayout = GridLayout{
        config: GridConfig{
            columns: [20, 30, 0, 0, 0, 0, 0, 0],
            rows: [10, 15, 0, 0, 0, 0, 0, 0],
            col_count: 2,
            row_count: 2,
            gap_x: 2,
            gap_y: 3,
            padding: [0, 0, 0, 0],
            auto_flow: GridAutoFlow.Row,
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 22);
    try assert_eq_i32(a.y as i32, 0);
    try assert_eq_i32(b.x as i32, 0);
    try assert_eq_i32(b.y as i32, 13);
}

test "grid layout accepts grid area shorthand" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    var a_builder: StyleBuilder = style_builder_new();
    a_builder.grid_area(1, 0, 2, 2);
    a.style = a_builder.build();

    var b_builder: StyleBuilder = style_builder_new();
    b_builder.grid_area(0, 1, 1, 1);
    b.style = b_builder.build();

    root.add_child(&a);
    root.add_child(&b);

    var layout: GridLayout = GridLayout{
        config: GridConfig{
            columns: [20, 30, 40, 0, 0, 0, 0, 0],
            rows: [10, 15, 20, 0, 0, 0, 0, 0],
            col_count: 3,
            row_count: 3,
            gap_x: 2,
            gap_y: 3,
            padding: [1, 0, 0, 4],
            auto_flow: GridAutoFlow.Row,
        },
    };
    layout.apply(&root);

    try assert_box(&a, 26, 1, 72, 28);
    try assert_box(&b, 4, 14, 20, 15);
}

test "obj tree perform layout uses auto layout mode" {
    gui_obj_reset_registry();

    var root: GuiObj = gui_obj_default();
    var left: GuiObj = gui_obj_default();
    var right: GuiObj = gui_obj_default();

    root.w = 120;
    root.h = 40;
    left.w = 20;
    left.h = 10;
    right.w = 20;
    right.h = 10;
    root.style.set_u32(StyleProp.LayoutMode, LayoutMode.Flex as u32);
    root.style.set_u32(StyleProp.Gap, 10u32);

    _ = gui_obj_register(0, &root);
    _ = gui_obj_register(1, &left);
    _ = gui_obj_register(2, &right);

    var tree: ObjTree = obj_tree_new();
    tree.set_root(0, &root);
    tree.attach(0, 1);
    tree.attach(0, 2);

    var auto: AutoLayout = auto_layout_new();
    auto.flex.config.gap = 10;
    tree.perform_layout(0, &auto);

    try assert_eq_i32(left.x as i32, 0);
    try assert_eq_i32(right.x as i32, 30);
}
