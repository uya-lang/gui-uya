test "flex layout applies row padding offsets" {
    var root: GuiObj = layout_box(100, 40);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.Row,
            justify: Justify.Start,
            align_items: Align.Start,
            align_content: Align.Start,
            wrap: false,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [2, 3, 4, 5],
        },
    };
    layout.apply(&root);

    try assert_box(&a, 5, 2, 20, 10);
    try assert_box(&b, 30, 2, 20, 10);
}

test "flex layout uses row gap between wrapped lines" {
    var root: GuiObj = layout_box(100, 50);
    var a: GuiObj = layout_box(40, 10);
    var b: GuiObj = layout_box(40, 10);
    var c: GuiObj = layout_box(40, 10);

    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.Start, Align.Start, true, 5, 7, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 40, 10);
    try assert_box(&b, 45, 0, 40, 10);
    try assert_box(&c, 0, 17, 40, 10);
}

test "flex layout uses column gap for row spacing" {
    var root: GuiObj = layout_box(100, 30);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Start, Align.Start, Align.Start, false, 2, 0, 9),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 20, 10);
    try assert_box(&b, 29, 0, 20, 10);
}

test "flex layout uses row gap for column spacing" {
    var root: GuiObj = layout_box(60, 100);
    var a: GuiObj = layout_box(20, 20);
    var b: GuiObj = layout_box(20, 20);

    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: flex_column_config(Justify.Start, Align.Start, Align.Start, false, 2, 7, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 0, 0, 20, 20);
    try assert_box(&b, 0, 27, 20, 20);
}

test "flex layout uses column gap for wrapped column tracks" {
    var root: GuiObj = layout_box(80, 100);
    var a: GuiObj = layout_box(20, 40);
    var b: GuiObj = layout_box(20, 40);
    var c: GuiObj = layout_box(20, 40);

