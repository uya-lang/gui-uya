    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.Column,
            justify: Justify.Start,
            align_items: Align.Start,
            align_content: Align.Start,
            wrap: true,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [0, 0, 0, 0],
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(a.y as i32, 0);
    try assert_eq_i32(b.x as i32, 0);
    try assert_eq_i32(b.y as i32, 45);
    try assert_eq_i32(c.x as i32, 25);
    try assert_eq_i32(c.y as i32, 0);
}

test "flex layout align content centers wrapped lines" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();
    var c: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 60;
    a.w = 40;
    a.h = 10;
    b.w = 40;
    b.h = 10;
    c.w = 40;
    c.h = 10;
    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.Row,
            justify: Justify.Start,
            align_items: Align.Start,
            align_content: Align.Center,
            wrap: true,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
