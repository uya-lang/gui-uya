test "flex layout supports row justify center" {
    var root: GuiObj = layout_box(100, 40);
    var a: GuiObj = layout_box(20, 10);
    var b: GuiObj = layout_box(20, 10);

    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: flex_row_config(Justify.Center, Align.Start, Align.Start, false, 5, 0, 0),
    };
    layout.apply(&root);

    try assert_box(&a, 27, 0, 20, 10);
    try assert_box(&b, 52, 0, 20, 10);
}

test "flex layout supports row justify end" {
    var root: GuiObj = layout_box(100, 40);
