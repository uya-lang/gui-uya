use core.obj.GuiObj;
use core.obj.gui_obj_default;
use core.obj.gui_obj_register;
use core.obj.gui_obj_reset_registry;
use core.obj_tree.ObjTree;
use core.obj_tree.obj_tree_new;
use layout.auto.AutoLayout;
use layout.auto.LayoutMode;
use layout.auto.auto_layout_new;
use layout.flex.Align;
use layout.flex.FlexConfig;
use layout.flex.FlexDir;
use layout.flex.FlexLayout;
use layout.flex.Justify;
use layout.flex.flex_config_column;
use layout.flex.flex_config_row;
use layout.grid.GridConfig;
use layout.grid.GridAutoFlow;
use layout.grid.GridLayout;
use style.StyleProp;
use std.testing.assert_eq_i32;

export const TEST_LAYOUT_MODULE: i32 = 1;

test "flex layout arranges row children" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 40;
    a.w = 20;
    a.h = 10;
    b.w = 30;
    b.h = 10;
    root.add_child(&a);
    root.add_child(&b);

    var cfg: FlexConfig = flex_config_row();
    cfg.gap = 5;
    cfg.align_items = Align.Center;
    var layout: FlexLayout = FlexLayout{ config: cfg };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(b.x as i32, 25);
    try assert_eq_i32(a.y as i32, 15);
}

test "flex layout supports row reverse order" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 40;
    a.w = 20;
    a.h = 10;
    b.w = 30;
    b.h = 10;
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.RowReverse,
            justify: Justify.Start,
            align_items: Align.Center,
            align_content: Align.Start,
            wrap: false,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [0, 0, 0, 0],
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 80);
    try assert_eq_i32(b.x as i32, 45);
    try assert_eq_i32(a.y as i32, 15);
    try assert_eq_i32(b.y as i32, 15);
}

test "flex layout supports column reverse order" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 60;
    root.h = 100;
    a.w = 20;
    a.h = 20;
    b.w = 10;
    b.h = 30;
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.ColumnReverse,
            justify: Justify.Start,
            align_items: Align.Center,
            align_content: Align.Start,
            wrap: false,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [0, 0, 0, 0],
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.y as i32, 80);
    try assert_eq_i32(b.y as i32, 45);
    try assert_eq_i32(a.x as i32, 20);
    try assert_eq_i32(b.x as i32, 25);
}

test "flex layout honors flex basis overrides" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 30;
    a.w = 10;
    a.h = 10;
    b.w = 10;
    b.h = 10;
    a.style.set_i32(StyleProp.FlexBasis, 30);
    b.style.set_i32(StyleProp.FlexBasis, 20);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_row() };
    layout.apply(&root);

    try assert_eq_i32(a.w as i32, 30);
    try assert_eq_i32(b.w as i32, 20);
    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(b.x as i32, 30);
}

test "flex layout distributes shrink by flex shrink weights" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();

    root.w = 60;
    root.h = 30;
    a.w = 40;
    a.h = 10;
    b.w = 40;
    b.h = 10;
    a.style.set_i32(StyleProp.FlexShrink, 1);
    b.style.set_i32(StyleProp.FlexShrink, 3);
    root.add_child(&a);
    root.add_child(&b);

    var layout: FlexLayout = FlexLayout{ config: flex_config_row() };
    layout.apply(&root);

    try assert_eq_i32(a.w as i32, 35);
    try assert_eq_i32(b.w as i32, 25);
    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(b.x as i32, 35);
}

test "flex layout wraps rows onto multiple lines" {
    var root: GuiObj = gui_obj_default();
    var a: GuiObj = gui_obj_default();
    var b: GuiObj = gui_obj_default();
    var c: GuiObj = gui_obj_default();

    root.w = 100;
    root.h = 40;
    a.w = 40;
    a.h = 10;
    b.w = 40;
    b.h = 10;
    c.w = 40;
    c.h = 10;
    root.add_child(&a);
    root.add_child(&b);
    root.add_child(&c);

    var layout: FlexLayout = FlexLayout{
        config: FlexConfig{
            direction: FlexDir.Row,
            justify: Justify.Start,
            align_items: Align.Start,
            align_content: Align.Start,
            wrap: true,
            gap: 5,
            row_gap: 0,
            col_gap: 0,
            padding: [0, 0, 0, 0],
        },
    };
    layout.apply(&root);

    try assert_eq_i32(a.x as i32, 0);
    try assert_eq_i32(a.y as i32, 0);
    try assert_eq_i32(b.x as i32, 45);
    try assert_eq_i32(b.y as i32, 0);
    try assert_eq_i32(c.x as i32, 0);
    try assert_eq_i32(c.y as i32, 15);
}

