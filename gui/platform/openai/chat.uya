@c_import("openai_chat_stub.c");

extern fn uya_openai_chat_available() i32;
extern fn uya_openai_chat_start(request_body: &const byte, request_len: usize) i32;
extern fn uya_openai_chat_poll(handle: i32, out_body: &byte, out_cap: i32, out_len: &i32) i32;
extern fn uya_openai_chat_cancel(handle: i32) void;
extern fn uya_openai_chat_get_model(out_model: &byte, out_cap: i32) i32;

export enum UyaOpenAiChatStatus {
    Ready,
    Pending,
    InvalidArg,
    Disabled,
    Busy,
    InvalidHandle,
    Cancelled,
    TransportError,
    HttpError,
    ResponseTooLarge,
    ParseError,
    NoContent,
}

export struct UyaOpenAiChatPollResult {
    status: UyaOpenAiChatStatus,
    content_len: i32,
}

fn uya_openai_chat_status_from_raw(raw: i32) UyaOpenAiChatStatus {
    if raw == 0 {
        return UyaOpenAiChatStatus.Ready;
    }
    if raw == 1 {
        return UyaOpenAiChatStatus.Pending;
    }
    if raw == -1 {
        return UyaOpenAiChatStatus.InvalidArg;
    }
    if raw == -2 {
        return UyaOpenAiChatStatus.Disabled;
    }
    if raw == -3 {
        return UyaOpenAiChatStatus.Busy;
    }
    if raw == -4 {
        return UyaOpenAiChatStatus.InvalidHandle;
    }
    if raw == -5 {
        return UyaOpenAiChatStatus.Cancelled;
    }
    if raw == -6 {
        return UyaOpenAiChatStatus.TransportError;
    }
    if raw == -7 {
        return UyaOpenAiChatStatus.HttpError;
    }
    if raw == -8 {
        return UyaOpenAiChatStatus.ResponseTooLarge;
    }
    if raw == -9 {
        return UyaOpenAiChatStatus.ParseError;
    }
    return UyaOpenAiChatStatus.NoContent;
}

export fn uya_openai_chat_is_available() bool {
    return uya_openai_chat_available() > 0;
}

export fn uya_openai_chat_start_request(request_body: &const byte, request_len: usize) i32 {
    if request_body == null || request_len == 0usize {
        return -1;
    }
    return uya_openai_chat_start(request_body, request_len);
}

export fn uya_openai_chat_poll_request(handle: i32, out_body: &byte, out_cap: i32) UyaOpenAiChatPollResult {
    var out_len: i32 = 0;
    if out_body != null && out_cap > 0 {
        out_body[0] = 0;
    }
    const raw: i32 = uya_openai_chat_poll(handle, out_body, out_cap, &out_len);
    return UyaOpenAiChatPollResult{
        status: uya_openai_chat_status_from_raw(raw),
        content_len: out_len,
    };
}

export fn uya_openai_chat_cancel_request(handle: i32) void {
    if handle <= 0 {
        return;
    }
    uya_openai_chat_cancel(handle);
}

export fn uya_openai_chat_model_name(out_model: &byte, out_cap: i32) bool {
    if out_model == null || out_cap <= 0 {
        return false;
    }
    out_model[0] = 0;
    return uya_openai_chat_get_model(out_model, out_cap) > 0;
}

fn uya_openai_chat_is_space(ch: byte) bool {
    return ch == ' ' as u8 || ch == '\n' as u8 || ch == '\r' as u8 || ch == '\t' as u8;
}

export fn uya_openai_chat_parse_action_id(text: &const byte, out_action_id: &i32) bool {
    if text == null || out_action_id == null {
        return false;
    }
    var i: usize = 0usize;
    while text[i] != 0 {
        if text[i] == '"' as u8 {
            if text[i + 1usize] == 'a' as u8
                && text[i + 2usize] == 'c' as u8
                && text[i + 3usize] == 't' as u8
                && text[i + 4usize] == 'i' as u8
                && text[i + 5usize] == 'o' as u8
                && text[i + 6usize] == 'n' as u8
                && text[i + 7usize] == '_' as u8
                && text[i + 8usize] == 'i' as u8
                && text[i + 9usize] == 'd' as u8
                && text[i + 10usize] == '"' as u8 {
                var j: usize = i + 11usize;
                while uya_openai_chat_is_space(text[j]) {
                    j = j + 1usize;
                }
                if text[j] != ':' as u8 {
                    i = i + 1usize;
                    continue;
                }
                j = j + 1usize;
                while uya_openai_chat_is_space(text[j]) {
                    j = j + 1usize;
                }
                var sign: i32 = 1;
                if text[j] == '-' as u8 {
                    sign = -1;
                    j = j + 1usize;
                }
                if text[j] < '0' as u8 || text[j] > '9' as u8 {
                    return false;
                }
                var value: i32 = 0;
                while text[j] >= '0' as u8 && text[j] <= '9' as u8 {
                    value = value * 10 + (text[j] - '0' as u8) as i32;
                    j = j + 1usize;
                }
                out_action_id[0] = value * sign;
                return true;
            }
        }
        i = i + 1usize;
    }
    return false;
}
