export struct Size {
    w: u16,
    h: u16,
}

export const SIZE_ZERO: Size = Size{ w: 0, h: 0 };

Size {
    fn is_empty(self: &Self) bool {
        return self.w == 0 || self.h == 0;
    }

    fn area(self: &Self) u32 {
        return (self.w as u32) * (self.h as u32);
    }

    fn aspect_ratio(self: &Self) f64 {
        if self.h == 0 {
            return 0.0;
        }
        return (self.w as f64) / (self.h as f64);
    }
}
