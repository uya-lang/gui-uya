    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 1024, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const msg: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        const resp_body: &[byte] = &"bad"[0: 3];
        _ = try uip_tcp_write_message(&conn, UIP_FLAG_RESPONSE, UIP_CODEC_RAW, UIP_MSG_EVENT, msg.request_id, resp_body);
        _ = sys_close(cfd) catch {};
