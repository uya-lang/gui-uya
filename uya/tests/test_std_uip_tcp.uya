    var resp_buf: [byte: 1024] = [0:1024];
    const req_body: &[byte] = &"hello"[0: 5];
    const _resp: UipMessage = uip_session_request(&sess, UIP_CODEC_RAW, 0x0101, req_body, &resp_buf[0], 1024) catch {
        uip_session_close(&sess);
        _ = sys_close(listen_fd) catch {};
        var status: i32 = 0;
        _ = sys_waitpid(pid as i32, &status, 0) catch {};
        return;
    };
    try assert_eq_i32(0, 1);
}

test "uip_tcp_ping_pong_roundtrip" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 1024, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const ping: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        try assert_eq_u64((ping.flags & UIP_FLAG_HEARTBEAT) as u64, UIP_FLAG_HEARTBEAT as u64);
        try assert_eq_u64((ping.flags & UIP_FLAG_ONEWAY) as u64, UIP_FLAG_ONEWAY as u64);
        _ = try uip_tcp_write_message(&conn, UIP_FLAG_RESPONSE | UIP_FLAG_HEARTBEAT, UIP_CODEC_RAW, UIP_MSG_PONG, 0, &[]);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 1024);
    var conn: UipTcpConn = try uip_tcp_connect(&cfg);
    _ = try uip_tcp_write_message(&conn, UIP_FLAG_HEARTBEAT | UIP_FLAG_ONEWAY, UIP_CODEC_RAW, UIP_MSG_PING, 0, &[]);
    var buf: [byte: 1024] = [0:1024];
    const pong: UipMessage = try uip_tcp_read_message(&conn, &buf[0], 1024);
    try assert_eq_u64(pong.msg_type as u64, UIP_MSG_PONG as u64);
    try assert_eq_u64((pong.flags & UIP_FLAG_HEARTBEAT) as u64, UIP_FLAG_HEARTBEAT as u64);
    uip_tcp_close(&conn);
    _ = sys_close(listen_fd) catch {};
    var status: i32 = 0;
    _ = sys_waitpid(pid as i32, &status, 0) catch {};
}

test "uip_tcp_ping_oneway_send" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 1024, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const ping: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        try assert_eq_u64(ping.msg_type as u64, UIP_MSG_PING as u64);
        try assert_eq_u64((ping.flags & UIP_FLAG_ONEWAY) as u64, UIP_FLAG_ONEWAY as u64);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 1024);
    var sess: UipSession = UipSession{ conn: try uip_tcp_connect(&cfg), next_request_id: 1 };
    try uip_session_send_ping(&sess);
    uip_session_close(&sess);
    _ = sys_close(listen_fd) catch {};
    var status: i32 = 0;
    _ = sys_waitpid(pid as i32, &status, 0) catch {};
}

test "uip_tcp_oversized_body_rejected" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 4096, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const req: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        var large: [byte: 64] = [0:64];
        var i: usize = 0;
        while i < 64 {
            large[i] = 'A' as byte;
            i = i + 1;
        }
        const resp_body: &[byte] = &large[0: 64];
        _ = try uip_tcp_write_message(&conn, UIP_FLAG_RESPONSE, UIP_CODEC_RAW, req.msg_type, req.request_id, resp_body);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 8);
    var sess: UipSession = UipSession{ conn: try uip_tcp_connect(&cfg), next_request_id: 1 };
    var resp_buf: [byte: 8] = [0:8];
    const req_body: &[byte] = &"ok"[0: 2];
    const _resp: UipMessage = uip_session_request(&sess, UIP_CODEC_RAW, 0x0102, req_body, &resp_buf[0], 8) catch {
        uip_session_close(&sess);
        _ = sys_close(listen_fd) catch {};
        var status: i32 = 0;
        _ = sys_waitpid(pid as i32, &status, 0) catch {};
        return;
    };
    try assert_eq_i32(0, 1);
}
