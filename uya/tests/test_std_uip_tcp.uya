use std.runtime.entry;
use std.uip.tcp;
use std.uip.types;
use std.uip.session;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use std.http.server.read_port_from_sockaddr_16;
use libc.syscall;

fn uip_test_listen_loopback(port_out: &u16) !i32 {
    const fd: i32 = try sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    var one: i32 = 1;
    _ = sys_setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &one as &void, 4 as u32) catch {};
    var addr: [byte: 16] = [0:16];
    addr[0] = 2;
    addr[1] = 0;
    addr[2] = 0;
    addr[3] = 0;
    addr[4] = 127;
    addr[5] = 0;
    addr[6] = 0;
    addr[7] = 1;
    _ = try sys_bind(fd, &addr[0] as &void, 16 as u32);
    _ = try sys_listen(fd, 4);
    var out: [byte: 16] = [0:16];
    var alen: u32 = 16;
    _ = try sys_getsockname(fd, &out[0] as &void, &alen);
    port_out[0] = read_port_from_sockaddr_16(&out[0] as &byte);
    return fd;
}

fn uip_sleep_ms(ms: i64) void {
    var req: TimeSpec = TimeSpec{ tv_sec: ms / 1000, tv_nsec: ((ms % (1000 as i64)) * (1000000 as i64)) };
    var rem: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 0 };
    _ = sys_nanosleep(&req, &rem) catch {};
}

fn uip_client_cfg(port: u16, max_body_len: usize) UipTcpClientConfig {
    return UipTcpClientConfig{
        host: &"127.0.0.1"[0: 9],
        port: port,
        nameserver: &""[0: 0],
        timeout_ms: 1000,
        max_body_len: max_body_len,
    };
}

test "uip_tcp_request_response_roundtrip" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 1024, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const msg: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        try assert_eq_u64(msg.request_id as u64, 1 as u64);
        const resp_body: &[byte] = &"world"[0: 5];
        _ = try uip_tcp_write_message(&conn, UIP_FLAG_RESPONSE, UIP_CODEC_RAW, msg.msg_type, msg.request_id, resp_body);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 1024);
    var sess: UipSession = UipSession{ conn: try uip_tcp_connect(&cfg), next_request_id: 1 };
    var resp_buf: [byte: 1024] = [0:1024];
    const req_body: &[byte] = &"hello"[0: 5];
    const resp: UipMessage = try uip_session_request(&sess, UIP_CODEC_RAW, 0x0101, req_body, &resp_buf[0], 1024);
    try assert_eq_u64(resp.request_id as u64, 1 as u64);
    try assert_eq_i32(resp.body_len as i32, 5);
    try assert_eq_i32(resp.body[0] as i32, 'w' as i32);
    uip_session_close(&sess);
    _ = sys_close(listen_fd) catch {};
    var status: i32 = 0;
    _ = sys_waitpid(pid as i32, &status, 0) catch {};
}

test "uip_tcp_request_id_mismatch" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        var conn: UipTcpConn = UipTcpConn{ fd: cfd, config: UipConfig{ max_body_len: 1024, timeout_ms: 1000, heartbeat_ms: 30000, enable_checksum: true } };
        var body_buf: [byte: 1024] = [0:1024];
        const msg: UipMessage = try uip_tcp_read_message(&conn, &body_buf[0], 1024);
        const resp_body: &[byte] = &"oops"[0: 4];
        _ = try uip_tcp_write_message(&conn, UIP_FLAG_RESPONSE, UIP_CODEC_RAW, msg.msg_type, msg.request_id + 1, resp_body);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 1024);
    var sess: UipSession = UipSession{ conn: try uip_tcp_connect(&cfg), next_request_id: 1 };
    var resp_buf: [byte: 1024] = [0:1024];
    const req_body: &[byte] = &"hello"[0: 5];
    const _resp: UipMessage = uip_session_request(&sess, UIP_CODEC_RAW, 0x0101, req_body, &resp_buf[0], 1024) catch {
        uip_session_close(&sess);
        _ = sys_close(listen_fd) catch {};
        var status: i32 = 0;
        _ = sys_waitpid(pid as i32, &status, 0) catch {};
        return;
    };
    try assert_eq_i32(0, 1);
}

test "uip_tcp_connection_closed_after_accept" {
    var port: u16 = 0;
    const listen_fd: i32 = try uip_test_listen_loopback(&port);
    const pid: i64 = try sys_fork();
    if pid == 0 {
        var peer: [byte: 16] = [0:16];
        var alen: u32 = 16;
        const cfd: i32 = try sys_accept(listen_fd, &peer[0] as &void, &alen);
        _ = sys_close(cfd) catch {};
        _ = sys_close(listen_fd) catch {};
        sys_exit(0);
    }
    uip_sleep_ms(50);
    var cfg: UipTcpClientConfig = uip_client_cfg(port, 1024);
    var conn: UipTcpConn = try uip_tcp_connect(&cfg);
    var buf: [byte: 1024] = [0:1024];
    const _msg: UipMessage = uip_tcp_read_message(&conn, &buf[0], 1024) catch {
        uip_tcp_close(&conn);
        _ = sys_close(listen_fd) catch {};
        var status: i32 = 0;
        _ = sys_waitpid(pid as i32, &status, 0) catch {};
        return;
    };
    try assert_eq_i32(0, 1);
}

