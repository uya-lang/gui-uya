use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.run_test;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;

struct ChainBox {
    value: i32,
}

ChainBox {
    fn add(self: &Self, x: i32) Self {
        return ChainBox{ value: self.value + x };
    }

    fn mul(self: &Self, x: i32) Self {
        return ChainBox{ value: self.value * x };
    }

    fn tag<T>(self: &Self, extra: T) Self {
        _ = extra;
        return ChainBox{ value: self.value };
    }

    fn get(self: &Self) i32 {
        return self.value;
    }
}

fn test_struct_literal_chain() !void {
    const v: i32 = ChainBox{ value: 2 }.add(3).mul(4).get();
    try assert_eq_i32(v, 20, "struct literal chain should keep calling methods");
}

fn test_generic_method_chain() !void {
    const v: i32 = ChainBox{ value: 5 }.tag<i32>(1).add(2).get();
    try assert_eq_i32(v, 7, "generic method result should continue chaining");
}

fn test_parenthesized_chain() !void {
    const v: i32 = (ChainBox{ value: 7 }).add(1).get();
    try assert_eq_i32(v, 8, "parenthesized expression should continue chaining");
}

fn test_array_literal_chain() !void {
    const v: i32 = [ChainBox{ value: 1 }][0].add(2).get();
    try assert_eq_i32(v, 3, "array literal access should continue chaining");
}

export fn main() i32 {
    test_suite_begin("Struct Method Chain Tests");
    run_test("struct literal chain", test_struct_literal_chain);
    run_test("generic method chain", test_generic_method_chain);
    run_test("parenthesized chain", test_parenthesized_chain);
    run_test("array literal chain", test_array_literal_chain);
    return test_suite_end();
}
