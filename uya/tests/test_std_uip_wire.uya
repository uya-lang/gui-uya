// tests/test_std_uip_wire.uya - UIP Wire 层测试
// 测试 wire.uya 的编解码逻辑

use std.uip.errors;
use std.uip.types;
use std.uip.wire;
use std.testing.testing;

// ============================================================
// 测试辅助
// ============================================================

/// 创建默认配置
fn make_config() UipConfig {
    return UipConfig{
        max_body_len: 65536,
        timeout_ms: 5000,
        heartbeat_ms: 30000,
        enable_checksum: true,
    };
}

/// 创建禁用 checksum 的配置
fn make_config_no_checksum() UipConfig {
    return UipConfig{
        max_body_len: 65536,
        timeout_ms: 5000,
        heartbeat_ms: 30000,
        enable_checksum: false,
    };
}

// ============================================================
// TC-WIRE-01: encode/decode 往返
// ============================================================

test "test_encode_decode_roundtrip" {
    test_suite_begin("TC-WIRE-01: encode/decode roundtrip");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    
    const body: [u8: 5] = [72u8, 101u8, 108u8, 108u8, 111u8];  // "Hello"
    const body_slice: &[byte] = &body[0: 5];
    
    // 编码
    const written: usize = try uip_encode_message(
        UIP_FLAG_REQUEST,
        UIP_CODEC_RAW,
        0x0101,
        12345,
        body_slice,
        &cfg,
        &out_buf[0],
        1024
    );
    
    // 验证写入长度
    expect(written == 24 + 5);
    
    // 验证 magic
    expect(out_buf[0] == 0x55 && out_buf[1] == 0x49 && out_buf[2] == 0x50);
    
    // 验证 version
    expect(out_buf[3] == 1);
    
    // 解码
    var body_buf: [u8: 1024] = [];
    var body_len: usize = 5;
    var i: usize = 0;
    while i < body_len {
        body_buf[i] = out_buf[24 + i];
        i = i + 1;
    }
    
    const msg: UipMessage = try uip_decode_message(
        &out_buf[0],
        24,
        &body_buf[0],
        body_len,
        &cfg
    );
    
    // 验证字段
    try assert_eq_u64(msg.flags as u64, UIP_FLAG_REQUEST as u64);
    try assert_eq_u64(msg.codec as u64, UIP_CODEC_RAW as u64);
    try assert_eq_u64(msg.msg_type as u64, 0x0101 as u64);
    try assert_eq_u64(msg.request_id as u64, 12345 as u64);
    try assert_eq_u64(msg.body_len as u64, 5 as u64);
    
    // 验证 body 内容
    try assert_eq_i64(msg.body.len as i64, 5 as i64);
    var j: usize = 0;
    while j < msg.body.len {
        try assert_eq_i64(msg.body[j] as i64, body[j] as i64);
        j = j + 1;
    }
    
    test_pass("encode/decode roundtrip");
}

// ============================================================
// TC-WIRE-02: 空 body
// ============================================================

test "test_empty_body" {
    test_suite_begin("TC-WIRE-02: empty body");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    
    // 编码空 body
    const written: usize = try uip_encode_message(
        UIP_FLAG_REQUEST,
        UIP_CODEC_RAW,
        UIP_MSG_HELLO,
        1,
        &[],
        &cfg,
        &out_buf[0],
        1024
    );
    
    // 验证长度只有 header
    expect(written == 24);
    
    // 解码
    const msg: UipMessage = try uip_decode_message(
        &out_buf[0],
        24,
        &out_buf[0],
        0,
        &cfg
    );
    
    // 验证 body_len=0, checksum=0
    try assert_eq_u64(msg.body_len as u64, 0 as u64);
    try assert_eq_u64(msg.checksum as u64, 0 as u64);
    try assert_eq_i64(msg.body.len as i64, 0 as i64);
    
    test_pass("empty body");
}

// ============================================================
// TC-WIRE-03: invalid magic
// ============================================================

test "test_invalid_magic" {
    test_suite_begin("TC-WIRE-03: invalid magic");
    
    var cfg: UipConfig = make_config();
    var buf: [u8: 24] = [];
    
    // 写入正常的 header，然后修改 magic
    buf[0] = 0x55;
    buf[1] = 0x49;
    buf[2] = 0x50;
    buf[3] = 1;  // version
    buf[4] = UIP_FLAG_REQUEST;
    buf[5] = UIP_CODEC_RAW;
    // ... 其余字段
    
    // 修改 magic[0] = 0x00
    buf[0] = 0x00;
    
    // 解码应该失败
    const result: UipMessage = uip_decode_message(&buf[0], 24, &buf[0], 0, &cfg) catch {
        test_pass("invalid magic");
        return;
    };
    
    // 如果没有捕获错误，测试失败
    test_fail("should have caught UipInvalidMagic");
}

// ============================================================
// TC-WIRE-04: invalid version
// ============================================================

test "test_unsupported_version" {
    test_suite_begin("TC-WIRE-04: unsupported version");
    
    var cfg: UipConfig = make_config();
    var buf: [u8: 24] = [];
    
    // 写入正常的 header，然后设置 version = 2
    buf[0] = 0x55;
    buf[1] = 0x49;
    buf[2] = 0x50;
    buf[3] = 2;  // version = 2 (不支持)
    buf[4] = UIP_FLAG_REQUEST;
    buf[5] = UIP_CODEC_RAW;
    // ... 其余字段
    
    // 解码应该失败
    const result: UipMessage = uip_decode_message(&buf[0], 24, &buf[0], 0, &cfg) catch {
        test_pass("unsupported version");
        return;
    };
    
    test_fail("should have caught UipUnsupportedVersion");
}

// ============================================================
// TC-WIRE-05: invalid flags (同时设置 REQUEST + RESPONSE)
// ============================================================

test "test_invalid_flags_request_response" {
    test_suite_begin("TC-WIRE-05: invalid flags (REQUEST + RESPONSE)");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    
    // 尝试编码同时设置 REQUEST + RESPONSE 的消息
    const result: usize = uip_encode_message(
        UIP_FLAG_REQUEST | UIP_FLAG_RESPONSE,
        UIP_CODEC_RAW,
        UIP_MSG_HELLO,
        1,
        &[],
        &cfg,
        &out_buf[0],
        1024
    ) catch {
        test_pass("invalid flags rejected");
        return;
    };
    
    test_fail("should have caught UipInvalidFlags");
}

// ============================================================
// TC-WIRE-06: invalid codec
// ============================================================

test "test_invalid_codec" {
    test_suite_begin("TC-WIRE-06: invalid codec");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    
    // 尝试编码 codec = 99 的消息
    const result: usize = uip_encode_message(
        UIP_FLAG_REQUEST,
        99,
        UIP_MSG_HELLO,
        1,
        &[],
        &cfg,
        &out_buf[0],
        1024
    ) catch {
        test_pass("invalid codec rejected");
        return;
    };
    
    test_fail("should have caught UipInvalidCodec");
}

// ============================================================
// TC-WIRE-07: checksum mismatch
// ============================================================

test "test_checksum_mismatch" {
    test_suite_begin("TC-WIRE-07: checksum mismatch");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    
    // 编码正常消息
    const body: [u8: 5] = [72u8, 101u8, 108u8, 108u8, 111u8];  // "Hello"
    const body_slice: &[byte] = &body[0: 5];
    
    const written: usize = try uip_encode_message(
        UIP_FLAG_REQUEST,
        UIP_CODEC_RAW,
        UIP_MSG_HELLO,
        1,
        body_slice,
        &cfg,
        &out_buf[0],
        1024
    );
    
    // 篡改 body
    out_buf[25] = out_buf[25] + 1;
    
    // 解码应该失败
    const result: UipMessage = uip_decode_message(
        &out_buf[0],
        24,
        &out_buf[24],
        5,
        &cfg
    ) catch {
        test_pass("checksum mismatch detected");
        return;
    };
    
    test_fail("should have caught UipChecksumMismatch");
}

// ============================================================
// TC-WIRE-08: body too large
// ============================================================

test "test_message_too_large" {
    test_suite_begin("TC-WIRE-08: body too large");
    
    // 小 max_body_len 配置
    var cfg: UipConfig = UipConfig{
        max_body_len: 10,
        timeout_ms: 5000,
        heartbeat_ms: 30000,
        enable_checksum: true,
    };
    var out_buf: [u8: 1024] = [];
    
    // 尝试编码 100 字节的 body
    var large_body: [u8: 100] = [];
    var i: usize = 0;
    while i < 100 {
        large_body[i] = i as u8;
        i = i + 1;
    }
    const body_slice: &[byte] = &large_body[0: 100];
    
    const result: usize = uip_encode_message(
        UIP_FLAG_REQUEST,
        UIP_CODEC_RAW,
        UIP_MSG_HELLO,
        1,
        body_slice,
        &cfg,
        &out_buf[0],
        1024
    ) catch {
        test_pass("body too large rejected");
        return;
    };
    
    test_fail("should have caught UipMessageTooLarge");
}

// ============================================================
// TC-WIRE-09: truncated header
// ============================================================

test "test_truncated_header" {
    test_suite_begin("TC-WIRE-09: truncated header");
    
    var cfg: UipConfig = make_config();
    var buf: [u8: 10] = [];  // 只有 10 字节
    
    // 写入部分数据
    buf[0] = 0x55;
    buf[1] = 0x49;
    buf[2] = 0x50;
    buf[3] = 1;
    // ... 不完整
    
    // 解码应该失败
    const result: UipMessage = uip_decode_message(&buf[0], 10, &buf[0], 0, &cfg) catch {
        test_pass("truncated header rejected");
        return;
    };
    
    test_fail("should have caught UipInvalidFrame");
}

// ============================================================
// TC-WIRE-10: 大端序读写正确
// ============================================================

test "test_big_endian_u32" {
    test_suite_begin("TC-WIRE-10: big endian u32");
    
    var buf: [u8: 8] = [];
    
    // 写入 u32 = 0x12345678
    const test_val: u32 = 0x12345678;
    
    // 直接写入大端序
    buf[0] = ((test_val >> 24) & 0xFFu32) as byte;
    buf[1] = ((test_val >> 16) & 0xFFu32) as byte;
    buf[2] = ((test_val >> 8) & 0xFFu32) as byte;
    buf[3] = (test_val & 0xFFu32) as byte;
    
    // 读取
    const read_val: u32 = ((buf[0] as u32) << 24) 
                         | ((buf[1] as u32) << 16)
                         | ((buf[2] as u32) << 8)
                         | (buf[3] as u32);
    
    try assert_eq_u64(read_val as u64, test_val as u64);
    
    test_pass("big endian u32");
}

// ============================================================
// TC-WIRE-11: 不同 msg_type 编码解码
// ============================================================

test "test_all_msg_types" {
    test_suite_begin("TC-WIRE-11: all msg types");
    
    var cfg: UipConfig = make_config();
    var out_buf: [u8: 1024] = [];
    var body_buf: [u8: 1024] = [];
    
    const msg_types: [u16: 5] = [
        UIP_MSG_HELLO,
        UIP_MSG_PING,
        UIP_MSG_PONG,
        UIP_MSG_ERROR,
        UIP_MSG_EVENT,
    ];
    
    var i: usize = 0;
    while i < 5 {
        const body: [u8: 3] = [1u8, 2u8, 3u8];
        const body_slice: &[byte] = &body[0: 3];
        
        // 编码
        const written: usize = try uip_encode_message(
            UIP_FLAG_REQUEST,
            UIP_CODEC_RAW,
            msg_types[i],
            i as u32 + 100,
            body_slice,
            &cfg,
            &out_buf[0],
            1024
        );
        
        // 复制 body
        var j: usize = 0;
        while j < 3 {
            body_buf[j] = out_buf[24 + j];
            j = j + 1;
        }
        
        // 解码
        const msg: UipMessage = try uip_decode_message(
            &out_buf[0],
            24,
            &body_buf[0],
            3,
            &cfg
        );
        
        // 验证 msg_type
        try assert_eq_u64(msg.msg_type as u64, msg_types[i] as u64);
        try assert_eq_u64(msg.request_id as u64, (i as u32 + 100) as u64);
        
        i = i + 1;
    }
    
    test_pass("all msg types");
}

// ============================================================
// TC-WIRE-12: PING/PONG 消息创建
// ============================================================

test "test_ping_pong_messages" {
    test_suite_begin("TC-WIRE-12: ping/pong messages");
    
    var cfg: UipConfig = make_config();
    var ping_buf: [u8: 1024] = [];
    var pong_buf: [u8: 1024] = [];
    
    // 创建 PING
    const ping_len: usize = try uip_make_ping(&ping_buf[0], &cfg);
    expect(ping_len == 24);
    
    // 验证 PING flags
    expect(ping_buf[4] == (UIP_FLAG_HEARTBEAT | UIP_FLAG_ONEWAY));
    
    // 验证 PING msg_type
    expect(ping_buf[6] == 0x00 && ping_buf[7] == 0x02);  // UIP_MSG_PING
    
    // 创建 PONG
    const pong_len: usize = try uip_make_pong(&pong_buf[0], &cfg);
    expect(pong_len == 24);
    
    // 验证 PONG flags
    expect(pong_buf[4] == (UIP_FLAG_RESPONSE | UIP_FLAG_HEARTBEAT));
    
    // 验证 PONG msg_type
    expect(pong_buf[6] == 0x00 && pong_buf[7] == 0x03);  // UIP_MSG_PONG
    
    test_pass("ping/pong messages");
}

// ============================================================
// TC-WIRE-13: 禁用 checksum 时校验
// ============================================================

test "test_no_checksum_mode" {
    test_suite_begin("TC-WIRE-13: no checksum mode");
    
    var cfg: UipConfig = make_config_no_checksum();
    var out_buf: [u8: 1024] = [];
    
    const body: [u8: 5] = [72u8, 101u8, 108u8, 108u8, 111u8];
    const body_slice: &[byte] = &body[0: 5];
    
    // 编码（不计算 checksum）
    const written: usize = try uip_encode_message(
        UIP_FLAG_REQUEST,
        UIP_CODEC_RAW,
        UIP_MSG_HELLO,
        1,
        body_slice,
        &cfg,
        &out_buf[0],
        1024
    );
    
    // 篡改 body（不应该被检测到）
    out_buf[25] = out_buf[25] + 1;
    
    // 解码（不应该检测 checksum）
    const msg: UipMessage = try uip_decode_message(
        &out_buf[0],
        24,
        &out_buf[24],
        5,
        &cfg
    );
    
    // 应该成功，因为 checksum 被禁用
    try assert_eq_u64(msg.body_len as u64, 5 as u64);
    
    test_pass("no checksum mode");
}