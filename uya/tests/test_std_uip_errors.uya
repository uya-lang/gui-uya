// test_std_uip_errors.uya - std.uip.errors 模块测试
// TDD 模式：先写测试，再实现

use std.runtime.entry;
use std.uip.errors;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

fn uip_throw_invalid_magic() !void {
    return error.UipInvalidMagic;
}

fn uip_throw_unsupported_version() !void {
    return error.UipUnsupportedVersion;
}

fn uip_throw_invalid_flags() !void {
    return error.UipInvalidFlags;
}

fn uip_throw_timeout() !void {
    return error.UipTimeout;
}

fn uip_throw_conn_closed() !void {
    return error.UipConnectionClosed;
}

fn uip_throw_resolve_failed() !void {
    return error.UipResolveFailed;
}

fn uip_throw_transport_error() !void {
    return error.UipTransportError;
}

fn uip_throw_unsupported_transport() !void {
    return error.UipUnsupportedTransport;
}

fn uip_throw_request_id_mismatch() !void {
    return error.UipRequestIdMismatch;
}

fn uip_throw_checksum_mismatch() !void {
    return error.UipChecksumMismatch;
}

fn uip_throw_message_too_large() !void {
    return error.UipMessageTooLarge;
}

fn uip_level1_checksum() !void {
    return error.UipChecksumMismatch;
}

fn uip_level2_checksum() !void {
    try uip_level1_checksum();
}

fn uip_level3_checksum() !void {
    try uip_level2_checksum();
}

fn uip_return_magic_error() !void {
    return error.UipInvalidMagic;
}

fn uip_return_frame_error() !void {
    return error.UipInvalidFrame;
}

fn uip_try_return_bool() !bool {
    return error.UipMessageTooLarge;
}

fn uip_try_return_usize() !usize {
    return error.UipTimeout;
}

// ========== TC-ERR-01: 验证所有错误类型可被 import ==========
test "TC-ERR-01: all error types can be imported" {
    // 验证所有错误符号都可被引用，并且拥有稳定的非零 error id
    try assert_eq_bool(@error_id(error.UipInvalidMagic) != 0, true);
    try assert_eq_bool(@error_id(error.UipUnsupportedVersion) != 0, true);
    try assert_eq_bool(@error_id(error.UipInvalidFlags) != 0, true);
    try assert_eq_bool(@error_id(error.UipInvalidCodec) != 0, true);
    try assert_eq_bool(@error_id(error.UipInvalidFrame) != 0, true);
    try assert_eq_bool(@error_id(error.UipMessageTooLarge) != 0, true);
    try assert_eq_bool(@error_id(error.UipChecksumMismatch) != 0, true);
    try assert_eq_bool(@error_id(error.UipTimeout) != 0, true);
    try assert_eq_bool(@error_id(error.UipConnectionClosed) != 0, true);
    try assert_eq_bool(@error_id(error.UipResolveFailed) != 0, true);
    try assert_eq_bool(@error_id(error.UipTransportError) != 0, true);
    try assert_eq_bool(@error_id(error.UipUnsupportedTransport) != 0, true);
    try assert_eq_bool(@error_id(error.UipRequestIdMismatch) != 0, true);
}

// ========== TC-ERR-02: 验证错误可被 try-catch 捕获 ==========
test "TC-ERR-02: errors can be caught with try-catch" {
    var caught_magic: bool = false;
    uip_throw_invalid_magic() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipInvalidMagic) as i32);
        caught_magic = true;
    };
    try assert_eq_bool(caught_magic, true);

    var caught_version: bool = false;
    uip_throw_unsupported_version() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipUnsupportedVersion) as i32);
        caught_version = true;
    };
    try assert_eq_bool(caught_version, true);

    var caught_flags: bool = false;
    uip_throw_invalid_flags() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipInvalidFlags) as i32);
        caught_flags = true;
    };
    try assert_eq_bool(caught_flags, true);

    var caught_timeout: bool = false;
    uip_throw_timeout() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipTimeout) as i32);
        caught_timeout = true;
    };
    try assert_eq_bool(caught_timeout, true);

    var caught_closed: bool = false;
    uip_throw_conn_closed() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipConnectionClosed) as i32);
        caught_closed = true;
    };
    try assert_eq_bool(caught_closed, true);

    var caught_resolve: bool = false;
    uip_throw_resolve_failed() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipResolveFailed) as i32);
        caught_resolve = true;
    };
    try assert_eq_bool(caught_resolve, true);

    var caught_transport: bool = false;
    uip_throw_transport_error() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipTransportError) as i32);
        caught_transport = true;
    };
    try assert_eq_bool(caught_transport, true);

    var caught_unsupported_transport: bool = false;
    uip_throw_unsupported_transport() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipUnsupportedTransport) as i32);
        caught_unsupported_transport = true;
    };
    try assert_eq_bool(caught_unsupported_transport, true);

    var caught_request_id: bool = false;
    uip_throw_request_id_mismatch() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipRequestIdMismatch) as i32);
        caught_request_id = true;
    };
    try assert_eq_bool(caught_request_id, true);
}

// ========== TC-ERR-03: 验证 catch-all 捕获 ==========
test "TC-ERR-03: catch-all captures all errors" {
    var caught: bool = false;
    uip_throw_checksum_mismatch() catch |err| {
        _ = err;
        caught = true;
    };
    try assert_eq_bool(caught, true);

    caught = false;
    uip_throw_message_too_large() catch |err| {
        _ = err;
        caught = true;
    };
    try assert_eq_bool(caught, true);
}

// ========== TC-ERR-04: 错误可传播 through 函数调用 ==========
test "TC-ERR-04: errors propagate through function calls" {
    var caught: bool = false;
    uip_level3_checksum() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipChecksumMismatch) as i32);
        caught = true;
    };
    try assert_eq_bool(caught, true);
}

// ========== TC-ERR-05: 错误可作为函数返回值类型 ==========
test "TC-ERR-05: errors can be used as return types" {
    _ = uip_return_magic_error() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipInvalidMagic) as i32);
        return;
    };
    try assert_eq_bool(false, true);

    _ = uip_return_frame_error() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipInvalidFrame) as i32);
        return;
    };
    try assert_eq_bool(false, true);
}

// ========== TC-ERR-06: 错误在 error union 中的行为 ==========
test "TC-ERR-06: errors work in error union types" {
    var caught: bool = false;
    uip_try_return_bool() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipMessageTooLarge) as i32);
        caught = true;
    };
    try assert_eq_bool(caught, true);

    caught = false;
    uip_try_return_usize() catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.UipTimeout) as i32);
        caught = true;
    };
    try assert_eq_bool(caught, true);
}
