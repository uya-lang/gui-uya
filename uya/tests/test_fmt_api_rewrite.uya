use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.fmt.FormatOptions;
use std.fmt.fmt.format_with_options;
use std.fmt.rewrite.RewriteRule;
use std.fmt.rewrite.parse_rewrite_rule;

fn index_of(haystack: &[byte], needle: &[byte]) i32 {
    if needle.len == 0 || haystack.len < needle.len {
        return -1;
    }
    var i: usize = 0;
    while i + needle.len <= haystack.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if haystack.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return i as i32;
        }
        i = i + 1;
    }
    return -1;
}

fn test_format_with_rewrite() !void {
    var arena_buf: [byte: 32768] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 32768);

    const rule: RewriteRule = try parse_rewrite_rule(&a, "foo.bar -> bar" as &[byte]);
    const opts: FormatOptions = FormatOptions {
        sort_imports: false,
        simplify: false,
        rewrite_rule: rule,
        has_rewrite_rule: true,
    };
    const out: &[byte] = try format_with_options(&a, "fn main(){return foo.bar;}" as &[byte], opts);

    try assert_eq_i32(index_of(out, "return bar;" as &[byte]) >= 0 as i32, true as i32);
}

export fn main() i32 {
    test_suite_begin("fmt api rewrite tests");
    run_test("format with rewrite", test_format_with_rewrite);
    return test_suite_end();
}
